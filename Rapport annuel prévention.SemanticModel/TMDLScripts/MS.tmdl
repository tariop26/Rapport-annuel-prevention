			measure '# adhérents fin validité FE dans les 6 mois' = ```
					
					CALCULATE(
					    'Evolution effectif'[# adhérents à jour de FE (fin de période)],    -- Mesure à calculer
					    'Evolution effectif - date prochaine FE'[Date] <= TODAY() + 183,    -- Filtre pour inclure les dates dans les 6 prochains mois
					    'Evolution effectif - date prochaine FE'[Date] > TODAY()            -- Filtre pour exclure les dates passées
					)
					
					-- Description : Cette mesure calcule le nombre d'adhérents dont la fin de validité de la fiche d'évaluation (FE) est dans les 6 prochains mois.
