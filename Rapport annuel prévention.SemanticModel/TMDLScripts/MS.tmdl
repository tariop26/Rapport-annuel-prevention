			measure '% Variation Tx de service S-2 à S-1' = ```
					
					VAR TxServiceS2 = [Tx de service S-1] -- Taux de service pour la semaine S-1
					VAR TxServiceS3 = [Tx de service S-2] -- Taux de service pour la semaine S-2
					
					RETURN
					    DIVIDE(
					        TxServiceS2 - TxServiceS3,      -- Calculer la différence entre S-1 et S-2
					        TxServiceS3,                    -- Diviser par le taux de service de S-2
					        0                               -- Valeur par défaut si le dénominateur est zéro, pour éviter les erreurs
					    )
					
					-- Cette mesure calcule le pourcentage de variation du taux de service entre les semaines S-2 et S-1.
					-- Elle utilise des variables pour stocker les taux de service des deux semaines et la fonction DIVIDE pour gérer les divisions par zéro.
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Retard
				lineageTag: 5b538f3a-dbbe-49bc-b59f-2034a7a9f46c

			measure 'Effectif déclaré Année-1' = ```
					
					VAR AnneePrecedente = YEAR(TODAY()) - 1                         -- Calculer l'année précédente
					VAR PremierMarsAnneePrecedente = DATE(AnneePrecedente, 3, 1)    -- Date du 1er mars de l'année dernière
					
					RETURN
					    IF(
					        AnneePrecedente = 2024,
					        174498,                                                     -- Valeur fixe pour 2024 en raison de l'absence de déclaration sur PADOA
					        CALCULATE(
					            'Evolution effectif'[Effectif déclaré début de période],
					            'Date principale'[Date] = PremierMarsAnneePrecedente    -- Filtrer sur la date du 1er mars de l'année dernière
					        )
					    )
					
					-- Description :
					-- Cette mesure calcule l'effectif déclaré au 1er mars de l'année précédente.
					-- Si l'année précédente est 2024, elle retourne une valeur fixe en raison de l'absence de déclaration sur PADOA.
					-- Elle utilise des variables pour stocker l'année précédente et la date du 1er mars, et applique un filtre dans CALCULATE pour obtenir l'effectif déclaré.
					
					```
				formatString: 0
				displayFolder: Effectif
				lineageTag: bfcdbec0-af22-4759-9a82-9a6e7625b84d

			measure 'NBre d''embauche Année-1 facturée' = ```
					
					VAR AnneePrecedente = YEAR(TODAY()) - 1                                         -- Calculer l'année précédente
					
					RETURN
					    CALCULATE(
					        [Nombre total d'actes facturables],                                     -- Mesure de base à calculer
					        'Facturation - article'[Type facturation] = "Nouvelle embauche",        -- Filtrer sur le type de facturation "Nouvelle embauche"
					        'Facturation - date facture'[Année facture] = AnneePrecedente           -- Filtrer sur l'année précédente
					    )
					
					-- Description :
					-- Cette mesure calcule le nombre d'actes facturables pour les nouvelles embauches effectuées l'année précédente.
					-- Elle utilise une variable pour stocker l'année précédente et applique des filtres dans CALCULATE pour obtenir le nombre d'actes facturables.
					
					```
				formatString: 0
				displayFolder: Effectif
				lineageTag: 2c6e7876-dc7b-4a98-ac99-71c03194ee71

			measure 'NBre d''embauche Année-1' = ```
					
