			measure 'Fin Dernier Mois' = ```
					
					VAR DateActuelle = TODAY()                      // Obtient la date actuelle
					VAR FinMoisDernier = EOMONTH(DateActuelle, -1)  // Calcule la fin du mois précédent
					
					RETURN
					    FORMAT(FinMoisDernier, "dd/MM/yyyy")        // Formate la date au format jour/mois/année
					
					/*
					Description :
					Cette mesure calcule la date de fin du mois précédent par rapport à la date actuelle.
