					    BLANK()
					    )                                 // Retourne le nombre de demandes ou 0 si la valeur est vide
					
					/*
					Description :
					Cette mesure retourne le nombre de demandes de visites adhérents.
					Si la valeur est vide ou nulle, elle retourne 0 grâce à l'utilisation de la fonction COALESCE.
					*/
					
					```
				formatString: #,0
				displayFolder: Demandes de RDV
				lineageTag: 4bb511ac-2097-4340-8f86-fa749ce66a0b

			measure 'détails salariés convocables' = ```
					
					VAR DateExtractionJMoins1 =                 -- Variable au nom explicite
					    TODAY() - 1                              -- Calcule la date de la veille (entier date DAX)
					VAR DateExtractionJMoins1Texte =             -- Prépare le texte formaté en français (évite conversions implicites)
					    FORMAT(
					        DateExtractionJMoins1,               -- Valeur à formater
					        "dd mmmm yyyy",                 -- Format lisible en FR (ex: lundi 07 août 2025)
					        "fr-FR"                              -- Locale explicite pour noms de jours/mois en français
					    )                                        -- FORMAT renvoie du texte (affichage uniquement)[1][5]
					RETURN
					    "* le nombre de salariés convocables est au jour de l'extraction, soit le "  -- Préfixe fixe
					    & DateExtractionJMoins1Texte             -- Concaténation avec la date formatée (évite conversion implicite)
					    /* Description:
					       Cette mesure retourne une phrase explicative destinée à l’affichage,
					       indiquant que le nombre de salariés convocables est évalué à la date de l’extraction (J-1),
					       avec une date formatée en français via FORMAT et la locale "fr-FR".
					       À utiliser dans des cartes/visuels de texte; la mesure renvoie du texte et n’est pas
					       destinée à des calculs numériques. */
					
					```
				displayFolder: Divers
				lineageTag: 5d1c71b1-1831-435b-ab3f-4250fdb83aa2

			measure 'titre Nbre de visites fonction publique réalisées le mois dernier' =
					
					VAR DateMoisDernier = EDATE(TODAY(), -1)                            -- Calcul de la date du mois dernier
					VAR DateFormatee = FORMAT(DateMoisDernier, "Mmmm yyyy", "fr-FR")    -- Formatage de la date
					RETURN
					"Nombre de visites fonction publique réalisées en " & DateFormatee                    -- Concaténation du texte avec la date formatée
					
					-- Description : Cette mesure calcule le nombre de visites réalisées le mois dernier et retourne un texte formaté indiquant le mois et l'année.
				displayFolder: Titres
				lineageTag: 6dcd096f-d61a-4c1f-9963-df98a4049949

			measure 'titre répartition des FE réalisées le mois dernier' = ```
					
					"Répartition des FE réalisées en " & 
					FORMAT(EDATE(TODAY(), -1), "Mmmm yyyy", "fr-FR")
					```
				displayFolder: Titres
				lineageTag: 7e6cd7ee-a8df-474b-a24d-00e1095590fc

			measure 'Nombre de visites mois N-12 (mois complet)' =
					
					VAR VisitesBase = [Nombre de visites réalisées (RDV)] // Mesure de base; doit respecter les filtres de dates
					VAR MoisCourant_Debut = STARTOFMONTH('Date principale'[Date])-13 // Début du mois dans le contexte courant
					VAR MoisCourant_Fin = ENDOFMONTH('Date principale'[Date])-13 // Fin du mois dans le contexte courant
					VAR MoisCourant_Complet = DATESBETWEEN('Date principale'[Date], MoisCourant_Debut, MoisCourant_Fin) // Plage du mois complet courant
					RETURN
					CALCULATE(
					VisitesBase, // Réévalue la mesure de base
					SAMEPERIODLASTYEAR(MoisCourant_Complet) // Décale exactement la même plage d’un an
					)
				formatString: #,0
				displayFolder: Visites
				lineageTag: 3cd1a99b-fb6f-4043-afb0-e9c4e9213d64

			measure DateLastYear = month(EOMONTH(TODAY(),-13))
				formatString: 0
				displayFolder: Date
				lineageTag: 03b6c40e-cde5-4599-9a1a-7d705dfddc75

			measure 'Nombre de visites (Mois dernier)' = ```
					
					VAR DateActuelle = TODAY()                                                          -- Obtenir la date actuelle
					VAR PremierJourMoisActuel = DATE(YEAR(DateActuelle), MONTH(DateActuelle), 1)        -- Premier jour du mois actuel
					VAR PremierJourPenultiemeMois = EDATE(PremierJourMoisActuel, -1)                    -- Premier jour du pénultième mois
					VAR DernierJourPenultiemeMois = EOMONTH(PremierJourPenultiemeMois, 0)               -- Dernier jour du pénultième mois
					VAR DatesPenultiemeMois =
					    FILTER(
					        'Date principale',
					        'Date principale'[Date] >= PremierJourPenultiemeMois &&
					        'Date principale'[Date] <= DernierJourPenultiemeMois
					    )                                                                               -- Table de dates du pénultième mois
					RETURN
					CALCULATE(
					    [Nombre de visites réalisées (RDV)],                                            -- Calculer le nombre de visites
					    DatesPenultiemeMois                                                             -- Filtrer par les dates du pénultième mois
					)
					
					-- Cette mesure calcule le nombre de visites pour le pénultième mois.
					-- Elle utilise des variables pour définir les dates de début et de fin du pénultième mois,
					-- puis filtre les visites en conséquence pour évaluer le nombre total de visites.
					
					```
				formatString: 0
				displayFolder: Visites
				lineageTag: 61e4f46c-6a02-474c-8700-eca6b3450f48

			measure 'Semaine derniere détaillée' = ```
					
					VAR DateActuelle = TODAY()                                                              // Obtient la date actuelle
					VAR PremierJourDerniereSemaine = DateActuelle - 7 - WEEKDAY(DateActuelle - 7, 2) + 1       // Calcule le lundi de la semaine derniere
					VAR DernierJourDerniereSemaine = PremierJourDerniereSemaine + 6                                   // Calcule le dimanche de la semaine derniere
					VAR NumeroSemaine = WEEKNUM(DateActuelle - 7, 21)                                      // Calcule le numéro de la semaine ISO
					
					RETURN
					    "Semaine n° " & NumeroSemaine & " : " &
					    FORMAT(PremierJourDerniereSemaine, "dddd d mmmm", "fr-FR") & " - " &                     // Formate le premier jour
					    FORMAT(DernierJourDerniereSemaine, "dddd d mmmm", "fr-FR")                               // Formate le dernier jour
					
					/*
					Description :
					Cette mesure fournit des détails sur la pénultième semaine par rapport à la date actuelle.
					Elle affiche le numéro de la semaine ISO ainsi que les dates du lundi et du dimanche de cette semaine, formatées en français.
					*/
					
					```
				displayFolder: Date
				lineageTag: 8d932028-77be-4d12-9c31-2d5e8aecb9e6

			measure 'Effectif en retard S-2 remove filter' = ```
					
					VAR CatRetard = "En retard" -- Valeur cible pour la catégorie "retard" 
					VAR IndS2 = "S-2" -- Valeur cible pour l’indicateur S-2 
					RETURN
					CALCULATE( 
					'Evolution retard'[Nombre de salariés suivis], -- Mesure agrégée de référene '
					'Evolution retard - catégorie retard'[Catégorie retard] = CatRetard, 
					'Date principale'[Indicateur S-2] = IndS2, 
					REMOVEFILTERS('Date principale')
					)
					```
				formatString: 0
				displayFolder: Retard
				lineageTag: 6cdaac9e-47c6-4924-af28-37777607fe1f

