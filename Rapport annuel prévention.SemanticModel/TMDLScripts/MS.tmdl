			column NomMoisAnneeRaccourcii = FORMAT('Date principale'[Date], "Mmm 'yy", "Fr-fr")
				lineageTag: 8e7a3c9c-7d69-4516-aa24-cc2eff4a2cc6
				summarizeBy: none
				sortByColumn: 'Numéro mois'

				changedProperty = Name

				changedProperty = SortByColumn

				annotation SummarizationSetBy = Automatic

			column 'Ordre Mois' = YEAR('Date principale'[Date]) * 100 + MONTH('Date principale'[Date])
				formatString: 0
				lineageTag: ffc54b17-226e-4a37-b0b8-145ab763041d
				summarizeBy: sum

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column 'Filtre Période 12 mois ajustés' = ```
					
					VAR today = TODAY()
					VAR DateFin = EOMONTH(today, 0) -- Dernier jour du mois actuel
					VAR DateDebut = DATE(YEAR(DateFin), MONTH(DateFin) - 12, 1) -- Premier jour du mois, 12 mois en arrière
					RETURN
					IF(
					    'Date principale'[Date] >= DateDebut &&
					    'Date principale'[Date] <= DateFin,
					    TRUE(),
					    FALSE()
					)
					
					
					-- Description :
					-- Cette colonne vérifie si une date donnée se situe dans les 12 derniers mois complets par rapport à la date maximale de la colonne 'Date principale'.
					-- Elle retourne TRUE si la date est dans cette période, sinon FALSE.
					-- Permet d'inclure les données du mois entier M-12 
					
					```
				formatString: """TRUE"";""TRUE"";""FALSE"""
				lineageTag: 264b0c5b-06b2-47e6-9511-b536208f789a
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column 'Filtre Période 6 mois ajustés' = ```
					
					VAR today = TODAY()
					VAR DateFin = EOMONTH(today, 0) -- Dernier jour du mois actuel
					VAR DateDebut = DATE(YEAR(DateFin), MONTH(DateFin) - 6, 1) -- Premier jour du mois, 6 mois en arrière
					RETURN
					IF(
					    'Date principale'[Date] >= DateDebut &&
					    'Date principale'[Date] <= DateFin,
					    TRUE(),
					    FALSE()
					)
					
					
					-- Description :
					-- Cette colonne vérifie si une date donnée se situe dans les 6 derniers mois complets par rapport à la date maximale de la colonne 'Date principale'.
					-- Elle retourne TRUE si la date est dans cette période, sinon FALSE.
					-- Permet d'inclure les données du mois entier M-6. 
					```
				formatString: """TRUE"";""TRUE"";""FALSE"""
				lineageTag: d265e495-8fd9-485d-a7f1-a82c5c1c895d
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column 'Indicateur M-1' = ```
					
					VAR AujourdHui = TODAY()
					VAR PremierJourMoisActuel = DATE(YEAR(AujourdHui), MONTH(AujourdHui), 1)
					VAR PremierJourMoisPrecedent = DATE(YEAR(PremierJourMoisActuel), MONTH(PremierJourMoisActuel) - 1, 1)
					VAR DernierJourMoisPrecedent = EOMONTH(PremierJourMoisPrecedent, 0)
					
					RETURN
					    IF(
					        'Date principale'[Date] >= PremierJourMoisPrecedent && 'Date principale'[Date] <= DernierJourMoisPrecedent,
					        "Mois Précédent",
					        "Autre"
					    )
					
					    -- Ajout d'une colonne qui indique si la date fait partie du Mois précédent ou non. 
					
					```
				lineageTag: 73763a6a-451d-422f-9b09-41aed7935822
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column 'Indicateur M-2' = ```
					
					VAR AujourdHui = TODAY()
					VAR PremierJourMoisActuel = DATE(YEAR(AujourdHui), MONTH(AujourdHui), 1)
					VAR PremierJourMoisNmoins2 = DATE(YEAR(PremierJourMoisActuel), MONTH(PremierJourMoisActuel) - 2, 1)
					VAR DernierJourMoisNmoins2 = EOMONTH(PremierJourMoisNmoins2, 0)
					
					RETURN
					    IF(
					        'Date principale'[Date] >= PremierJourMoisNmoins2 && 'Date principale'[Date] <= DernierJourMoisNmoins2,
					        "Mois N-2",
					        "Autre"
					    )
					
					```
				lineageTag: 9f404f1d-903d-4ae1-a017-f91a79715aa1
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column 'Indicateur S-1' = ```
					
					VAR AujourdHui = TODAY()
					VAR DebutSmoins1 = AujourdHui - 7 - WEEKDAY(AujourdHui - 7, 1) + 1
					VAR FinSmoins1 = DebutSmoins1 + 6
					
					RETURN
					IF('Date principale'[date] >= DebutSmoins1 && 'Date principale'[date] <= FinSmoins1, "S-1", "Autre")
					
					```
				lineageTag: cabc605d-afc7-4000-ba48-f189e776f9dd
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column 'Indicateur S-2' = ```
					
					VAR AujourdHui = TODAY()
					VAR DebutPenultieme = AujourdHui - 14 - WEEKDAY(AujourdHui - 14, 1) + 1
					VAR FinPenultieme = DebutPenultieme + 6
					
					RETURN
					IF('Date principale'[date] >= DebutPenultieme && 'Date principale'[date] <= FinPenultieme, "S-2", "Autre")
					
					```
				lineageTag: f0e32dee-fc7b-43e2-8e6a-8762aabd9d0b
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column 'Indicateur S-3' = ```
					
					VAR AujourdHui = TODAY()
					VAR DebutSmoins3 = AujourdHui - 21 - WEEKDAY(AujourdHui - 21, 2) + 1
					VAR FinSmoins3 = DebutSmoins3 + 6
					
					RETURN
					IF(
					    'Date principale'[date] >= DebutSmoins3 && 'Date principale'[date] <= FinSmoins3, 
					    "S-3", 
					    "Autre"
					    )
					
					```
				lineageTag: 50653351-e399-41db-9ab0-24a09f542e6d
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

			column EstJourOuvré = ```
					
					VAR Jour = WEEKDAY('Date principale'[Date], 2) // Lundi=1, Dimanche=7
					VAR Mois = MONTH('Date principale'[Date])
					VAR JourDuMois = DAY('Date principale'[Date])
					VAR Annee = YEAR('Date principale'[Date])
					
					// --- Calcul de la date de Pâques (algorithme de Gauss) ---
					VAR a = MOD(Annee, 19)
					VAR b = QUOTIENT(Annee, 100)
					VAR c = MOD(Annee, 100)
					VAR d = QUOTIENT(b, 4)
					VAR e = MOD(b, 4)
					VAR f = QUOTIENT(b + 8, 25)
					VAR g = QUOTIENT(b - f + 1, 3)
					VAR h = MOD(19 * a + b - d - g + 15, 30)
					VAR i = QUOTIENT(c, 4)
					VAR k = MOD(c, 4)
					VAR l = MOD(32 + 2 * e + 2 * i - h - k, 7)
					VAR m = QUOTIENT(a + 11 * h + 22 * l, 451)
					VAR MoisPaques = QUOTIENT(h + l - 7 * m + 114, 31)
					VAR JourPaques = MOD(h + l - 7 * m + 114, 31) + 1
					VAR DatePaques = DATE(Annee, MoisPaques, JourPaques)
					
					// --- Jours fériés fixes ---
					VAR EstFerieFixe =
					    (Mois = 1 && JourDuMois = 1)      || // 1er janvier
					    (Mois = 5 && JourDuMois = 1)      || // 1er mai
					    (Mois = 5 && JourDuMois = 8)      || // 8 mai
					    (Mois = 7 && JourDuMois = 14)     || // 14 juillet
					    (Mois = 8 && JourDuMois = 15)     || // Assomption
					    (Mois = 11 && JourDuMois = 1)     || // Toussaint
					    (Mois = 11 && JourDuMois = 11)    || // Armistice
					    (Mois = 12 && JourDuMois = 25)       // Noël
					
					// --- Jours fériés mobiles (liés à Pâques) ---
					VAR EstFerieMobile =
					    'Date principale'[Date] = DatePaques + 1   || // Lundi de Pâques
					    'Date principale'[Date] = DatePaques + 39  || // Ascension
					    'Date principale'[Date] = DatePaques + 50     // Lundi de Pentecôte
					
					VAR EstWeekend = Jour IN {6, 7}
					RETURN
					IF(EstWeekend || EstFerieFixe || EstFerieMobile, FALSE, TRUE)
					
					```
				formatString: """TRUE"";""TRUE"";""FALSE"""
				lineageTag: 439e9a8d-a08c-46be-b563-25693a7ef78e
				summarizeBy: none

				changedProperty = Name

				annotation SummarizationSetBy = Automatic

