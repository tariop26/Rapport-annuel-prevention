			measure 'max demande de rdv mensuel non filtré' =
					
					VAR DemandesParMois =
					    CALCULATETABLE(
					        SUMMARIZE(
					            'Demande visite adhérent',
					            'Date principale'[Mois], // Groupe par mois
					            "TotalDemandes", [Nombre de demandes de visite adhérent] // Utilise la mesure directement pour obtenir le nombre de demandes pour chaque mois
					        ),
					        ALLSELECTED('Demande visite adhérent') // Ignore les filtres visuels mais conserve d'autres contextes de filtre
					    )
					RETURN
					    MAXX(
					        DemandesParMois, // Itère sur chaque mois
					        [TotalDemandes] // Retourne le maximum des demandes de visite pour chaque mois
					    ) * 1.2 // Multiplie le résultat par 1.2
					
					/*
					Description du rôle de la mesure :
					Cette mesure calcule le nombre maximum de demandes de rendez-vous pour chaque mois,
					en ignorant les filtres visuels appliqués.
					Elle utilise la mesure 'Nombre de demandes de visite adhérent' pour obtenir le nombre de demandes,
					et groupe les résultats par mois pour calculer le maximum des demandes de visite pour chaque mois individuellement.
					Le résultat est ensuite multiplié par 1.2 pour ajuster la valeur.
					*/
				displayFolder: Demandes de RDV
				lineageTag: c267ae82-cfb8-43ff-a6bd-70641f24cca6

				annotation PBI_FormatHint = {"isGeneralNumber":true}

