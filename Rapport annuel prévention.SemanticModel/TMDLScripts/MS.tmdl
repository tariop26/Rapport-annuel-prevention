			column 'Type (FE ou autre)' =
					SWITCH(
						TRUE,
						ISBLANK('AMT - informations principales'[Type]),
						"(Vide)",
						'AMT - informations principales'[Type] IN {"Fiche d'entreprise"},
						"FE",
						"Autre"
					)
