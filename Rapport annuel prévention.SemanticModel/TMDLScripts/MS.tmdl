			measure '% adhérents avec FE à jour (fin de période)' = ```
					
					VAR AdherentsAJour = 'Evolution effectif'[# adhérents à jour de FE (fin de période)]        -- Nombre d'adhérents avec FE à jour
					VAR AdherentsEligibles = 'Evolution effectif'[# adhérents éligibles FE (fin de période)]    -- Nombre total d'adhérents éligibles
					
					RETURN
					    IF(
					        AdherentsEligibles = 0,
					        BLANK(),                                                                            -- Retourne une valeur vide si le dénominateur est zéro
					        DIVIDE(AdherentsAJour, AdherentsEligibles, 0)                                       -- Calcule le pourcentage, en évitant la division par zéro
					    )
					
					-- Description : Cette mesure calcule le pourcentage d'adhérents dont la fiche d'évaluation (FE) est à jour à la fin de la période.
					-- Elle utilise les mesures [# adhérents à jour de FE (fin de période)] et [# adhérents éligibles FE (fin de période)] pour effectuer le calcul.
					
