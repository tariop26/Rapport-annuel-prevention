			measure '% Annulation pour Contraintes de Service' = ```
					
					VAR AnnulationsContraintesService = [Nombre annulation pour contraintes de service]     -- Nombre d'annulations pour contraintes de service
					VAR TotalRDV = [Nombre de RDV]                                                          -- Nombre total de rendez-vous
					
