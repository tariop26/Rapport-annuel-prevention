			/// Affiche le premier jour de l'avant dernière semaine (le lundi)
			measure 'Début Pénultième Semaine' = ```
					
					VAR DateActuelle = TODAY()                                                              // Obtient la date actuelle
					VAR DebutPenultiemeSemaine = DateActuelle - 14 - WEEKDAY(DateActuelle - 14, 2) + 1      // Calcule le lundi de la pénultième semaine
					
					RETURN
					    DebutPenultiemeSemaine
					
					/*
					Description :
					Cette mesure calcule le premier jour (lundi) de la pénultième semaine par rapport à la date actuelle.
					Elle utilise la fonction WEEKDAY pour déterminer le jour de la semaine et ajuste en conséquence pour obtenir le lundi.
					*/
					
					```
				formatString: dddd d mmmm yyyy
				displayFolder: Date
				lineageTag: 91508876-9788-4eab-9bc1-b14a4f22f3bb

				annotation PBI_FormatHint = {"isCustom":true}

			measure 'Données à jour à la fin du mois dernier' = ```
					
					VAR FinMoisDernier = [Fin Dernier Mois]                     // Récupère la date de fin du dernier mois
