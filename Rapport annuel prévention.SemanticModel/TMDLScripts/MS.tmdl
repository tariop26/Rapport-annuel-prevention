					CALCULATE(
					    [Nombre d'EPD actives],                     -- mesure du nombre d'EPD actives
					    FILTER(
					        ALL('Equipe médicale'),                  -- on enlève le filtre sur la table 'Equipe médicale'
					        [Nombre de téléconsultations] > 0       -- filtre sur mesure Téléconsultations
					    )
