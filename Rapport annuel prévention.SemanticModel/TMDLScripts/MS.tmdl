			measure 'Nbre d''AMT terminées' =
					
					VAR TotalAMTTerminees = 'AMT v2'[# AMT terminées]
					VAR Result =
					IF(
					    ISBLANK(TotalAMTTerminees),
					    BLANK(),
					    TotalAMTTerminees
					)
					RETURN
					Result
					
					/*
					Description du rôle de la mesure :
					Cette mesure calcule le nombre d'AMT terminées. Elle vérifie d'abord si la valeur de la colonne 'AMT v2'[# AMT terminées] est vide.
					Si c'est le cas, elle retourne une valeur vide (BLANK()), sinon elle retourne la valeur de la colonne.
					L'utilisation de variables et de la fonction ISBLANK améliore la lisibilité et les performances de la mesure.
					*/
				formatString: #,0
				displayFolder: AMT
				lineageTag: ae8e30e1-a61e-4675-a9bc-532cb6d6dcf2

			measure 'max demande de rdv mensuel pour échelle Y' = ```
					
					VAR DateMax = MAX('Date principale'[Date]) // Obtient la date maximale dans la table
					VAR DateMin = EDATE(DateMax, -12) // Calcule la date il y a 12 mois à partir de la date maximale
					VAR Demandes12DerniersMois =
					    CALCULATETABLE(
					        SUMMARIZE(
					            'Demande visite adhérent',
					            'Date principale'[Mois], // Groupe par mois
					            "MaxDemandes", CALCULATE(
					                [Nombre de demandes de visite adhérent], // Calcule le maximum des demandes de visite pour chaque mois
					                ALL('Demande visite adhérent') // Ignore tous les filtres sur la table 'Demande visite adhérent'
					            )
					        ),
					        FILTER(
					            ALL('Date principale'),
					            'Date principale'[Date] >= DateMin && 'Date principale'[Date] <= DateMax // Filtre pour les 12 derniers mois
					        )
					    )
					RETURN
					    MAXX(
					        Demandes12DerniersMois, // Itère sur chaque mois
					        [MaxDemandes] // Retourne le maximum des demandes de visite pour chaque mois
					    ) * 1.2 // Multiplie le résultat par 1.2 pour ajuster la valeur
					
					/*
					Description du rôle de la mesure :
					Cette mesure calcule le nombre maximum de demandes de rendez-vous pour chaque mois,
					en ignorant tous les filtres appliqués sur la table 'Demande visite adhérent' et en considérant uniquement les 12 derniers mois.
					Elle utilise la mesure 'Nombre de demandes de visite adhérent' pour obtenir le nombre de demandes,
					et groupe les résultats par mois pour calculer le maximum des demandes de visite pour chaque mois individuellement.
					Le résultat est ensuite multiplié par 1.2 pour ajuster la valeur.
					*/
					
					```
				displayFolder: Demandes de RDV
				lineageTag: c073b736-a238-43bb-9962-c6b152f523e4

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'max demande de rdv mensuel' = ```
					
					VAR DemandesParMois =
					    SUMMARIZE(
					        'Demande visite adhérent',
					        'Date principale'[Mois], // Groupe par mois
					        "TotalDemandes", ('Demande visite adhérent'[Nombre de demandes de visite adhérent]) // Calcule le total des demandes de visite pour chaque mois
					    )
					RETURN
					    MAXX(
					        DemandesParMois, // Itère sur chaque mois
					        [TotalDemandes] // Retourne le maximum des demandes de visite pour chaque mois
					    )
					    *1.2
					
					/*
					Description du rôle de la mesure :
					Cette mesure calcule le nombre maximum de demandes de rendez-vous pour chaque mois.
					Elle utilise la colonne 'Nombre de demandes de visite adhérent' pour obtenir le nombre de demandes,
					et groupe les résultats par mois pour calculer le maximum des demandes de visite pour chaque mois individuellement.
					*/
					
					```
				formatString: 0
				displayFolder: Demandes de RDV
				lineageTag: 30d12c3e-6051-4438-b2b6-4661e5d0b54f

			measure 'Moyenne mobile visites Médecin (12 mois)' = ```
					
					VAR DateMax = MAX('Date principale'[Date]) // Récupère la date maximale dans le contexte actuel
					VAR DateMin = DATEADD('Date principale'[Date], -11, MONTH) // Calcule la date de début de la période de 12 mois en arrière
					
					RETURN
					CALCULATE(
					    AVERAGEX(
					        DATESBETWEEN(
					            'Date principale'[Date], // Utilise la colonne de date appropriée
					            DateMin,
					            DateMax
					        ),
					        [Nombre de visites médecin] // Mesure à moyenner
					    ),
					    DATESBETWEEN('Date principale'[Date], DateMin, DateMax) // Applique le contexte de date
					)
					/*
					Description : Cette mesure calcule la moyenne mobile du nombre de visites chez le médecin sur une période de 12 mois.
					Elle utilise AVERAGEX avec DATESBETWEEN pour s'assurer que le calcul est effectué sur la bonne période glissante.
					Les variables DateMax et DateMin sont utilisées pour définir la fenêtre de 12 mois.
					CALCULATE est utilisé pour s'assurer que le contexte de filtre est correctement appliqué.
					*/
					
					```
				displayFolder: Visites
				lineageTag: 018e51f0-d29d-4f80-ae1d-582c4d6d1a7b

				annotation PBI_FormatHint = {"isGeneralNumber":true}

