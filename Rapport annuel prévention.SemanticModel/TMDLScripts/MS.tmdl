				lineageTag: 3a1c9300-fcc1-45aa-baf7-fe050e5ef7a6

			measure 'Nombre de visites intérimaires IDEST (12 derniers mois)' = ```
					
					VAR DateDernierAn = TODAY() - 365                                                   -- Calculer la date d'il y a un an
					
					RETURN
					    CALCULATE(
					        [Nombre de visites réalisées (RDV)],
					        'Salarié (actuel)'[Contrat intérimaire (actuel)] = "Salarié intérimaire",
					        'RDV/visite - réalisateur'[Role réalisateur] = "IDEST",
					        'Date principale'[Date] >= DateDernierAn,                                   -- Filtrer sur les 12 derniers mois
					        ALL('Adhérent (actuel)'[Type entreprise])
					    )
					
					-- Description :
					-- Cette mesure calcule le nombre de visites intérimaires réalisées par un IDEST sur les 12 derniers mois.
					-- Elle utilise une variable pour stocker la date d'il y a un an et applique un filtre dans CALCULATE pour obtenir le nombre de visites réalisées sur cette période.
					
