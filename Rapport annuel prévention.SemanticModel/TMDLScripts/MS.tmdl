			measure '# adhérents sans FE (fin de période)' = ```
					
					CALCULATE(
					    'Evolution effectif'[# adhérents en retard de FE (fin de période)],     -- Mesure à calculer
					    'Evolution effectif'[date dernière fe] = DATE(1900, 1, 1)               -- Filtre pour inclure uniquement les adhérents sans FE
					)
					
					-- Description : Cette mesure calcule le nombre d'adhérents qui n'ont pas de fiche d'évaluation (FE) à la fin de la période.
