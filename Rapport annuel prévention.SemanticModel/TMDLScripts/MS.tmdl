			column 'Indicateur Pénultième Semaine' = ```
					
					VAR AujourdHui = TODAY()
					VAR DebutPenultieme = AujourdHui - 14 - WEEKDAY(AujourdHui - 14, 2) + 1
					VAR FinPenultieme = DebutPenultieme + 6
					RETURN
					IF('Date principale'[date] >= DebutPenultieme && 'Date principale'[date] <= FinPenultieme, "Pénultième Semaine", "Autre")
					
					```
				lineageTag: aef2046c-463c-49c2-ab2e-0a79b7556b62
				summarizeBy: none

				changedProperty = Name

				changedProperty = IsHidden

