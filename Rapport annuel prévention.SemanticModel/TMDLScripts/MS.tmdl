			measure MaxDureeMoyTraitement =
					
					VAR MaxDureeMensuelle =
					    CALCULATE(
					        ('CRM - tickets'[Durée moyenne traitement tickets (j)]),
					        ALLEXCEPT('Date principale', 'Date principale'[Mois]) -- Conserver le filtre sur le mois
					    )
					RETURN
					    MaxDureeMensuelle + 5 -- Ajouter 5 à la valeur calculée
					
					-- Cette mesure calcule la durée moyenne maximale de traitement des tickets pour chaque mois
					-- et ajoute 5 à cette valeur. Elle utilise ALLEXCEPT pour conserver uniquement le filtre sur le mois,
					-- ce qui permet de calculer le maximum pour chaque mois séparément.
				displayFolder: Divers
				lineageTag: 078c560d-79f7-4943-81d6-e62b486e1a6b

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure MaxDemandeRDVSurPeriode = ```
					
					VAR MaxDmdRDV =
					    MAXX(
					        CALCULATETABLE(
					            SUMMARIZE(
					                'Date principale',
					                'Date principale'[Mois]
					            ),
					            ALLSELECTED('Date principale'), -- Enlève les filtres de rapport sur les mois, mais conserve les autres
					            ALL('Demande visite adhérent - statut') -- Enlève tous les filtres sur le statut
					        ),
					        [Demande de rdv] -- Mesure à évaluer pour chaque mois
					    )
					RETURN
					    MaxDmdRDV * 1.25 -- Applique un facteur de 125%
					
					-- Cette mesure calcule la valeur maximale de la mesure 'Demande de rdv' sur tous les mois sélectionnés,
					-- en ignorant les filtres de rapport appliqués directement sur les mois et sur le statut des demandes.
					-- Elle applique ensuite un facteur de 125% au maximum trouvé pour obtenir le résultat final.
					-- Cela peut être utilisé pour ajuster l'échelle dans des visualisations, par exemple, en prenant en compte une marge de 25%.
					
					```
				formatString: 0
				displayFolder: Divers
				lineageTag: 50444863-322e-4c46-9ef5-1488af6a7682

