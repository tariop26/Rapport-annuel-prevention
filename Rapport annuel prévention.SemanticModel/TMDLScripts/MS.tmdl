			/// Affiche le numéro de l'avant dernière semaine
			measure 'Pénultième Semaine' = ```
					
					VAR DateActuelle = TODAY()                          // Obtient la date actuelle
					VAR DatePenultieme = DateActuelle - 14              // Calcule la date deux semaines en arrière
					VAR NumeroSemaine = WEEKNUM(DatePenultieme, 21)     // Calcule le numéro de la semaine ISO pour cette date
					
					RETURN
					    NumeroSemaine
					
					/*
					Description :
					Cette mesure calcule le numéro de la semaine ISO pour la date située deux semaines avant la date actuelle.
					Elle utilise la fonction WEEKNUM avec le type 21 pour obtenir le numéro de la semaine selon la norme ISO 8601.
					*/
					
					```
				formatString: 0
				displayFolder: Date
				lineageTag: 178165c5-9af0-4a20-8247-1c76fdb97bc6

			/// Affiche les infos ssuivantes au sujet de l'avant dernière semaine:
			/// Semaine n°.... : lundi x ...... - dimanche y ........
			measure 'Pénultième Semaine détaillée' = ```
					
					VAR DateActuelle = TODAY()                                                              // Obtient la date actuelle
					VAR PremierJourPenultieme = DateActuelle - 14 - WEEKDAY(DateActuelle - 14, 2) + 1       // Calcule le lundi de la pénultième semaine
					VAR DernierJourPenultieme = PremierJourPenultieme + 6                                   // Calcule le dimanche de la pénultième semaine
					VAR NumeroSemaine = WEEKNUM(DateActuelle - 14, 21)                                      // Calcule le numéro de la semaine ISO
					
					RETURN
					    "Semaine n° " & NumeroSemaine & " : " &
					    FORMAT(PremierJourPenultieme, "dddd d mmmm", "fr-FR") & " - " &                     // Formate le premier jour
					    FORMAT(DernierJourPenultieme, "dddd d mmmm", "fr-FR")                               // Formate le dernier jour
					
					/*
					Description :
					Cette mesure fournit des détails sur la pénultième semaine par rapport à la date actuelle.
					Elle affiche le numéro de la semaine ISO ainsi que les dates du lundi et du dimanche de cette semaine, formatées en français.
					*/
					
					```
				displayFolder: Date
				lineageTag: e49ff8ef-463b-426a-838f-48c1853e595e

			measure 'Mois dernier' = ```
					
					VAR DateDebutDernierMois = [Début Dernier Mois]                                 // Récupère la date de début du dernier mois
					VAR MoisAnnee = FORMAT(DateDebutDernierMois, "mmmm yyyy", "fr-FR")              // Formate la date en "mois année" en français
					VAR PremierCaractereMajuscule = UPPER(LEFT(MoisAnnee, 1))                       // Met en majuscule le premier caractère
					VAR ResteTexteMinuscule = LOWER(RIGHT(MoisAnnee, LEN(MoisAnnee) - 1))           // Met en minuscule le reste du texte
					
					RETURN
					    PremierCaractereMajuscule & ResteTexteMinuscule                             // Concatène le premier caractère en majuscule avec le reste en minuscule
					
					/*
					Description :
					Cette mesure formate la date de début du dernier mois en "mois année" en français, avec la première lettre en majuscule et le reste en minuscules.
					Elle utilise les fonctions FORMAT, UPPER, LEFT, LOWER et RIGHT pour obtenir le résultat souhaité.
					*/
					
					```
				displayFolder: Date
				lineageTag: 59eebeb0-0643-4202-a615-6447b2928317

			measure '% demandes de visites déclinées' = ```
					
					VAR TotalDemandes = SUM('Demande visite adhérent'[nb_demande_visite])               // Calcule le total des demandes de visites
					VAR DemandesDeclinees =
					    CALCULATE(
					        SUM('Demande visite adhérent'[nb_demande_visite]),
					        'Demande visite adhérent - statut'[Statut demande visite] = "Déclinée"      // Calcule le nombre de demandes déclinées
					    )
					
					RETURN
					    DIVIDE(DemandesDeclinees, TotalDemandes)                                        // Calcule le pourcentage de demandes déclinées
					
					/*
					Description :
					Cette mesure calcule le pourcentage de demandes de visites qui ont été déclinées.
					Elle utilise CALCULATE pour filtrer les demandes avec le statut "Déclinée" et DIVIDE pour obtenir le pourcentage par rapport au total des demandes.
					*/
					
					```
				displayFolder: Demandes de RDV
				lineageTag: b8b52793-fa1d-4c9a-b43a-ad007eac1bd4

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Avant Pénultième Semaine (Demande RDV)' = ```
					
					VAR DateActuelle = TODAY()                                                          // Obtient la date actuelle
					VAR DebutPenultiemeSemaine = DateActuelle - 14 - WEEKDAY(DateActuelle - 14, 2) + 1  // Calcule le lundi de la pénultième semaine
					VAR FinPenultiemeSemaine = DebutPenultiemeSemaine + 6                               // Calcule le dimanche de la pénultième semaine
					VAR DateMaxDemande = MAX('Demande visite adhérent'[Date création demande])          // Obtient la date maximale de création de demande
					
					RETURN
					    IF(DateMaxDemande <= FinPenultiemeSemaine, "Oui", "Non")                        // Vérifie si la date de la demande est dans la pénultième semaine
					
					/*
					Description :
					Cette mesure vérifie si la date maximale de création de demande se situe dans la pénultième semaine par rapport à la date actuelle.
					Elle retourne "Oui" si c'est le cas, sinon "Non".
					*/
					
					```
				displayFolder: Demandes de RDV
				lineageTag: 385f30fd-1004-4c9f-afa7-f9e8d0c1a283

			measure 'Nbre de demandes de visites en attente' = ```
					
