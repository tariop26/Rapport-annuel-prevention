			column 'Taille d''entreprise' =
					SWITCH(
						TRUE,
						ISBLANK('Adhérent (actuel)'[Taille entreprise DGT 2023]),
						"(Vide)",
						'Adhérent (actuel)'[Taille entreprise DGT 2023] IN {"Aucun salarié",
							"Entre 1 et 10 salariés"},
						"0-10 salariés",
						'Adhérent (actuel)'[Taille entreprise DGT 2023] IN {"Entre 11 et 49 salariés"},
						"11-49 salariés",
						'Adhérent (actuel)'[Taille entreprise DGT 2023] IN {"Entre 50 et 199 salariés",
							"Entre 200 et 249 salariés"},
						"50-249 salariés",
						'Adhérent (actuel)'[Taille entreprise DGT 2023] IN {"Entre 250 et 299 salariés",
							"Plus de 300 salariés"},
						"Plus de 249 salariés",
						'Adhérent (actuel)'[Taille entreprise DGT 2023]
					)
				lineageTag: cd8055d3-cb6d-4e68-953d-1141cfd324eb
				summarizeBy: none

