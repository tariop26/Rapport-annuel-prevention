				lineageTag: a7b382a8-9c9f-4542-8849-4cb14ea30b92

			measure 'Nbre de visites mensuelles / ETP théoriques' = ```
					
					VAR TotalVisitesTheoriques = [Visites annuelles]                            -- Total des visites théoriques
					VAR ETPTheoriqueParEPD = sum('4 - Equipes - membres'[ETP théorique])        -- ETP théorique par EPD
					
					VAR VisitesMensuelles =
					    DIVIDE(
					        TotalVisitesTheoriques,
					        12,                                                                 -- Diviser par 12 pour obtenir un nombre mensuel
					        0                                                                   -- Valeur par défaut si le dénominateur est zéro
					    )
					
					RETURN
					    DIVIDE(
					        VisitesMensuelles,
					        ETPTheoriqueParEPD,
					        0                                                                   -- Valeur par défaut si le dénominateur est zéro
					    )
					
					-- Description :
					-- Cette mesure calcule le nombre de visites mensuelles par ETP théorique en divisant le total des visites théoriques par 12 (pour obtenir un nombre mensuel) et par l'ETP théorique par EPD.
					-- Elle utilise des variables pour stocker les différentes composantes du calcul et applique la fonction DIVIDE pour éviter les erreurs de division par zéro.
					
					```
				formatString: #,0.00
				displayFolder: Prévision de charge
				lineageTag: ef88f325-9df9-402b-bf73-1fc5e751159d

			measure 'Nbre de visites intérimaires (12 derniers mois)' =
					
					VAR DateDernierAn = TODAY() - 365  -- Calculer la date d'il y a un an
					
					RETURN
					CALCULATE(
					    [Nombre de visites réalisées (RDV)],                                        -- Mesure de base à calculer
					    'Salarié (actuel)'[Contrat intérimaire (actuel)] = "Salarié intérimaire",   -- Filtrer sur les contrats intérimaires
					    'Date principale'[Date] >= DateDernierAn,                                   -- Filtrer sur les 12 derniers mois
					        ALL('Adhérent (actuel)'[Type entreprise])                               -- Ignorer les filtres sur le type d'entreprise
					    )
					
					-- Description :
					-- Cette mesure calcule le nombre de visites intérimaires réalisées sur les 12 derniers mois.
					-- Elle utilise CALCULATE pour appliquer des filtres sur les contrats intérimaires et les 12 derniers mois, tout en ignorant les filtres sur le type d'entreprise.
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 3e53cb3c-8570-4b91-83f1-55d4c826500f

			measure 'Capacité vs. Visites théoriques Médecin' = ```
					
