			measure 'Plage Max Axe Y PDP' =
					
					
					MAX(
					    MAXX(
					        SUMMARIZE(
					            'Demande consultation spécialisée',
					            'Date principale'[Mois], -- Colonne représentant les mois
					            "Total Orientations", [# demandes consultation spécialisée]
					        ),
					        [Total Orientations]
					    ),
					    MAXX(
					        SUMMARIZE(
					            FILTER(
					                'Visite',
					                CALCULATE(
					                    MAX('RDV/Visite - réalisateur'[Profil réalisateur détaillé]) = "Conseiller maintien de la cellule PDP"
					                )
					            ),
					            'Date principale'[Mois], -- Colonne représentant les mois
					            "Total Visites", [Nombre de visites]
					        ),
					        [Total Visites]
					    )
					)
					
					
					-- Cette mesure calcule la valeur maximale entre le nombre total d'orientations et le nombre total de visites par mois,
					-- en filtrant les visites pour inclure uniquement celles réalisées par un "Conseiller maintien de la cellule PDP".
				formatString: 0
				displayFolder: Orientations
				lineageTag: 4ed9ec56-d2f4-4e97-b647-80718fddfc3d

			measure 'Besoin IDEST' = [Visites IDEST]/1848
				formatString: #,0.00
				displayFolder: Prévision de charge
				lineageTag: 60a7a946-79de-48f6-96aa-01eb6257e898

			measure 'Besoin médecin' = [Visites médecin]/1574
				formatString: #,0.00
				displayFolder: Prévision de charge
				lineageTag: 92d3e8a1-07d1-4b2b-a5cc-13acd6024634

			measure 'Nombre d''IDEST actifs' =
					CALCULATE(
					    DISTINCTCOUNT('Utilisateurs et équipes médicales'[Nom utilisateur]),
					    'Utilisateurs et équipes médicales'[Role utilisateur] = "IDEST",
					    'Utilisateurs et équipes médicales'[Profil actif (actuel)] = "Profil actif"
					)
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: c46fd310-a817-4957-8b24-7a203350a68a

			measure 'Nombre de Médecins actifs' =
					CALCULATE(
					    DISTINCTCOUNT('Utilisateurs et équipes médicales'[Nom utilisateur]),
					    'Utilisateurs et équipes médicales'[Role utilisateur] = "Médecin",
					    'Utilisateurs et équipes médicales'[Profil actif (actuel)] = "Profil actif"
					)
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 79f5880c-f3aa-453b-a5ee-886a530e9583

			measure 'Visites annuelles' = ```
					
					VAR VisitesIDEST = [Visites IDEST]          -- Visites réalisées par IDEST
					VAR VisitesMedecin = [Visites Médecin]      -- Visites réalisées par Médecin
					
					RETURN
					    VisitesIDEST + VisitesMedecin           -- Somme des visites réalisées par IDEST et Médecin
					
					-- Description :
					-- Cette mesure calcule le nombre total de visites annuelles en additionnant les visites réalisées par les IDEST et les Médecins.
					-- Elle utilise des variables pour stocker les différentes composantes des visites et applique un calcul pour obtenir le nombre total de visites.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: cd26d6eb-c3f0-449d-b4a4-ac5b8de68aab

			measure 'Visites embauche IDEST' = ```
					
					VAR EffectifTotalSuivi =
					    'Salariés'[Effectif suivi non-intérimaire SI]
					    + 'Salariés'[Effectif suivi non-intérimaire SIA] * (1 - 0.166667)       -- Ajuster pour SIA tous les 6 ans
					
					VAR EffectifTotalDeclare =
					    IF(
					        YEAR(TODAY()) >= 2026,
					        [Effectif déclaré Année-1],                                         -- Utiliser une mesure dynamique à partir de 2026
					        174498                                                              -- Valeur fixe jusqu'en 2025
					    )
					
					VAR TauxEmbauche =
					    DIVIDE(
					        [NBre d'embauche Année-1 facturée],                                 -- Nombre de nouveaux noms facturés dans l'année
					        EffectifTotalDeclare,
					        0                                                                   -- Valeur par défaut si le dénominateur est zéro
					    )
					
					VAR VisitesInterimaires = [Nombre de visites intérimaires IDEST (12 derniers mois)]  -- Utiliser une mesure dynamique
					
					RETURN
					    EffectifTotalSuivi * TauxEmbauche + VisitesInterimaires  -- Calculer le nombre total de visites
					
					-- Description :
					-- Cette mesure calcule le nombre total de visites liées à l'embauche réalisées par un IDEST, en tenant compte de l'effectif suivi et des visites intérimaires.
					-- Elle utilise des variables pour stocker les différentes composantes de l'effectif et des taux, et applique un calcul pour obtenir le nombre total de visites.
					
					```
				formatString: #,0.00
				displayFolder: Prévision de charge
				lineageTag: 25ff90de-39d1-435d-b5a3-1882038f6dfb

			measure 'Visites embauche Médecin' = ```
					
					VAR EffectifTotalSuivi =
					    [Effectif suivi SIR]
					    + [Effectif suivi INB cat A]
					    + [Effectif suivi INB cat B]
					    + [Effectif suivi Rayonnements ionisants A]
					    + [Effectif suivi Rayonnements ionisants B]
					    + [Effectif suivi SIA] * 0.166667                           -- Ajuster pour SIA tous les 6 ans
					
					VAR EffectifTotalDeclare =
					    IF(
					        YEAR(TODAY()) >= 2026,
					        [Effectif déclaré Année-1],                             -- Utiliser une mesure dynamique à partir de 2026
					        174498                                                  -- Valeur fixe jusqu'en 2025
					    )
					
					VAR TauxEmbauche =
					    DIVIDE(
					        [NBre d'embauche Année-1 facturée],                     -- Nombre de nouveaux noms facturés dans l'année
					        EffectifTotalDeclare,
					        0                                                       -- Valeur par défaut si le dénominateur est zéro
					    )
					
					VAR VisitesInterimaires = [Nombre de visites intérimaires Médecin (12 derniers mois)]  -- Utiliser une mesure dynamique
					
					RETURN
					    EffectifTotalSuivi * TauxEmbauche + VisitesInterimaires     -- Calculer le nombre total de visites
					
					-- Description :
					-- Cette mesure calcule le nombre total de visites liées à l'embauche réalisées par un médecin, en tenant compte de l'effectif suivi et des visites intérimaires.
					-- Elle utilise des variables pour stocker les différentes composantes de l'effectif et des taux, et applique un calcul pour obtenir le nombre total de visites.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 06f053ec-1837-4016-b08b-a78cb54a8513

			measure 'Visites IDEST' = ```
					
					VAR VisitesEmbaucheIDEST = [Visites embauche IDEST]                         -- Visites liées à l'embauche par IDEST
					VAR VisitesOccasionnellesIDEST = [Visites occasionnelles IDEST]             -- Visites occasionnelles par IDEST
					VAR VisitesPeriodiquesIDEST = [Visites périodiques IDEST]                   -- Visites périodiques par IDEST
					
					RETURN
					    VisitesEmbaucheIDEST + VisitesOccasionnellesIDEST + VisitesPeriodiquesIDEST  -- Somme des différentes catégories de visites
					
					-- Description :
					-- Cette mesure calcule le nombre total de visites réalisées par un IDEST en additionnant les visites d'embauche, occasionnelles et périodiques.
					-- Elle utilise des variables pour stocker les différentes composantes des visites et applique un calcul pour obtenir le nombre total de visites.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: db5d3834-d344-4c49-b9ca-dd36aa118ed6

			measure 'Visites médecin' = [Visites embauche Médecin]+[Visites occasionelles Méd]+[Visites périodiques Médecin]
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 289c7af8-2326-4f2a-8f6d-c49661eddc25

			measure 'Visites occasionnelles IDEST' =
					CALCULATE(
					    Visite[Nombre de visites],
					    'Date principale'[Dernière année glissante],
					    'RDV/visite - type visite'[Catégorie visite] = "Occasionnelle",
					    'RDV/visite - type visite'[Type visite] in {"Reprise","Pré-reprise"}
					    )
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: acceb08a-dd5c-4437-9317-cba891e6474a

			measure 'Visites occasionelles Méd' = ```
					
					VAR EffectifSuiviNonInterimaire = 'Salariés'[Effectif suivi non-intérimaire]    -- Effectif suivi non-intérimaire
					
					VAR TauxVisitesOccasionnelles =
					    DIVIDE(
					        [Nombre de visites occasionnelles Médecin (12 derniers mois)],          -- Nombre de visites occasionnelles sur les 12 derniers mois
					        [Effectif déclaré],                                                     -- Effectif total déclaré
					        0                                                                       -- Valeur par défaut si le dénominateur est zéro
					    )
					
					RETURN
					    EffectifSuiviNonInterimaire * TauxVisitesOccasionnelles                     -- Calculer le nombre de visites occasionnelles basé sur l'effectif suivi
					
					-- Description :
					-- Cette mesure calcule le nombre de visites occasionnelles réalisées par un médecin sur les 12 derniers mois, en fonction de l'effectif suivi non-intérimaire.
					-- Elle utilise des variables pour stocker l'effectif et le taux de visites occasionnelles, et applique un calcul pour obtenir le nombre total de visites.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 358a8c63-fc27-4ffb-b636-d94dbf84e02e

			measure 'Visites périodiques Médecin' = ```
					
					VAR VisitesSI = 0                                                                       -- Aucune visite périodique par Médecin pour SI
					
					VAR VisitesSIA =
					    'Salariés'[Effectif suivi non-intérimaire SIA] * 0.166667                           -- SIA tous les 6 ans par Médecin (tous les 3 ans mais une fois sur 2 avec IDEST)
					
					VAR VisitesSIR =
					    'Salariés'[Effectif suivi non-intérimaire SIR] * 0.25                               -- SIR tous les 4 ans par Médecin (tous les 2 ans mais une fois sur 2 avec IDEST)
					
					VAR VisitesCatA =
					    [Effectif suivi INB cat A] + [Effectif suivi Rayonnements ionisants A]              -- INB et RI cat A tous les ans par Médecin
					
					VAR VisitesCatB =
					    ([Effectif suivi INB cat B] + [Effectif suivi Rayonnements ionisants B]) * 0.5      -- INB et RI cat B tous les 2 ans par Médecin (tous les ans mais une fois sur 2 avec IDEST)
					
					RETURN
					    VisitesSI + VisitesSIA + VisitesSIR + VisitesCatA + VisitesCatB                     -- Somme des différentes catégories de visites
					
					-- Description :
					-- Cette mesure calcule le nombre total de visites périodiques effectuées par les médecins pour différentes catégories de salariés.
					-- Elle prend en compte les visites pour les catégories SIA, SIR, INB cat A, INB cat B, et rayons ionisants A et B, en appliquant les fréquences appropriées.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 0e66b42b-3ffe-4c36-8e8d-0e61a02348a7

			measure 'Effectif en retard' = ```
					
					VAR CategorieRetard = "En retard"               -- Définir la catégorie de retard à filtrer
					
					VAR EffectifRetard =                            -- Calculer l'effectif en retard en appliquant le filtre sur la catégorie de retard
					    CALCULATE(
					        [Effectif suivi non-intérimaire],
					        'Salarié (actuel)'[Catégorie retard] = CategorieRetard
					    )
					
					RETURN
					    EffectifRetard
					
					-- Cette mesure calcule l'effectif des salariés en retard en filtrant les salariés dont la catégorie de retard est "En retard".
					
					```
				formatString: 0
				displayFolder: Retard
				lineageTag: acfb9510-1114-4a12-84f7-2f871ea26354

			measure 'Nbre de semaines pour rattraper retards' = ```
					
					VAR SalariesEnRetard =
					    CALCULATE(
					        [Effectif suivi non-intérimaire],
					        'Salarié (actuel)'[Catégorie retard] = "En retard"              -- Filtre pour inclure uniquement les salariés en retard
					    )
					VAR MoyenneVisitesHebdo = [Moy. visites hebdomadaires (12 mois)]        -- Moyenne des visites hebdomadaires sur 12 mois
					
					RETURN
					IF(
					    MoyenneVisitesHebdo > 0,
					    DIVIDE(
					        SalariesEnRetard,
					        MoyenneVisitesHebdo,
					        0                                                              -- Valeur par défaut si le dénominateur est zéro
					    ),
					    BLANK()                                                             -- Retourne une valeur vide si la moyenne des visites est zéro
					)
					
					-- Description : Cette mesure calcule le nombre de semaines nécessaires pour rattraper le retard dans le suivi des salariés.
					-- Elle utilise la mesure [Effectif suivi non-intérimaire] pour les salariés en retard et la moyenne des visites hebdomadaires pour effectuer le calcul.
					
					```
				formatString: 0
				displayFolder: Retard
				lineageTag: aa5f92fa-9dd5-4846-8f93-8eef7481ed18

				annotation PBI_FormatHint = {"isDecimal":true}

