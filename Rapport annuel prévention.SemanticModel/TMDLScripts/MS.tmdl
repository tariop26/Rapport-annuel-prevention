			measure '% heures non exploitées' = ```
					
					VAR TempsNonExploite = [Temps total non exploité (en heures)]       -- Temps total non exploité
					VAR TempsTotalEnZone = [Temps total en zone (en heures)]            -- Temps total en zone
					
					RETURN
					    DIVIDE(
					        TempsNonExploite,
					        TempsTotalEnZone,
					        0                                                           -- Valeur par défaut si le dénominateur est zéro
					    )
					
					-- Description : Cette mesure calcule le pourcentage d'heures non exploitées par rapport au temps total en zone.
					-- Elle utilise les mesures [Temps total non exploité (en heures)] et [Temps total en zone (en heures)] pour effectuer le calcul.
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Temps de travail
				lineageTag: 94e3f90e-d868-4aba-998e-b1e2ada80fe4

			measure 'Ratio visite / temps' = ```
					
					VAR NombreVisites = [Nombre de visites]                                                 -- Nombre total de visites
					VAR TempsTotalVisites = 'Temps travail'[Temps total visites réalisées (en heures)]      -- Temps total des visites réalisées
					
					RETURN
					    DIVIDE(
					        NombreVisites,
					        TempsTotalVisites,
					        0                                                                               -- Valeur par défaut si le dénominateur est zéro
					    )
					
					-- Description : Cette mesure calcule le ratio entre le nombre de visites et le temps total des visites réalisées.
					-- Elle utilise les mesures [Nombre de visites] et [Temps total visites réalisées (en heures)] pour effectuer le calcul.
					
					```
				displayFolder: Temps de travail
				lineageTag: 92a2b117-21d8-41a9-bcaf-1a7b5c69e589

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Durée visite (Pénultième mois)' = ```
					
					VAR DateActuelle = TODAY()                                                      -- Obtenir la date actuelle
					VAR PremierJourMoisActuel = DATE(YEAR(DateActuelle), MONTH(DateActuelle), 1)    -- Premier jour du mois actuel
					VAR PremierJourPenultiemeMois = EDATE(PremierJourMoisActuel, -2)                -- Premier jour du pénultième mois
					VAR DernierJourPenultiemeMois = EOMONTH(PremierJourPenultiemeMois, 0)           -- Dernier jour du pénultième mois
					VAR DatesPenultiemeMois =
					    FILTER(
					        'Date principale',
					        'Date principale'[Date] >= PremierJourPenultiemeMois &&
					        'Date principale'[Date] <= DernierJourPenultiemeMois
					    )                                                                           -- Table de dates du pénultième mois
					
					RETURN
					CALCULATE(
					    [Durée moyenne après transfert (en minutes)],                               -- Calculer la durée de visite
					    DatesPenultiemeMois                                                         -- Filtrer par les dates du pénultième mois
					)
					
					-- Cette mesure calcule la durée moyenne des visites pour le pénultième mois.
					-- Elle utilise des variables pour définir les dates de début et de fin du pénultième mois,
					-- puis filtre les visites en conséquence pour évaluer la durée moyenne.
					
					```
				displayFolder: Visites
				lineageTag: 5da16c60-ad7d-4979-9422-e57f089e173f

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure Max_Créneaux_Par_Semaine_IDEST = ```
					
					VAR DerniereDate = MAX('Date principale'[Date])             -- Récupère la date maximale du contexte actuel
					VAR DateLimite = EDATE(DerniereDate, -3)                    -- Calcule la date limite pour les 3 derniers mois
					VAR CreneauxParSemaine =
					    SUMMARIZE(
					        FILTER(
					            'Date principale',
					            'Date principale'[Date] >= DateLimite           -- Filtre les dates des 3 derniers mois
					        ),
					        'Date principale'[Semaine],                         -- Grouper par semaine
					        "TotalCreneaux",
					        CALCULATE(
					            [Nombre de créneaux],
					            'RDV/visite - réalisateur'[Role réalisateur] = "IDEST"          -- Filtre pour le rôle "IDEST"
					        )
					    )
					VAR MaxCreneaux = MAXX(CreneauxParSemaine, [TotalCreneaux])                 -- Calcule le maximum des créneaux par semaine
					
					RETURN
					MaxCreneaux * 1.1                                            -- Multiplie le résultat par 1.1
					
					-- Cette mesure calcule le maximum des créneaux par semaine pour le rôle "IDEST" sur les 3 derniers mois,
					-- puis multiplie ce résultat par 1.1. Elle utilise des variables pour définir les dates et les calculs intermédiaires.
					-- Utilisé pour gérer l'axe Y dans un graphique
					
					```
				displayFolder: IDEST
				lineageTag: 9026f407-fca4-4bea-9656-5a7a5bf63ff4

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure Max_Visites_IDEST = ```
					
					CALCULATE(
					    MAX('Visite'[nb_visite]),                                   -- Calcule la valeur maximale des visites
					    'RDV/visite - réalisateur'[Role réalisateur] = "IDEST",     -- Filtre pour le rôle "IDEST"
					    ALLSELECTED('Date principale')                              -- Conserve uniquement le contexte des dates filtrées
					) * 1.1                                                         -- Ajoute une marge de 10%
					
					-- Cette mesure calcule la valeur maximale des visites pour le rôle "IDEST" en tenant compte uniquement
					-- des dates sélectionnées dans le contexte actuel, puis ajoute une marge de 10%.
					-- Utilisé pour gérer l'axe Y dans un graph
					
					```
				displayFolder: IDEST
				lineageTag: de42bbc2-1017-4791-9e80-3a553e83f76a

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure Max_Visites_Par_Mois_IDEST = ```
					
					VAR DerniereDate = MAX('Date principale'[Date])         -- Récupère la date maximale du contexte actuel
					VAR DateLimite = EDATE(DerniereDate, -12)               -- Calcule la date limite pour les 52 dernières semaines
					VAR VisitesParMois =
					    SUMMARIZE(
					        FILTER(
					            'Date principale',
					            'Date principale'[Date] >= DateLimite       -- Filtre les dates des 52 dernières semaines
					        ),
					        'Date principale'[Mois],                        -- Grouper par mois
					        "TotalVisites",
					        CALCULATE(
					            SUM('Visite'[nb_visite]),
					            'RDV/visite - réalisateur'[Role réalisateur] = "IDEST"      -- Filtre pour le rôle "IDEST"
					        )
					    )
					VAR MaxVisites = MAXX(VisitesParMois, [TotalVisites])   -- Calcule le maximum des visites par mois
					
					RETURN
					MaxVisites * 1.1                                        -- Multiplie le résultat par 1.1
					
					-- Cette mesure calcule le maximum des visites par mois pour le rôle "IDEST" sur les 52 dernières semaines,
					-- puis multiplie ce résultat par 1.1. Elle utilise des variables pour définir les dates et les calculs intermédiaires.
					-- Utilisé pour gérer l'axe Y dans un graph 
					
					
					```
				displayFolder: IDEST
				lineageTag: edac0ee6-a860-4a24-8378-737a12970237

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure Max_Visites_Par_Semaine_IDEST = ```
					
					VAR DerniereDate = MAX('Date principale'[Date])         -- Récupère la date maximale du contexte actuel
					VAR DateLimite = EDATE(DerniereDate, -12)               -- Calcule la date limite pour les 52 dernières semaines
					VAR VisitesParSemaine =
					    SUMMARIZE(
					        FILTER(
					            'Date principale',
					            'Date principale'[Date] >= DateLimite       -- Filtre les dates des 52 dernières semaines
					        ),
					        'Date principale'[Semaine],                     -- Grouper par semaine
					        "TotalVisites",
					        CALCULATE(
					            SUM('Visite'[nb_visite]),
					            'RDV/visite - réalisateur'[Role réalisateur] = "IDEST"      -- Filtre pour le rôle "IDEST"
					        )
					    )
					VAR MaxVisites = MAXX(VisitesParSemaine, [TotalVisites])                -- Calcule le maximum des visites par semaine
					RETURN
					MaxVisites * 1.1                                        -- Multiplie le résultat par 1.1
					
					-- Cette mesure calcule le maximum des visites par semaine pour le rôle "IDEST" sur les 52 dernières semaines,
					-- puis multiplie ce résultat par 1.1. Elle utilise des variables pour définir les dates et les calculs intermédiaires.
					-- Utilisé pour gérer l'axe Y dans un graph 
					
					```
				displayFolder: IDEST
				lineageTag: feec5afe-db30-4de8-a543-dbe081564b10

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Moy. visites hebdomadaires IDEST (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])              -- Récupère la date maximale du contexte actuel
					VAR LastWeek = CurrentDate - 7                              -- Calcule la date de la semaine précédente
					VAR FiftyTwoWeeksAgo = LastWeek - 364                       -- Calcule la date il y a 52 semaines par rapport à LastWeek
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'RDV/visite - réalisateur'[Role réalisateur] = "IDEST",                                 -- Filtre pour le rôle "IDEST"
					        'Date principale'[Date] > FiftyTwoWeeksAgo && 'Date principale'[Date] <= LastWeek       -- Filtre sur les 52 dernières semaines
					    )
					VAR NombreSemaines = 52                                     -- Nombre de semaines sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreSemaines, 0)                     -- Calcule la moyenne hebdomadaire, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne hebdomadaire des visites pour le rôle "IDEST" sur les 52 dernières semaines.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				displayFolder: Visites
				lineageTag: 47675201-040b-4308-8235-eb129ccd6569

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Moy. visites hebdomadaires Médecin (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])              -- Récupère la date maximale du contexte actuel
					VAR LastWeek = CurrentDate - 7                              -- Calcule la date de la semaine précédente
					VAR FiftyTwoWeeksAgo = LastWeek - 364                       -- Calcule la date il y a 52 semaines par rapport à LastWeek
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'RDV/visite - réalisateur'[Role réalisateur] = "Médecin",                                 -- Filtre pour le rôle "Médecin"
					        'Date principale'[Date] > FiftyTwoWeeksAgo && 'Date principale'[Date] <= LastWeek       -- Filtre sur les 52 dernières semaines
					    )
					VAR NombreSemaines = 52                                     -- Nombre de semaines sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreSemaines, 0)                     -- Calcule la moyenne hebdomadaire, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne hebdomadaire des visites pour le rôle "Médecin" sur les 52 dernières semaines.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				formatString: 0
				displayFolder: Visites
				lineageTag: 5b1953cc-2dad-40d8-a27a-8a964eafff8b

			measure 'Nbre de visites réalisées' =
					
					COALESCE(
					    [Nombre de visites],          -- Retourne la valeur de [Nombre de visites réalisées] si elle n'est pas vide
					    ""                                             -- Retourne "" si [Nombre de visites réalisées] est vide
					)
					
					-- Cette mesure retourne le nombre de visites réalisées  en utilisant la mesure [Nombre de visites réalisées (RDV)].
					
					-- Si [Nombre de visites réalisées (RDV)] est vide, elle retourne 0 grâce à la fonction coalesce.
				formatString: #,0
				displayFolder: Visites
				lineageTag: 5598d136-0825-47ee-8bb2-b31f5429b080

			measure 'Nombre de visites (Pénultième mois)' = ```
					
					VAR DateActuelle = TODAY()                                                          -- Obtenir la date actuelle
					VAR PremierJourMoisActuel = DATE(YEAR(DateActuelle), MONTH(DateActuelle), 1)        -- Premier jour du mois actuel
					VAR PremierJourPenultiemeMois = EDATE(PremierJourMoisActuel, -2)                    -- Premier jour du pénultième mois
					VAR DernierJourPenultiemeMois = EOMONTH(PremierJourPenultiemeMois, 0)               -- Dernier jour du pénultième mois
					VAR DatesPenultiemeMois =
					    FILTER(
					        'Date principale',
					        'Date principale'[Date] >= PremierJourPenultiemeMois &&
					        'Date principale'[Date] <= DernierJourPenultiemeMois
					    )                                                                               -- Table de dates du pénultième mois
					RETURN
					CALCULATE(
					    [Nombre de visites réalisées (RDV)],                                            -- Calculer le nombre de visites
					    DatesPenultiemeMois                                                             -- Filtrer par les dates du pénultième mois
					)
					
					-- Cette mesure calcule le nombre de visites pour le pénultième mois.
					-- Elle utilise des variables pour définir les dates de début et de fin du pénultième mois,
					-- puis filtre les visites en conséquence pour évaluer le nombre total de visites.
					
					```
				formatString: #,0
				displayFolder: Visites
				lineageTag: 6f9ce774-48df-4a4d-a4e1-e0477e0914fe

			measure 'Taux de Service (tout PST38)' = ```
					
					VAR VisitesRealizables =
					    {"Médecin et IDEST", "Médecin uniquement", "Inconnu", "Non pertinent", "Spécialiste uniquement"}    -- Liste des types de visites réalisables
					
					RETURN
					CALCULATE(
					    [Taux de service],
					    ALL(Utilisateur),                                                                                   -- Ignorer tous les filtres sur la table Utilisateur
					    'Evolution retard - type visite calculée'[Visite calculée réalisable par] IN VisitesRealizables     -- Filtrer les visites réalisables
					)
					
					-- Cette mesure calcule le taux de service en tenant compte uniquement des visites réalisables spécifiées.
					-- Elle ignore tous les filtres sur la table Utilisateur et applique un filtre sur les types de visites réalisables.
					-- Cela permet de comparer le taux de service d'une équipe par rapport au taux de service de l'ensemble des équipes PST38. 
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Visites
				lineageTag: 348ab1be-a0f5-4e15-84da-acfb32534659

			measure 'Taux de service IDEST' = ```
					
					CALCULATE(
					    [Taux de service],                                                                                  -- Calcule le taux de service
					    ALL(Utilisateur),                                                                                   -- Ignorer tous les filtres sur la table Utilisateur
					    'Evolution retard - type visite calculée'[Visite calculée réalisable par] = "Médecin et IDEST"      -- Filtrer les visites réalisables par "Médecin et IDEST" donc les IDEST
					)
					
					-- Cette mesure calcule le taux de service pour les visites réalisables par des "IDEST".
					-- Elle ignore tous les filtres sur la table Utilisateur et applique un filtre spécifique sur le type de visite réalisable.
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Visites
				lineageTag: a7336e31-64ce-4873-a947-5497c4257fda

			measure 'Max Visites' = ```
					
					MAXX(
					    ALLSELECTED('Date principale'[Mois]),               -- Conserver uniquement les filtres internes sur les mois
					    [Nombre de visites réalisées (RDV)] * 1.05          -- Calculer le maximum des visites réalisées, ajusté de 5%
					)
					
					-- Cette mesure calcule la valeur maximale des visites réalisées, ajustée par un facteur de 5%,
					-- en tenant compte uniquement des filtres internes sur les mois.
					-- Utilisé pour gérer l'axe Y dans un graph
					
					```
				displayFolder: Visites
				lineageTag: 71d53e86-cfc9-48d7-acc7-73cd989a70b2

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'AMT en-cours ayant atteints le statut à valider' = ```
					
					VAR StatutAValider = "Oui"                                          -- Définir le statut à valider dans une variable pour plus de clarté
					VAR AMTFiltres =
					    FILTER(
					        AMT,
					        AMT[AMT a atteint statut 'à valider'] = StatutAValider      -- Appliquer le filtre sur le statut
					    )
					RETURN
					    CALCULATE(
					        COUNTROWS(AMTFiltres),                                      -- Utiliser COUNTROWS pour compter les lignes filtrées
					        REMOVEFILTERS('Date principale')                            -- Supprimer les filtres sur la table 'Date principale'
					    )
					
					-- Cette mesure compte le nombre d'AMT distincts ayant atteint le statut 'à valider',
					-- en ignorant les filtres appliqués sur la table 'Date principale'.
					
					```
				displayFolder: AMT
				lineageTag: 6b3c6ac6-6e6c-4c15-a11b-d80ef53a2a36

			measure '% AMT terminées par type / modèle' = ```
					
					VAR AMTValide = 'Mesures'[AMT en-cours ou terminés ayant atteint le statut à valider]       -- Stocker la mesure dans une variable pour éviter les répétitions
					VAR AMTTotalModele =
					    CALCULATE(
					        AMTValide,
					        ALL('AMT'[Modèle])                                                                  -- Calculer le total en ignorant les filtres sur le modèle
					    )
					VAR AMTTotalType =
					    CALCULATE(
					        AMTValide,
					        ALL('AMT'[Type])                                                                    -- Calculer le total en ignorant les filtres sur le type
					    )
					RETURN
					    IF(
					        ISINSCOPE('AMT'[Modèle]),
					        DIVIDE(AMTValide, AMTTotalModele, 0),                                               -- Calculer le pourcentage par modèle
					        DIVIDE(AMTValide, AMTTotalType, 0)                                                  -- Calculer le pourcentage par type
					    )
					
					-- Cette mesure calcule le pourcentage d'AMT terminées par type ou modèle,
					-- en fonction du contexte actuel. Elle utilise des variables pour éviter
					-- les répétitions de calculs et améliorer la lisibilité.
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: AMT
				lineageTag: 984115ca-bca6-45d0-92f9-dad9a1429826

			measure 'AMT en-cours ou terminés ayant atteint le statut à valider' = ```
					
					VAR AMTTerminees =
					    CALCULATE(
					        [Nombre d'AMT terminées],
					        'Date principale'[Filtre Période 12 mois ajustés] = true                    -- Filtrer les AMT terminées sur la période ajustée
					    )
					VAR AMTEncours =
					    CALCULATE(
					        [AMT en-cours ayant atteint le statut à valider],
					        REMOVEFILTERS('Date principale')                                            -- Supprimer les filtres sur la date pour les AMT en cours
					    )
					RETURN
					    AMTTerminees + AMTEncours                                                       -- Additionner les deux résultats
					
					-- Cette mesure calcule le nombre total d'AMT en cours ou terminées ayant atteint le statut 'à valider'.
					-- Elle utilise des variables pour séparer les calculs et améliorer la lisibilité.
					
					```
				formatString: #,0
				displayFolder: AMT
				lineageTag: 621cb51e-711d-43d5-84f6-25f7402e448c

			measure 'AMT en-cours ayant atteint le statut à valider' = ```
					
					VAR StatutAValider = "Oui"                                              -- Définir le statut à valider dans une variable pour plus de clarté
					VAR AMTFiltres =
					    FILTER(
					        AMT,
					        AMT[AMT a atteint statut 'à valider'] = StatutAValider          -- Appliquer le filtre sur le statut
					    )
					RETURN
					    CALCULATE(
					        COUNTROWS(AMTFiltres),                                          -- Utiliser COUNTROWS pour compter les lignes filtrées
					        REMOVEFILTERS('Date principale')                                -- Supprimer les filtres sur la table 'Date principale'
					    )
					
					-- Cette mesure compte le nombre d'AMT distincts ayant atteint le statut 'à valider',
