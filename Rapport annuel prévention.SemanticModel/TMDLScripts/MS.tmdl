			column 'Indicateur 4 years ago' =
					
					VAR AujourdHui = TODAY()
					VAR fouryearsago = AujourdHui - 1461
					RETURN
					IF([Date dernière FE] < fouryearsago, "FE > 4 ans", "Autre")
