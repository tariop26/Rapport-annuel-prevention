			measure 'Evol convocables S-2 -> S-1' = ```
					
					VAR DifferenceConvocables =
					    [Effectif en retard S-2] - [Effectif en retard S-1]                 -- Calculer la différence entre S-2 et S-1
					
					RETURN
					    -DifferenceConvocables                                              -- Inverser la différence pour obtenir l'évolution
					
					-- Cette mesure calcule l'évolution des effectifs convocables entre les semaines S-2 et S-1.
					-- Elle utilise une variable pour stocker la différence et retourne l'inverse de cette différence pour représenter l'évolution.
					
					```
				formatString: 0
				displayFolder: Retard
				lineageTag: cd11e558-d4ab-4038-aa62-c9f11ab44ad4

			measure 'Evol convocables S-2 -> S-1 symbole' = ```
					
					VAR DifferenceConvocables =
					    [Effectif en retard S-2] - [Effectif en retard S-1]         -- Calculer la différence entre S-2 et S-1
					    
					RETURN
					    SWITCH(
					        TRUE(),
					        DifferenceConvocables < 0, UNICHAR(9650),               -- Symbole pour une diminution
					        DifferenceConvocables > 0, UNICHAR(9660),               -- Symbole pour une augmentation
					        UNICHAR(9681)                                           -- Symbole pour aucun changement
					    )
					
					-- Cette mesure affiche un symbole représentant l'évolution des effectifs convocables entre les semaines S-2 et S-1.
					-- Elle utilise une variable pour stocker la différence et la fonction SWITCH pour déterminer le symbole approprié.
					
					```
				displayFolder: Retard
				lineageTag: aaaf5c58-5196-4e8e-ad12-3711b97a7221

