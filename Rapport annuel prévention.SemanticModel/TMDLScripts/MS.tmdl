				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Delai Planification Demande de visite' = ```
					
					VAR LastNonBlankValue =
					    CALCULATE(
					        MAXX(
					            FILTER(
					                ALLSELECTED('Date Principale'),                                 -- Considérer toutes les dates sélectionnées
					                'Date Principale'[Date] <= MAX('Date Principale'[Date]) &&      -- Filtrer jusqu'à la date maximale
					                NOT(ISBLANK([Délai moyen planification demande (en jours)]))    -- Exclure les valeurs vides
					            ),
					            [Délai moyen planification demande (en jours)]                      -- Trouver la valeur maximale non vide
					        )
					    )
					RETURN
					    IF(
					        ISBLANK([Délai moyen planification demande (en jours)]),                -- Vérifier si la valeur actuelle est vide
					        LastNonBlankValue,                                                      -- Retourner la dernière valeur non vide
					        [Délai moyen planification demande (en jours)]                          -- Sinon, retourner la valeur actuelle
					    )
					
					-- Description :
					-- Cette mesure calcule le délai moyen de planification en utilisant la dernière valeur disponible si la valeur actuelle est vide.
					-- Elle utilise CALCULATE, FILTER, et MAXX pour déterminer la dernière valeur non vide dans la période sélectionnée.
					
					```
				displayFolder: Demandes de RDV
				lineageTag: 075d6984-3de8-4f5d-8f20-3e21e7f0725b

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Demande de rdv' = ```
					
					VAR NombreDemandes = CALCULATE(
					    [Nombre de demandes de visite adhérent],
					    TREATAS(
					        VALUES('Equipe médicale'[Equipe médicale]),
					        'Adhérent (actuel)'[Equipe médicale]
					    )
					)    // Récupère le nombre de demandes de visites adhérents
					
					RETURN
					    COALESCE(NombreDemandes, 
					    0
					    )                                 // Retourne le nombre de demandes ou 0 si la valeur est vide
					
					/*
					Description :
					Cette mesure retourne le nombre de demandes de visites adhérents.
					Si la valeur est vide ou nulle, elle retourne 0 grâce à l'utilisation de la fonction COALESCE.
					*/
					```
				formatString: #,0
				displayFolder: Demandes de RDV
				lineageTag: 77514d12-a260-449a-a007-71e30f1bff48

			measure 'Nbre de FE' = ```
					
					COALESCE(
					    CALCULATE(
					        [Nombre d'AMT terminées],               -- Mesure à calculer
					        'AMT'[Type] = "Fiche d'entreprise"        -- Filtre pour inclure uniquement les fiches d'entreprise
					    ),
					    0                                           -- Valeur par défaut si le résultat est vide
					)
					
					-- Description : Cette mesure calcule le nombre de fiches d'entreprise (FE) terminées.
					-- Elle utilise la mesure [Nombre d'AMT terminées] et applique un filtre sur le type d'AMT pour inclure uniquement les fiches d'entreprise.
					
					```
				formatString: 0
				displayFolder: FE
				lineageTag: eaf13df0-1944-4e33-80f6-faf06c4b9719

			/// Absenteisme 12 derniers mois = 
			/// VAR CurrentDate = TODAY()                                       -- Obtenir la date actuelle
			/// VAR StartDate12MonthsAgo = EDATE(CurrentDate, -12)              -- Calculer la date du début des 12 derniers mois
			/// VAR EndDateToday = CurrentDate                                  -- Définir la date de fin comme aujourd'hui
			/// VAR DatesLast12Months =                                         -- Créer une table de dates pour les 12 derniers mois
			///     CALCULATETABLE(
			///         'Date principale',
			///         DATESBETWEEN('Date principale'[Date], StartDate12MonthsAgo, EndDateToday) -- Filtrer les dates entre le début et la fin
			///     )
			/// RETURN
			/// CALCULATE(
			///     [Taux annulation non excusée (absentéisme)],                -- Calculer le taux d'absentéisme
			///     DatesLast12Months                                           -- Appliquer le filtre sur les dates des 12 derniers mois
			/// )
			/// 
			/// -- Description :
			/// -- Cette mesure calcule le taux d'absentéisme non excusé sur les 12 derniers mois en utilisant la date actuelle comme référence.
			/// -- Elle crée une table de dates pour les 12 derniers mois et applique ce filtre pour calculer le taux d'absentéisme.
			/// 
			measure 'Absenteisme 12 derniers mois' = ```
					
					VAR CurrentDate = TODAY()                                       -- Obtenir la date actuelle
					VAR StartDate12MonthsAgo = EDATE(CurrentDate, -12)              -- Calculer la date du début des 12 derniers mois
					VAR EndDateToday = CurrentDate                                  -- Définir la date de fin comme aujourd'hui
					VAR DatesLast12Months =                                         -- Créer une table de dates pour les 12 derniers mois
					    CALCULATETABLE(
					        'Date principale',
					        DATESBETWEEN('Date principale'[Date], StartDate12MonthsAgo, EndDateToday) -- Filtrer les dates entre le début et la fin
					    )
					RETURN
					CALCULATE(
					    [Taux annulation non excusée (absentéisme)],                -- Calculer le taux d'absentéisme
					    DatesLast12Months                                           -- Appliquer le filtre sur les dates des 12 derniers mois
					)
					
					-- Description :
					-- Cette mesure calcule le taux d'absentéisme non excusé sur les 12 derniers mois en utilisant la date actuelle comme référence.
					-- Elle crée une table de dates pour les 12 derniers mois et applique ce filtre pour calculer le taux d'absentéisme.
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Absentéisme
				lineageTag: 241b65f1-39be-47da-9efb-5dc15be5d2b8

			/// Cette mesure calcule le taux d'absentéisme non excusé pour le pénultième mois par rapport à la date actuelle.
			/// Elle crée une table de dates pour le pénultième mois et applique ce filtre pour calculer le taux d'absentéisme.
			measure 'Absenteisme Penultieme Mois' = ```
					
					VAR CurrentDate = TODAY()                                                   -- Obtenir la date actuelle
					VAR FirstDayCurrentMonth = DATE(YEAR(CurrentDate), MONTH(CurrentDate), 1)   -- Premier jour du mois actuel
					VAR FirstDayPenultimateMonth = EDATE(FirstDayCurrentMonth, -2)              -- Calculer le premier jour du pénultième mois
					VAR LastDayPenultimateMonth = EOMONTH(FirstDayPenultimateMonth, 0)          -- Calculer le dernier jour du pénultième mois
					VAR DatesPenultimateMonth =                                                 -- Créer une table de dates pour le pénultième mois
					    CALCULATETABLE(
					        'Date principale',
					        DATESBETWEEN('Date principale'[Date], FirstDayPenultimateMonth, LastDayPenultimateMonth)    -- Filtrer les dates du pénultième mois
					    )
					RETURN
					CALCULATE(
					    [Taux annulation non excusée (absentéisme)],                            -- Calculer le taux d'absentéisme
					    DatesPenultimateMonth                                                   -- Appliquer le filtre sur les dates du pénultième mois
					)
					
					-- Description :
					-- Cette mesure calcule le taux d'absentéisme non excusé pour le pénultième mois par rapport à la date actuelle.
					-- Elle crée une table de dates pour le pénultième mois et applique ce filtre pour calculer le taux d'absentéisme.
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Absentéisme
				lineageTag: 5e37e88f-cf86-4272-98ab-117ccc4bfaed

			/// Cette mesure calcule le nombre de salariés suivis en ignorant les filtres appliqués sur la table Utilisateur.
			measure 'Effectif Suivi Non Intérimaire Non Filtré' = ```
					
					CALCULATE(
					    'Evolution retard'[Nombre de salariés suivis],      -- Calculer le nombre de salariés suivis
					    ALL(Utilisateur)                                    -- Ignorer tous les filtres sur la table Utilisateur
					)
					
					-- Description :
					-- Cette mesure calcule le nombre de salariés suivis en ignorant les filtres appliqués sur la table Utilisateur.
					-- Elle utilise CALCULATE avec ALL pour modifier le contexte de filtrage et obtenir un résultat non filtré par utilisateur.
					
					```
				formatString: 0
				displayFolder: Adhérents
				lineageTag: 4165e2c0-994c-4a51-a48d-273445ff280f

			measure Adhérents_Min_Axe_Y =
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date]) -- Capturer la période visible sur le graphe
					
					VAR MinAdherents =
					    MINX(PeriodeVisible, [Nombre d'adhérents fin de période]) -- Trouver la valeur minimale du nombre d'adhérents sur la période visible
					
					RETURN
					    MinAdherents * 0.8 -- Retourner 80% de la valeur minimale
					
					-- Description :
					-- Cette mesure calcule 80% de la valeur minimale du nombre d'adhérents sur la période visible du graphique.
					-- Elle utilise ALLSELECTED pour capturer la période visible et MINX pour déterminer la valeur minimale.
