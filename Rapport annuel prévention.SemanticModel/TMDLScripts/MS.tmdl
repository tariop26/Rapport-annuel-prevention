			measure 'Max Orientations / mois' = ```
					
					MAXX(
					    ALLSELECTED('Date principale'[Mois]),           -- Itérer sur tous les mois sélectionnés
					    [# demandes consultation spécialisée] * 1.15    -- Appliquer une augmentation de 15%
					)
					
					-- Cette mesure calcule le nombre maximal d'orientations par mois,
