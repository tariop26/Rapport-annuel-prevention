			measure 'Max AMT sur période' = ```
					
					VAR MaxAMTTerminees =
					    MAXX(                                           -- Itère sur chaque mois
					        ALLSELECTED('Date principale'[Mois]),       -- Enlève les filtres de rapport sur les mois, mais conserve les autres
					        [# AMT terminées]                           -- Mesure à évaluer pour chaque mois
					    )
					RETURN
					    MaxAMTTerminees * 1.25                          -- Applique un facteur de 125%
					
					-- Description :
					-- Cette mesure calcule la valeur maximale de la mesure '# AMT terminées' sur tous les mois sélectionnés,
					-- en ignorant les filtres de rapport appliqués directement sur les mois.
					-- Elle applique ensuite un facteur de 125% au maximum trouvé pour obtenir le résultat final.
					-- Cela peut être utilisé pour ajuster l'échelle dans des visualisations, par exemple, en prenant en compte une marge de 25%.
					
					```
				formatString: 0
				displayFolder: AMT\Graph
				lineageTag: ffc0ba72-b4d7-47be-82c3-9dcac8a0bc77

			/// Affiche la moyenne des convocations hebdomadaires sur les 12 derniers mois
			measure 'Moy. Convocations Hebdomadaires (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])      -- Obtenir la date actuelle maximale
					VAR LastWeek = CurrentDate - 7                      -- Calculer la date de la semaine dernière 
					VAR FiftyTwoWeeksAgo = LastWeek - 365               -- Calculer la date d'il y a 52 semaines
					VAR TotalVisites =                                  -- Calculer le total des visites sur les 52 dernières semaines
					    CALCULATE(
					        SUM('RDV'[nb_rdv_convoque]),
					        FILTER(
					            'Date principale',
					            'Date principale'[Date] > FiftyTwoWeeksAgo &&
					            'Date principale'[Date] <= LastWeek
					        )
					    )
					VAR NombreSemaines = 52                             -- Nombre de semaines dans un an
					RETURN
					DIVIDE(TotalVisites, NombreSemaines)                -- Calculer la moyenne hebdomadaire des visites
					
					-- Description :
					-- Cette mesure calcule la moyenne hebdomadaire des convocations sur les 12 derniers mois.
					-- Elle prend en compte les dates des 52 dernières semaines par rapport à la date actuelle maximale.
					```
				formatString: #,0
				displayFolder: Convocations
				lineageTag: 5dcd3fc7-c9d7-4e76-ad32-f7589a2b9630

			/// Affiche la moyenne des convocations hebdomadaires sur les 6 derniers mois à destination des IDEST
			measure 'Moy. Convocations Hebdomadaires IDEST (6 mois)' =
					
					VAR CurrentDate = MAX('Date principale'[Date])     -- Obtenir la date actuelle maximale
					VAR LastWeek = CurrentDate - 7                     -- Calculer la date de la semaine dernière
					VAR DaysInSixMonths = 26 * 7                       -- Calculer le nombre de jours dans 6 mois (26 semaines)
					VAR TwentySixWeeksAgo = LastWeek - DaysInSixMonths -- Calculer la date d'il y a 26 semaines
					VAR TotalVisites =                                 -- Calculer le total des convocations IDEST sur les 26 dernières semaines
					    CALCULATE(
					        SUM('RDV'[nb_rdv_convoque]),
					        FILTER(
					            'RDV/visite - réalisateur',
					            'RDV/visite - réalisateur'[Role réalisateur] = "IDEST"
					        ),
					        'Date principale'[Date] > TwentySixWeeksAgo,
					        'Date principale'[Date] <= LastWeek
					    )
					VAR NombreSemaines = 26                             -- Nombre de semaines sur 6 mois
					RETURN
					DIVIDE(TotalVisites, NombreSemaines)                -- Calculer la moyenne hebdomadaire des visites
					
					-- Description :
					-- Cette mesure calcule la moyenne hebdomadaire des convocations IDEST sur les 6 derniers mois.
					-- Elle prend en compte les dates des 26 dernières semaines par rapport à la date actuelle maximale.
				displayFolder: Convocations
				lineageTag: c28d4e09-7af5-417b-b2d6-f3f575573653

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Moy. Convocations Hebdomadaires Médecin (6 mois)' =
					
					VAR CurrentDate = MAX('Date principale'[Date])     -- Obtenir la date actuelle maximale
					VAR LastWeek = CurrentDate - 7                     -- Calculer la date de la semaine dernière
					VAR DaysInSixMonths = 26 * 7                       -- Calculer le nombre de jours dans 6 mois (26 semaines)
					VAR TwentySixWeeksAgo = LastWeek - DaysInSixMonths -- Calculer la date d'il y a 26 semaines
					VAR TotalVisites =                                 -- Calculer le total des convocations Médecin sur les 26 dernières semaines
					    CALCULATE(
					        SUM('RDV'[nb_rdv_convoque]),
					        FILTER(
					            'RDV/visite - réalisateur',
					            'RDV/visite - réalisateur'[Role réalisateur] = "Médecin"
					        ),
					        'Date principale'[Date] > TwentySixWeeksAgo,
					        'Date principale'[Date] <= LastWeek
					    )
					VAR NombreSemaines = 26                             -- Nombre de semaines sur 6 mois
					RETURN
					DIVIDE(TotalVisites, NombreSemaines)                -- Calculer la moyenne hebdomadaire des visites
					
					-- Description :
					-- Cette mesure calcule la moyenne hebdomadaire des convocations Médecin sur les 6 derniers mois.
					-- Elle prend en compte les dates des 26 dernières semaines par rapport à la date actuelle maximale.
				displayFolder: Convocations
				lineageTag: 495f97b7-cc8d-4114-ab88-7a9e3a45fd3a

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Booléen. La période sélectionnée appartient t'elle a la semaine précédente ? oui ou non
			measure 'Avant Pénultième Semaine' = ```
					
					VAR DateActuelle = TODAY()                                                          // Obtient la date actuelle
					VAR DebutPenultiemeSemaine = DateActuelle - 14 - WEEKDAY(DateActuelle - 14, 2) + 1  // Calcule le lundi de la pénultième semaine
					VAR FinPenultiemeSemaine = DebutPenultiemeSemaine + 6                               // Calcule le dimanche de la pénultième semaine
					VAR DateMax = MAX('Date principale'[Date])                                          // Obtient la date maximale dans la colonne 'Date principale'
					
					RETURN
					IF(DateMax <= FinPenultiemeSemaine, "Oui", "Non")                                   // Vérifie si la date maximale est dans la pénultième semaine
					
					/*
					Description :
					Cette mesure vérifie si la date maximale dans la colonne 'Date principale' se situe dans la pénultième semaine par rapport à la date actuelle.
					Elle retourne "Oui" si c'est le cas, sinon "Non".
					*/
					
					```
				displayFolder: Date
				lineageTag: 7ef1787e-fbe8-44ed-b011-1a40d4d23e3e

			/// Affiche le premier puis le dernier jour de la période de données sélectionnée
			measure 'Date ou période sélectionnée' = ```
					
					VAR DateMinimale = MIN('Date principale'[Date])                                                         // Obtient la date minimale dans la colonne 'Date principale'
					VAR DateMaximale = MAX('Date principale'[Date])                                                         // Obtient la date maximale dans la colonne 'Date principale'
					RETURN
					    IF(
					        DateMinimale = DateMaximale,
					        FORMAT(DateMinimale, "dd/MM/yyyy"),                                                             // Retourne la date unique formatée si les dates sont identiques
					        FORMAT(DateMinimale, "dd/MM/yyyy") & " - " & FORMAT(DateMaximale, "dd/MM/yyyy")                 // Retourne la période formatée si les dates sont différentes
					    )
					
					/*
					Description :
					Cette mesure détermine si la période sélectionnée dans la colonne 'Date principale' correspond à une seule date ou à une plage de dates.
					Elle retourne la date unique ou la période formatée en conséquence.
					*/
					
					```
				displayFolder: Date
				lineageTag: 0b70e8e5-7c15-4295-bd8b-bab70dd93f99

			measure 'Début Dernier Mois' = ```
					
					VAR DateActuelle = TODAY()                              // Obtient la date actuelle
					VAR FinAvantDernierMois = EOMONTH(DateActuelle, -2)     // Calcule la fin du mois précédent il y a 2 mois
					VAR DebutDernierMois = FinAvantDernierMois + 1          // Calcule le premier jour du dernier mois
					
					RETURN
					    DebutDernierMois
					
					/*
					Description :
					Cette mesure calcule le premier jour du mois précédent par rapport à la date actuelle.
					Elle utilise la fonction EOMONTH pour déterminer la fin du mois précédent il y a deux mois, puis ajoute un jour pour obtenir le début du dernier mois.
					*/
					
					```
				formatString: Short Date
