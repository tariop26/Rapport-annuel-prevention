			measure '% Annulation par le Service' =
					
					VAR AnnulationsService = [Nombre annulation par le service]     -- Nombre d'annulations par le service
					VAR TotalRDV = [Nombre de RDV]                                -- Nombre total de rendez-vous
					RETURN
					DIVIDE(AnnulationsService, TotalRDV, 0)                       -- Calculer le pourcentage d'annulations par le service, retourne 0 en cas de division par zéro
					
					-- Description :
					-- Cette mesure calcule le pourcentage d'annulations par le service par rapport au nombre total de rendez-vous.
					-- Elle utilise la fonction DIVIDE pour éviter les erreurs de division par zéro.
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Annulation
				lineageTag: 07e9df00-395c-43d9-8d1a-47f1314cbf75

			measure 'Nombre Annulation par le Service' =
					
					VAR Motif = "Annulation par le service"     -- Définir le motif d'annulation par le service
					
					RETURN
					CALCULATE(
					    [Nombre de RDV annulés],
					    'RDV - motif annulation'[Motif annulation] = Motif
					)
					
					-- Description :
					-- Cette mesure calcule le nombre de rendez-vous annulés par le service.
					-- Elle utilise la fonction CALCULATE pour appliquer un filtre sur le motif d'annulation.
				formatString: #,0
