			measure 'Capacité Théorique IDEST' = ```
					
					VAR Role = "IDEST"                                              -- Définir le rôle "IDEST" dans une variable pour une meilleure lisibilité
					VAR CapaciteVisitesAnnuelles =                                  -- Calculer la somme des capacités de visites annuelles
					    CALCULATE(
					        SUM('4 - Equipes - membres'[Capacité visites annuelles]),
					        '4 - Equipes - membres'[Attribut (groupes)] = Role      -- Appliquer le filtre sur le rôle "IDEST"
					    )
					RETURN
					    CapaciteVisitesAnnuelles                                    -- Retourner le résultat final
					
					-- Description :
					-- Cette mesure calcule la capacité théorique annuelle des visites pour les membres ayant le rôle "IDEST".
					-- Elle utilise une variable pour stocker le rôle et applique un filtre dans CALCULATE pour obtenir la somme des capacités de visites annuelles.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 1d656bb3-4f13-4532-967a-4e12b8408502

			measure 'Capacité Théorique Médecin' = ```
					
					VAR Role = "Médecin"                                              -- Définir le rôle "Médecin" dans une variable pour une meilleure lisibilité
					VAR CapaciteVisitesAnnuelles =                                  -- Calculer la somme des capacités de visites annuelles
					    CALCULATE(
					        SUM('4 - Equipes - membres'[Capacité visites annuelles]),
					        '4 - Equipes - membres'[Attribut (groupes)] = Role      -- Appliquer le filtre sur le rôle "Médecin"
					    )
					RETURN
					    CapaciteVisitesAnnuelles                                    -- Retourner le résultat final
					
					-- Description :
					-- Cette mesure calcule la capacité théorique annuelle des visites pour les membres ayant le rôle "Médecin".
					-- Elle utilise une variable pour stocker le rôle et applique un filtre dans CALCULATE pour obtenir la somme des capacités de visites annuelles.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: cf5d4f00-56ef-4112-9174-4e77392cca67

			measure 'Visites périodiques IDEST' = ```
					
					VAR VisitesSI =
					    'Salariés'[Effectif suivi non-intérimaire SI] * 0.2                         -- SI tous les 5 ans par IDEST
					
					VAR VisitesSIA =
					    'Salariés'[Effectif suivi non-intérimaire SIA] * 0.166667                   -- SIA tous les 6 ans par IDEST (tous les 3 ans mais une fois sur deux par Médecin)
					
					VAR VisitesSIR =
					    'Salariés'[Effectif suivi non-intérimaire SIR] * 0.25                       -- SIR tous les 4 ans par IDEST (tous les 2 ans mais une fois sur deux par Médecin)
					
					VAR VisitesCatA = 0                                                             -- INB et RI cat A non applicable pour IDEST
					
					VAR VisitesCatB =
					    [Effectif suivi INB cat B] * 0.5                                            -- INB cat B tous les 2 ans par IDEST (tous les ans mais une fois sur deux par Médecin)
					
					RETURN
					    VisitesSI + VisitesSIA + VisitesSIR + VisitesCatA + VisitesCatB             -- Somme des différentes catégories de visites
					
					-- Description :
					-- Cette mesure calcule le nombre total de visites périodiques effectuées par les IDEST pour différentes catégories de salariés.
					-- Elle prend en compte les visites pour les catégories SI, SIA, SIR, et INB cat B, en appliquant les fréquences appropriées.
					
					```
				formatString: #,0.00
				displayFolder: Prévision de charge
				lineageTag: 97d9e488-e7f9-4cb1-80c4-7a2333131ea5

			measure 'Nombre de visites intérimaires Médecin (12 derniers mois)' = ```
					
					VAR DateDernierAn = TODAY() - 365                                                   -- Calculer la date d'il y a un an
					
					RETURN
					    CALCULATE(
					        [Nombre de visites réalisées (RDV)],
					        'Salarié (actuel)'[Contrat intérimaire (actuel)] = "Salarié intérimaire",
					        'RDV/visite - réalisateur'[Role réalisateur] = "Médecin",
					        'Date principale'[Date] >= DateDernierAn,                                   -- Filtrer sur les 12 derniers mois
					        ALL('Adhérent (actuel)'[Type entreprise])
					    )
					
					-- Description :
					-- Cette mesure calcule le nombre de visites intérimaires réalisées par un médecin sur les 12 derniers mois.
					-- Elle utilise une variable pour stocker la date d'il y a un an et applique un filtre dans CALCULATE pour obtenir le nombre de visites réalisées sur cette période.
					
					```
				formatString: #,0
				displayFolder: Prévision de charge
				lineageTag: 07ac53eb-4898-43a3-bc3b-c70c2371821c

			measure 'Nombre de visites occasionnelles Médecin (12 derniers mois)' = ```
					
					VAR DateDernierAn = TODAY() - 365                                           -- Calculer la date d'il y a un an
					
					RETURN
					    CALCULATE(
					        [Nombre de visites réalisées (RDV)],
					        'RDV/visite - type visite'[Catégorie visite] = "Occasionnelle",
					        'Date principale'[Date] >= DateDernierAn                            -- Filtrer sur les 12 derniers mois
					    )
					
					-- Description :
					-- Cette mesure calcule le nombre de visites occasionnelles réalisées par un médecin sur les 12 derniers mois.
					-- Elle utilise une variable pour stocker la date d'il y a un an et applique un filtre dans CALCULATE pour obtenir le nombre de visites réalisées sur cette période.
					
