				annotation __PBI_SemanticLinks = [{"LinkTarget":{"TableName":"Examen complémentaire - type examen","TableItemName":"Type examen (groupes)","ObjectType":4},"LinkType":"UsedInGroup"}]

			column 'Type examen (groupes)' =
					SWITCH(
						TRUE,
						ISBLANK('Examen complémentaire - type examen'[Type examen]),
						"(Vide)",
						'Examen complémentaire - type examen'[Type examen] IN {"Audiogramme",
							"Audiolyser ADL20 connecté",
							"Audiométrie",
							"PDD401 connecté"},
						"Audiométrie",
						'Examen complémentaire - type examen'[Type examen] IN {"Bandelette urinaire"},
						"Bandelette urinaire",
						'Examen complémentaire - type examen'[Type examen] IN {"IMC"},
						"IMC",
						'Examen complémentaire - type examen'[Type examen] IN {"Spirolyser Q13 connecté",
							"Spirométrie"},
						"Spirométrie",
						'Examen complémentaire - type examen'[Type examen] IN {"Tension"},
						"Tension",
						'Examen complémentaire - type examen'[Type examen] IN {"Astigmatisme",
							"Autre examen vision",
							"Champs visuel",
							"Visiolite connecté",
							"Vision de loin",
							"Vision de près",
							"Vision des couleurs"},
						"Visiotest",
						"Autre"
					)
				lineageTag: b5cca48c-27d8-4c05-9597-2f9e43c506e2
