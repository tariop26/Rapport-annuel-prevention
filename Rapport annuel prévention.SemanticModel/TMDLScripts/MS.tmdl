					VAR TxServiceS3 = [Tx de service S-3] -- Taux de service pour la semaine S-3
					
					RETURN
					    DIVIDE(
					        TxServiceS2 - TxServiceS3,      -- Calculer la différence entre S-2 et S-3
					        TxServiceS3,                    -- Diviser par le taux de service de S-3
					        0                               -- Valeur par défaut si le dénominateur est zéro, pour éviter les erreurs
					    )
					
					-- Cette mesure calcule le pourcentage de variation du taux de service entre les semaines S-3 et S-2.
					-- Elle utilise des variables pour stocker les taux de service des deux semaines et la fonction DIVIDE pour gérer les divisions par zéro.
					
