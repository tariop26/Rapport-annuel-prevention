			measure Adhérents_Max_Axe_Y = ```
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date]) -- Capturer la période visible sur le graphe
					
					VAR MaxAdherents =
					    MAXX(PeriodeVisible, [Nombre d'adhérents fin de période]) -- Trouver la valeur maximale du nombre d'adhérents sur la période visible
					
