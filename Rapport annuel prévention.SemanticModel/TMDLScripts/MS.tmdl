			/// Permet d'afficher la sélection dans le coin en haut à gauche du rapport : Ensemble du service, Zone, Centre ou équipe
			/// 
			/// Entite Selectionnee =
			/// VAR SelectedTeam = SELECTEDVALUE('Equipe médicale'[Equipe médicale])
			/// VAR SelectedCenter = SELECTEDVALUE('Equipe médicale'[Centre rattachement])
			/// VAR SelectedGeographicZone = SELECTEDVALUE('Equipe médicale'[Zone géographique])
			/// 
			/// RETURN
			/// IF(
			/// NOT ISBLANK(SelectedTeam),
			/// "Equipe médicale : " & SelectedTeam,
			/// IF(
			/// NOT ISBLANK(SelectedCenter),
			/// "Centre de convocation : " & SelectedCenter,
			/// IF(
			/// NOT ISBLANK(SelectedGeographicZone),
			/// "Zone géographique : " & SelectedGeographicZone,
			/// "Ensemble du service"
			/// )
			/// )
			/// )
			measure 'Médecin sélectionné' = ```
					
					VAR EquipesSelectionnees = VALUES('Equipe médicale'[Equipe médicale])
					VAR ZoneGeographiqueSelectionnee = SELECTEDVALUE('Equipe médicale'[Equipe médicale (secteur et médecin référent)])
					VAR SecteurSelectionnee = SELECTEDVALUE('Equipe médicale'[Zone géographique])
					VAR CentreSelectionnee = SELECTEDVALUE('Equipe médicale'[Centre rattachement])
					VAR AdherentSelectionnee = SELECTEDVALUE('Adhérent (actuel)'[Nom entreprise])
					
					
					// Vérifie si un seul médecin référent est associé à toutes les équipes sélectionnées
					VAR MedecinReferent =
					    IF(
					        COUNTROWS(EquipesSelectionnees) = 1,
					        LOOKUPVALUE('Equipe médicale'[Médecin référent], 'Equipe médicale'[Equipe médicale], SELECTEDVALUE('Equipe médicale'[Equipe médicale])),
					        IF(
					            HASONEVALUE('Equipe médicale'[Médecin référent]),
					            VALUES('Equipe médicale'[Médecin référent]),
					            "Plusieurs médecins référents"
					        )
					    )
					
					RETURN
					    IF(
					        NOT ISBLANK(AdherentSelectionnee),
					            AdherentSelectionnee,
					            IF(
					                NOT ISBLANK(SELECTEDVALUE('Equipe médicale'[Equipe médicale])),
					                    "Equipe médicale  : " & EquipesSelectionnees,
					                    IF(
					                        NOT ISBLANK(CentreSelectionnee),
					                        "Centre : " & CentreSelectionnee,
					                        IF(
					                            NOT ISBLANK(ZoneGeographiqueSelectionnee),
					                            "Zone géographique : " & ZoneGeographiqueSelectionnee,
					                            "PST38"
					                        )
					                    )
					            )
					    )
					
					```
				displayFolder: Divers
				lineageTag: 3dd51da0-b737-4755-85f8-74356075ef37

			measure 'Etiquette min/max tx de service' = ```
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date])                           // Capture la période affichée sur le graphe
					VAR MaxTauxService = MAXX(PeriodeVisible, 'Mesures'[Taux de service])               // Trouve le maximum sur la période affichée
					VAR MinTauxService = MINX(PeriodeVisible, 'Mesures'[Taux de service])               // Trouve le minimum sur la période affichée
					VAR DerniereDateVisible = MAXX(PeriodeVisible, 'Date principale'[Date])             // Trouve la dernière date visible
					VAR TauxServiceDerniereDate =
					    CALCULATE(
					        'Mesures'[Taux de service],
					        'Date principale'[Date] = DerniereDateVisible                               // Récupère le taux de service à la dernière date
					    )
					
					RETURN
					    IF(
					        'Mesures'[Taux de service] = MaxTauxService ||
					        'Mesures'[Taux de service] = MinTauxService ||
					        'Mesures'[Taux de service] = TauxServiceDerniereDate,
					        'Mesures'[Taux de service],
					        BLANK()                                                                     // Retourne une valeur vide si aucune condition n'est remplie
					    )
					
					/*
					Description :
					Cette mesure identifie et retourne le taux de service s'il correspond au maximum, au minimum ou au taux de service de la dernière date visible sur le graphe.
					Elle utilise des variables pour capturer la période visible, calculer les valeurs maximales et minimales, et obtenir le taux de service à la dernière date.
					*/
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Etiquettes
				lineageTag: 0dd4b39d-bb11-4fbc-b627-596729552279

			/// Affiche seulement l'étiquette de données Max et Min sur le graph de l'évolution des effectifs suivis.
			measure 'Etiquette min/max/dernier effectif suivi' = ```
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date]) // Capture la période affichée sur le graphe
					VAR MaxEffectif = MAXX(PeriodeVisible, [Effectif suivi figé non intérimaire fin de période]) // Trouve le maximum sur la période affichée
					VAR MinEffectif = MINX(PeriodeVisible, [Effectif suivi figé non intérimaire fin de période]) // Trouve le minimum sur la période affichée
					VAR DerniereDateVisible = MAX('Date principale'[Date]) // Trouve la dernière date visible
					
					// Récupère le dernier mois terminé
					VAR DernierMoisTermine =
					    MAXX(
					        FILTER(
					            VALUES('Date principale'[Date]),
					            'Date principale'[Date] < TODAY() // On s'assure que le mois est bien terminé
					        ),
					        FORMAT('Date principale'[Date], "YYYY-MM") // Récupère le dernier mois terminé
					    )
					
					// Récupère le dernier jour du dernier mois terminé
					VAR DernierJourDernierMois =
					    MAXX(
					        FILTER(
					            'Date principale',
					            FORMAT('Date principale'[Date], "YYYY-MM") = DernierMoisTermine
					        ),
					        'Date principale'[Date]
					    )
					
					// Récupère la valeur de l'effectif au dernier jour du dernier mois terminé
					VAR EffectifDernierJourMois =
					    CALCULATE(
					        [Effectif suivi figé non intérimaire fin de période],
					        FILTER(
					            'Date principale',
					            'Date principale'[Date] = DernierJourDernierMois
					        )
					    )
					
					// Retourne l'effectif s'il correspond au maximum, au minimum ou à l'effectif de la dernière date du dernier mois terminé
					RETURN
					    IF(
					        [Effectif suivi figé non intérimaire fin de période] = 0,
					        BLANK(), // Retourne une valeur vide si l'effectif est égal à zéro
					        IF(
					            [Effectif suivi figé non intérimaire fin de période] = MaxEffectif ||
					            [Effectif suivi figé non intérimaire fin de période] = MinEffectif ||
					            (MAX('Date principale'[Date]) = DernierJourDernierMois && [Effectif suivi figé non intérimaire fin de période] = EffectifDernierJourMois),
					            [Effectif suivi figé non intérimaire fin de période],
					            BLANK() // Retourne une valeur vide si aucune condition n'est remplie
					        )
					    )
					
					/*
					Description :
					Cette mesure identifie et retourne l'effectif suivi s'il correspond au maximum, au minimum ou à l'effectif de la dernière date du dernier mois terminé visible sur le graphe.
					Elle utilise des variables pour capturer la période visible, calculer les valeurs maximales et minimales, et obtenir l'effectif à la dernière date du mois terminé.
					Les améliorations incluent une meilleure gestion des dates et une optimisation des calculs pour garantir des performances élevées.
					*/
					
					```
				formatString: #,0
				displayFolder: Etiquettes
				lineageTag: ecf7375e-9611-4126-b820-baa2dd82f279

			measure '# adhérents avec FE à mettre à jour (fin de période)' = ```
					
					CALCULATE(
					    'Evolution effectif'[# adhérents en retard de FE (fin de période)],         -- Mesure à calculer
					    'Evolution effectif'[date dernière fe] <> DATE(1900, 1, 1)                  -- Filtre pour exclure les dates non valides
					)
					
					-- Description : Cette mesure calcule le nombre d'adhérents dont la fiche d'évaluation (FE) doit être mise à jour à la fin de la période.
					-- Elle exclut les adhérents dont la date de la dernière FE est une date par défaut (1900-01-01), indiquant que la FE n'est pas valide ou n'a pas été mise à jour.
					
