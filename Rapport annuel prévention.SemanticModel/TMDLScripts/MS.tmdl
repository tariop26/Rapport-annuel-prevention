					VAR DateFormatee = FORMAT(FinMoisDernier, "dd/MM/yyyy")     // Formate la date au format jour/mois/année
					
					RETURN
					    TexteBase & DateFormatee                                // Concatène le texte de base avec la date formatée
					
					/*
