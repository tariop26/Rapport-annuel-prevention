			measure Effectif_max_Axe_Y = ```
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date])                           -- Capture la période affichée sur le graphe
					
					VAR Effectif_Maxi =
					    MAXX(PeriodeVisible, [Effectif suivi figé non intérimaire fin de période])      -- Trouve le maximum sur la période affichée
					    
					    
					RETURN
					  Effectif_Maxi * 1.1
					
					  
					-- Description :
					-- Cette mesure calcule 80% de la valeur maximale de l'effectif suivi non intérimaire sur la période visible du graphique.
					-- Elle utilise ALLSELECTED pour capturer la période visible et MAXX pour déterminer la valeur maximale.
					-- Cett mesure sert à règler l'affichage sur l'échelle Y d'un graph 'Evolution de l'effectif suivi non intérimaire' dans le temps
					```
