				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Durée AMT en jours (Pénultième mois)' = ```
					
					VAR DateActuelle = TODAY()                                                      -- Obtenir la date actuelle
					VAR PremierJourMoisActuel = DATE(YEAR(DateActuelle), MONTH(DateActuelle), 1)    -- Premier jour du mois actuel
					VAR PremierJourPenultiemeMois = EDATE(PremierJourMoisActuel, -2)                -- Premier jour du pénultième mois
					VAR DernierJourPenultiemeMois = EOMONTH(PremierJourPenultiemeMois, 0)           -- Dernier jour du pénultième mois
					VAR DatesPenultiemeMois =                                                       -- Table de dates du pénultième mois
					    CALCULATETABLE(
					        'Date principale',
					        DATESINPERIOD('Date principale'[Date], DernierJourPenultiemeMois, -1, MONTH)
					    )
					RETURN
					CALCULATE( 
					    [Évolution Nbre AMT 2023->2024],                                        -- Calculer la durée de visite
					    DatesPenultiemeMois                                          -- Filtrer par les dates du pénultième mois
					)
					
					-- Description :
					-- Cette mesure calcule la durée moyenne des AMT en jours du Pénultième Mois
					-- Elle utilise AVERAGEX pour itérer sur chaque AMT et DATEDIFF pour calculer la différence entre la date de création et la date de clôture.
					-- RELATED est utilisé pour récupérer les dates de création et de clôture à partir des tables associées.
					```
				displayFolder: AMT
				lineageTag: 764d7190-00db-4975-8371-65b598090070

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Nombre d''AMT terminées (Pénultième mois)' =
					
					VAR DateActuelle = TODAY()                                                      -- Obtenir la date actuelle
					VAR PremierJourMoisActuel = DATE(YEAR(DateActuelle), MONTH(DateActuelle), 1)    -- Premier jour du mois actuel
					VAR PremierJourPenultiemeMois = EDATE(PremierJourMoisActuel, -2)                -- Premier jour du pénultième mois
					VAR DernierJourPenultiemeMois = EOMONTH(PremierJourPenultiemeMois, 0)           -- Dernier jour du pénultième mois
					VAR DatesPenultiemeMois =                                                       -- Table de dates du pénultième mois
					    CALCULATETABLE(
					        'Date principale',
					        DATESINPERIOD('Date principale'[Date], DernierJourPenultiemeMois, -1, MONTH)
					    )
					RETURN
					CALCULATE(
					    [# AMT terminées],                                                          -- Calculer le nombre d'AMT
					    DatesPenultiemeMois                                                         -- Filtrer par les dates du pénultième mois
					)
				formatString: 0
				displayFolder: AMT
				lineageTag: d3ff2f81-2cc4-4e46-bbb7-b7192d42c20d

			measure 'Nbre d''entretiens PDP' = ```
					
					VAR PDP =
					    CALCULATE(
					        [Nombre de visites réalisées (RDV)],
					        'RDV/visite - réalisateur'[Profil réalisateur détaillé] = "Conseiller maintien de la cellule PDP"
					    )
					RETURN
					    CALCULATE(
					        PDP,
					        'Date principale'[Filtre Période 12 mois ajustés] = TRUE
					    )
					
					-- Explications :
					-- 1. PDP : Calcule le nombre de visites réalisées par les "Conseiller maintien de la cellule PDP".
					-- 2. CALCULATE final : Applique le filtre pour inclure uniquement les visites des 12 derniers mois en utilisant la colonne calculée [Filtre Période 12 mois ajustés].
					
					```
				formatString: #,0
				displayFolder: Consultations Spécialisées\PDP
				lineageTag: 7ef7f0b7-4291-4345-8278-da6cb73f96c9

			measure 'Nombre Moyen Entretiens PDP par Mois' =
					
					VAR CurrentDate = MAX('Date principale'[Date])     -- Obtenir la date actuelle maximale
					VAR LastMonth = EOMONTH(CurrentDate, -1)           -- Dernier jour du mois précédent
					VAR TwelveMonthsAgo = EOMONTH(LastMonth, -12)      -- Dernier jour du mois, 12 mois en arrière
					VAR NombreMois = 12                                -- Nombre de mois sur la période de 12 mois
					VAR NombreEntretiensPDP =                          -- Calculer le nombre d'entretiens PDP sur les 12 derniers mois
					    CALCULATE(
					        [Nbre d'entretiens PDP],
					        'Date principale'[Date] > TwelveMonthsAgo,
					        'Date principale'[Date] <= LastMonth
					    )
					RETURN
					DIVIDE(NombreEntretiensPDP, NombreMois)             -- Calculer la moyenne mensuelle des entretiens PDP
					
					-- Description :
					-- Cette mesure calcule le nombre moyen d'entretiens PDP par mois sur les 12 derniers mois.
					-- Elle utilise la date maximale de la colonne 'Date principale' pour déterminer la période de calcul.
				formatString: #,0
				displayFolder: Consultations Spécialisées\PDP
				lineageTag: fb2344a1-752a-4acd-8a25-cf413fede6e4

			measure 'Nbre d''entretiens QVCT' =
					
					VAR QVCT =
					    CALCULATE(
					        [Nombre de visites réalisées (RDV)],
					        'RDV/visite - réalisateur'[Profil réalisateur détaillé] = "Psychologue du travail"
					    )
					RETURN
					    QVCT
					
					-- Explications :
					-- 1. QVCT : Calcule le nombre de visites réalisées par les "Psychologue du travail".
				formatString: #,0
				displayFolder: Consultations Spécialisées\QVCT
				lineageTag: 32d9ac41-93ab-46fc-9fb6-ac8b05c4916d

			measure 'Nombre Moyen Entretiens QVCT par Mois' =
					
					VAR CurrentDate = MAX('Date principale'[Date])     -- Obtenir la date actuelle maximale
					VAR LastMonth = EOMONTH(CurrentDate, -1)           -- Dernier jour du mois précédent
					VAR TwelveMonthsAgo = EOMONTH(LastMonth, -12)      -- Dernier jour du mois, 12 mois en arrière
					VAR NombreMois = 12                                -- Nombre de mois sur la période de 12 mois
					VAR NombreEntretiensQVCT =                          -- Calculer le nombre d'entretiens QVCT sur les 12 derniers mois
					    CALCULATE(
					        [Nbre d'entretiens QVCT],
					        'Date principale'[Date] > TwelveMonthsAgo,
					        'Date principale'[Date] <= LastMonth
					    )
					RETURN
					DIVIDE(NombreEntretiensQVCT, NombreMois)             -- Calculer la moyenne mensuelle des entretiens QVCT
					
					-- Description :
					-- Cette mesure calcule le nombre moyen d'entretiens QVCT par mois sur les 12 derniers mois.
