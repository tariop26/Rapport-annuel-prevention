			measure 'Nom Utilisateur Sélectionné' = ```
					
					IF(
					    ISFILTERED('Utilisateur'[Nom utilisateur]),                 -- Vérifier si un filtre est appliqué sur le nom d'utilisateur
					    SELECTEDVALUE('Utilisateur'[Nom utilisateur]),              -- Retourner la valeur sélectionnée si un filtre est appliqué
					    "PST38"                                  -- Retourner une valeur par défaut si aucun filtre n'est appliqué
					)
					
					-- Cette mesure retourne le nom de l'utilisateur sélectionné si un filtre est appliqué sur la colonne 'Nom utilisateur'.
					-- Si aucun filtre n'est appliqué, elle retourne la chaîne "PST38".
					
					```
				displayFolder: Divers
				lineageTag: 762624a4-e940-4616-b4a3-cb900f3cecdf

			measure 'Temps Format Horaire' = ```
					
					VAR TotalHeures = 'temps travail'[temps total créneaux (en heures)]         -- Total des heures de travail
					VAR Heures = INT(TotalHeures)                                               -- Extraire la partie entière des heures
					VAR Minutes = INT((TotalHeures - Heures) * 60)                              -- Calculer les minutes restantes
					RETURN
					    FORMAT(Heures, "0") & "h" & FORMAT(Minutes, "00")                       -- Formater et concaténer les heures et minutes
					
					-- Cette mesure convertit un total d'heures en un format horaire lisible (heures et minutes). 
					-- Elle utilise des variables pour séparer les calculs des heures et des minutes, et formate le résultat pour un affichage cohérent.
					
					```
				displayFolder: Divers
				lineageTag: cf756533-909d-41c1-a4ee-012993af1929

			/// Taux d'annulation non excusée de l'ensemble des IDEST PST.  Cela permet de comparer le taux d'annulation d'un IDEST avec celui de tous ces collègues IDEST cumulés
			measure 'Taux Annulation IDEST (Tout PST38)' = ```
					
					CALCULATE(
					    [Taux annulation non excusée (absentéisme)],                    -- Mesure à évaluer dans le nouveau contexte
					    'RDV/visite - réalisateur'[Role réalisateur] = "IDEST",         -- Filtrer les rôles réalisateurs pour "IDEST"
					    REMOVEFILTERS('Utilisateur'),                                   -- Ignorer tous les filtres sur la table 'Utilisateur'
					    REMOVEFILTERS('Adhérent (actuel)')                              -- Ignorer tous les filtres sur la table 'Adhérent (actuel)'
					)
					
					-- Cette mesure calcule le taux d'annulation non excusée pour les réalisateurs ayant le rôle "IDEST",
					-- en ignorant les filtres appliqués sur les tables 'Utilisateur' et 'Adhérent (actuel)'.
					-- Cela permet de comparer le taux d'annulation d'un IDEST avec celui de tous ces collègues IDEST cumulés
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Absentéisme
				lineageTag: d83be82b-1f07-4b0f-b5f9-e771315fe411

			measure 'Moy. AMT mensuelles PDP (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])      -- Obtenir la date actuelle maximale
					VAR LastMonth = EOMONTH(CurrentDate, -1)            -- Calculer la fin du mois précédent
					VAR TwelveMonthsAgo = EOMONTH(LastMonth, -12)       -- Calculer la date il y a 12 mois
					VAR TotalVisites =
					    CALCULATE(
					        [Nombre d'AMT terminées],                   -- Mesure à évaluer
					        'AMT - intervenant'[Profil intervenant détaillé] = "Conseiller maintien de la cellule PDP",     -- Filtrer par profil d'intervenant
					        'Date principale'[Date] > TwelveMonthsAgo,  -- Filtrer les dates après il y a 12 mois
					        'Date principale'[Date] <= CurrentDate      -- Filtrer les dates jusqu'à la date actuelle
					    )
					VAR NombreMois = 12                                 -- Nombre de mois pour la moyenne
					
					RETURN
					    DIVIDE(TotalVisites, NombreMois)                -- Calculer la moyenne mensuelle
					
					-- Cette mesure calcule la moyenne mensuelle du nombre d'AMT terminées par un conseiller PDP sur les 12 derniers mois.
					-- Elle utilise des variables pour définir les périodes de temps et applique des filtres pour obtenir le total des visites.
					
					```
				displayFolder: AMT
				lineageTag: e7a1d568-4d00-4c14-935f-d55c74e660b7

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Moy. AMT mensuelles QVCT (12 mois)' = ```
					
