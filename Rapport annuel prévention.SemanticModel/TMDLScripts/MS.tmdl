			partition 'Choisir Période' = calculated
				mode: import
				source =
						{
						    ("Mois", NAMEOF('Date principale'[Mois]), 0)
						}

			annotation PBI_Id = 763a01d99fac43f387847f78a9dcc573

		/// Table de mesure
		table Mesures
			lineageTag: e4e5606e-6c09-4686-927a-7d77b8ae27e1

			measure 'Différence prévisions / réel' = ```
					
					VAR VisitesAnnuelles = [Visites annuelles]          -- Récupère la valeur des visites annuelles prévues
					VAR VisitesReelles = [Nombre de visites]            -- Récupère la valeur des visites réelles
					VAR Difference =
					    COALESCE(VisitesAnnuelles, 0) - COALESCE(VisitesReelles, 0)     -- Calcule la différence, en gérant les valeurs nulles
					    
					RETURN
					Difference
					
					-- Cette mesure calcule la différence entre les visites annuelles prévues et les visites réelles.
					-- Elle utilise des variables pour stocker les valeurs des visites prévues et réelles, et gère les valeurs nulles avec COALESCE.
					
					```
				formatString: #,0
				displayFolder: Visites
				lineageTag: 5f0da02d-3dc4-482d-b6d1-257596c1054d

			/// Affiche la moyenne des visites hebdomadaires des 12 derniers mois
			measure 'Moy. visites hebdomadaires (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])                      -- Récupère la date maximale du contexte actuel
					VAR LastWeek = CurrentDate - 7                                      -- Calcule la date de la semaine précédente
					VAR FiftyTwoWeeksAgo = LastWeek - 364                               -- Calcule la date il y a 52 semaines par rapport à LastWeek
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'Date principale'[Date] > FiftyTwoWeeksAgo && 'Date principale'[Date] <= LastWeek       -- Filtre sur les 52 dernières semaines
					    )
					VAR NombreSemaines = 52                                             -- Nombre de semaines sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreSemaines, 0)                             -- Calcule la moyenne hebdomadaire, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne hebdomadaire des visites sur les 52 dernières semaines.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				formatString: #,0
				displayFolder: Visites
				lineageTag: 8e06447d-74a0-4ec1-9a43-13e5ac99a0a2

			/// Affiche la moyenne des visites hebdomadaires des 6 derniers mois réalisés par les IDEST
			measure 'Moy. visites hebdomadaires IDEST (6 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])                  -- Récupère la date maximale du contexte actuel
					VAR LastWeek = CurrentDate - 7                                  -- Calcule la date de la semaine précédente
					VAR TwentySixWeeksAgo = LastWeek - 182                          -- Calcule la date il y a 26 semaines par rapport à LastWeek
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'RDV/visite - réalisateur'[Role réalisateur] = "IDEST",                                 -- Filtre pour les IDEST
					        'Date principale'[Date] > TwentySixWeeksAgo && 'Date principale'[Date] <= LastWeek      -- Filtre sur les 26 dernières semaines
					    )
					VAR NombreSemaines = 26                                         -- Nombre de semaines sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreSemaines, 0)                         -- Calcule la moyenne hebdomadaire, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne hebdomadaire des visites effectuées par des IDEST sur les 26 dernières semaines.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				formatString: #,0
				displayFolder: Visites
				lineageTag: 1b83c8e0-4aad-4490-ad37-d3f9dda69bdf

			measure 'Moy. visites hebdomadaires Médecin (6 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])                  -- Récupère la date maximale du contexte actuel
					VAR LastWeek = CurrentDate - 7                                  -- Calcule la date de la semaine précédente
					VAR TwentySixWeeksAgo = LastWeek - 182                          -- Calcule la date il y a 26 semaines par rapport à LastWeek
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'RDV/visite - réalisateur'[Role réalisateur] = "Médecin",                               -- Filtre pour les médecins
					        'Date principale'[Date] > TwentySixWeeksAgo && 'Date principale'[Date] <= LastWeek      -- Filtre sur les 26 dernières semaines
					    )
					VAR NombreSemaines = 26                                         -- Nombre de semaines sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreSemaines, 0)                         -- Calcule la moyenne hebdomadaire, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne hebdomadaire des visites effectuées par des médecins sur les 26 dernières semaines.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				formatString: #,0
				displayFolder: Visites
				lineageTag: 968bc2a1-78b4-4b35-9515-bd8d8cff0549

			/// Affiche la moyenne des visites des 12 derniers mois
			/// 
			measure 'Moy. visites mensuelles (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])              -- Récupère la date maximale du contexte actuel
					VAR LastMonth = EOMONTH(CurrentDate, 0)                    -- Calcule la fin du mois précédent
					VAR TwelveMonthsAgo = EOMONTH(LastMonth, -12)               -- Calcule la date il y a 12 mois par rapport à LastMonth
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'Date principale'[Date] > TwelveMonthsAgo && 'Date principale'[Date] <= LastMonth       -- Filtre sur les 12 derniers mois
					    )
					VAR NombreMois = 12                                        -- Nombre de mois sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreMois, 0)                         -- Calcule la moyenne mensuelle, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne mensuelle des visites effectuées sur les 12 derniers mois.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				formatString: #,0
				displayFolder: Visites
				lineageTag: f64822a3-b0bd-4263-a0ad-e4a653753c52

			/// Affiche la moyenne des visites des 12 derniers mois réalisés par les IDEST
			measure 'Moy. visites mensuelles IDEST (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])              -- Récupère la date maximale du contexte actuel
					VAR LastMonth = EOMONTH(CurrentDate, 0)                    -- Calcule la fin du mois précédent
					VAR TwelveMonthsAgo = EOMONTH(LastMonth, -12)               -- Calcule la date il y a 12 mois par rapport à LastMonth
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'RDV/visite - réalisateur'[Role réalisateur] = "IDEST",                                 -- Filtre pour les IDEST
					        'Date principale'[Date] > TwelveMonthsAgo && 'Date principale'[Date] <= LastMonth       -- Filtre sur les 12 derniers mois
					    )
					VAR NombreMois = 12                                        -- Nombre de mois sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreMois, 0)                         -- Calcule la moyenne mensuelle, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne mensuelle des visites effectuées par des IDEST sur les 12 derniers mois.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				formatString: #,0
				displayFolder: Visites
				lineageTag: 57b26ea5-9aa4-4be5-9795-15251b4b37bf

			/// Affiche la moyenne des visites des 12 derniers mois réalisés par les Médecins
			measure 'Moy. visites mensuelles Médecin (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])              -- Récupère la date maximale du contexte actuel
					VAR LastMonth = EOMONTH(CurrentDate, 0)                    -- Calcule la fin du mois précédent
					VAR TwelveMonthsAgo = EOMONTH(LastMonth, -12)               -- Calcule la date il y a 12 mois par rapport à LastMonth
					VAR TotalVisites =
					    CALCULATE(
					        SUM('Visite'[nb_visite]),
					        'RDV/visite - réalisateur'[Role réalisateur] = "Médecin",                               -- Filtre pour les médecins
					        'Date principale'[Date] > TwelveMonthsAgo && 'Date principale'[Date] <= LastMonth       -- Filtre sur les 12 derniers mois
					    )
					VAR NombreMois = 12                                        -- Nombre de mois sur lequel on calcule la moyenne
					
					RETURN
					DIVIDE(TotalVisites, NombreMois, 0)                         -- Calcule la moyenne mensuelle, retourne 0 si TotalVisites est 0
					
					-- Cette mesure calcule la moyenne mensuelle des visites effectuées par des médecins sur les 12 derniers mois.
					-- Elle utilise des variables pour définir les dates de début et de fin, puis filtre les visites en conséquence.
					
					```
				formatString: #,0.00
				displayFolder: Visites
				lineageTag: ce4dbc09-5ced-4c01-8426-dfaff45af028

			measure 'Nbre visites effectuées chez l''adhérent' =
					
					VAR TypeCentreConvocation = "Entreprise"                                                        -- Définition du type de centre de convocation recherché
					
					RETURN
					CALCULATE(
					    [Nombre de visites],
					    'RDV/visite - centre convocation'[Type centre de convocation RDV] = TypeCentreConvocation   -- Filtre sur le type de centre spécifié
					)
					
					-- Description : Cette mesure calcule le nombre de visites effectuées chez l'adhérent, où le type de centre de convocation est "Entreprise".
				formatString: #,0
				displayFolder: Visites
				lineageTag: b09ee39a-11f0-48f0-9628-2794b87e3e8f

			measure 'Nombre de visites PDP' =
					
					VAR ProfilConseillerPDP = "Conseiller maintien de la cellule PDP"                       -- Définition du profil recherché
					
					RETURN
					COALESCE(
					    CALCULATE(
					    [Nombre de visites],
					    'RDV/visite - réalisateur'[Profil réalisateur détaillé] = ProfilConseillerPDP       -- Filtre sur le profil spécifié
					),
					""
					)
					
					-- Description : Cette mesure calcule le nombre de visites réalisées par un conseiller de la cellule PDP.
				formatString: #,0
				displayFolder: Visites
				lineageTag: 69d1859d-0e73-41ad-8dbe-74bb7fcee799

			measure 'Ratio Visites (Équipe Médicale)' = ```
					
					VAR VisitesEquipeMedicale =
					    CALCULATE(
					        [Nombre de visites],
					        'Equipe médicale'[Equipe médicale] <> "Non affecté"     -- Ajout d'un filtre explicite pour éviter les équipes non affectées
					    )
					VAR VisitesTotales =
					    CALCULATE(
					        [Nombre de visites],
					        ALL('Equipe médicale'),
					        'Equipe médicale'[Equipe médicale] <> "Non affecté"     -- Calcul des visites totales en ignorant les filtres sur l'équipe médicale
					    )
					    
					RETURN
					    DIVIDE(VisitesEquipeMedicale, VisitesTotales, 0)            -- Calcul du ratio avec gestion des divisions par zéro
					
					-- Description : Cette mesure calcule le ratio des visites effectuées par l'équipe médicale par rapport au total des visites, en excluant les équipes non affectées.
					```
				displayFolder: Visites
				lineageTag: d508f010-977f-466a-892e-022803c03471

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Plutôt que d'afficher le taux de retard, affichons du positif avec le taux de service représentant le % de salariés à jour de visites
			measure 'Taux de service' = ```
					
					VAR TauxRetard = [Taux de retard] // Stocke la valeur de la mesure [Taux de retard]
					VAR TauxService = 1 - TauxRetard // Calcule le taux de service en soustrayant le taux de retard de 1
					
					RETURN
					TauxService
					 //    COALESCE(
					 //     IF(
					   //   ISBLANK(TauxRetard), // Vérifie si la valeur du taux de retard est vide
					     // 1, // Retourne une valeur vide si le taux de retard est vide
					      //IF(
					        //  TauxService = 1, // Vérifie si le taux de service est égal à 1 (100%)
					          //1, // Retourne une valeur vide si le taux de service est égal à 100%
					          //TauxService // Retourne le taux de service calculé
					      //)
					  //),
					  //""
					  //)
					
					/*
					Description :
					Cette mesure calcule le taux de service en soustrayant le taux de retard de 1.
					Elle utilise une variable pour stocker la valeur de [Taux de retard] et une condition IF pour vérifier si la valeur est vide ou si le taux de service est égal à 100%.
					Si le taux de retard est vide ou si le taux de service est égal à 100%, la mesure retourne une valeur vide.
					*/
					
					```
				formatString: 0.0\ %;-0.0\ %;0.0\ %
				displayFolder: Visites
				lineageTag: f7d52d6e-55c7-4bec-a94e-fd2b4491389d

			/// Taux d'annulation non excusée des IDEST sélectionnés
			measure 'Taux Annulation IDEST' =
					
					VAR RoleIDEST = "IDEST"                                             -- Définir la valeur du rôle IDEST dans une variable pour une meilleure lisibilité
					VAR TauxAnnulationNonExcusee =
					    CALCULATE(
					        [Taux annulation non excusée (absentéisme)],
					        'RDV/visite - réalisateur'[Role réalisateur] = RoleIDEST    -- Appliquer le filtre sur le rôle IDEST
					    )
					RETURN
					    TauxAnnulationNonExcusee                                        -- Retourner le taux d'annulation calculé
				formatString: 0.0\ %;-0.0\ %;0.0\ %
				displayFolder: Absentéisme
				lineageTag: 228934f7-8927-4029-a963-58b41f25514e

			/// Taux d'annulation non excusée des Médecins sélectionnés
			measure 'Taux Annulation Médecin' =
					
					VAR RoleMedecin = "Médecin"                                             -- Définir la valeur du rôle Médecin dans une variable pour une meilleure lisibilité
					VAR TauxAnnulationNonExcusee =
					    CALCULATE(
					        [Taux annulation non excusée (absentéisme)],
					        'RDV/visite - réalisateur'[Role réalisateur] = RoleMedecin      -- Appliquer le filtre sur le rôle Médecin
					    )
					RETURN
					    TauxAnnulationNonExcusee                                            -- Retourner le taux d'annulation calculé
				formatString: 0.0\ %;-0.0\ %;0.0\ %
				displayFolder: Absentéisme
				lineageTag: 9daced4c-20ba-43a0-83b0-95812cb4a768

			/// Calcule le taux de présentation aux RDV à partir du taux d'annulation non excusé et excusé.
			measure 'Tx de présence' =
					
					VAR TauxAnnulationNonExcusee = [Taux annulation non excusée (absentéisme)]  -- Stocker le taux d'annulation non excusée dans une variable
					VAR TauxAnnulationExcusee = [Taux annulation excusée (vacation)]            -- Stocker le taux d'annulation  excusée dans une variable
					VAR TauxPresence = 1 - TauxAnnulationNonExcusee  - TauxAnnulationExcusee    -- Calculer le taux de présence
					RETURN
					    TauxPresence                                                            -- Retourner le taux de présence calculé
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Absentéisme
				lineageTag: 8cd0d4a1-5e76-41a8-aaa3-654d77f9019e

			/// Classement des adhérents par taille d'effectif
			measure 'Classement Adherents' = ```
					
					RANKX(
					    ALLSELECTED('Adhérents'),                                   -- Considérer tous les adhérents sélectionnés, en ignorant les filtres de rapport
					    [Effectif suivi - hors intérim],                            -- Classer en fonction de l'effectif suivi (hors intérim)
					    ,                                                           -- Valeur par défaut pour le paramètre de gestion des égalités (ties)
					    DESC                                                        -- Classer en ordre décroissant
					)
					
					-- Description :
					-- Cette mesure classe les adhérents en fonction de l'effectif suivi (hors intérim) en ordre décroissant.
					-- Elle utilise RANKX pour attribuer un rang à chaque adhérent, en ignorant les filtres de rapport grâce à ALLSELECTED.
					
					```
				formatString: 0
				displayFolder: Adhérents
				lineageTag: 6d35a9ae-c550-4082-9841-86793145dfbb

			/// Cette mesure calcule l'évolution de l'effectif suivi non intérimaire entre le début et la fin d'une période.
			measure 'Evolution Effectif' = ```
					
					VAR EffectifFinPeriode = 'Evolution effectif'[Effectif suivi figé non intérimaire fin de période]           -- Effectif à la fin de la période
					VAR EffectifDebutPeriode = 'Evolution effectif'[Effectif suivi figé non intérimaire début de période]       -- Effectif au début de la période
					
					RETURN
					    EffectifFinPeriode - EffectifDebutPeriode                                                               -- Calculer l'évolution de l'effectif
					
					-- Description :
					-- Cette mesure calcule l'évolution de l'effectif suivi non intérimaire entre le début et la fin d'une période.
					-- Elle soustrait l'effectif du début de période de l'effectif de fin de période pour obtenir l'évolution.
					
					```
				formatString: 0
				displayFolder: Adhérents
				lineageTag: 3735905c-ca38-45a0-a530-93caa1cd46e8

			measure 'Adherents Fin Validite APP dans les 6 Mois' = ```
					
					CALCULATE(
					    'Evolution effectif'[# adhérents à jour d'AMT primaire (fin de période)], -- Calculer le nombre d'adhérents
					    'Evolution effectif - date prochaine FE'[Date] <= TODAY() + 183,        -- Filtrer les adhérents dont la validité expire dans les 6 mois
					    'Evolution effectif - date prochaine FE'[Date] > TODAY()                -- Filtrer les adhérents dont la validité n'a pas encore expiré
					)
					
					-- Description :
					-- Cette mesure calcule le nombre d'adhérents dont la validité de l'APP expire dans les 6 mois à partir de la date actuelle.
					-- Elle utilise CALCULATE pour appliquer des filtres sur la date de fin de validité et obtenir le nombre d'adhérents concernés.
					
					```
				formatString: 0
				displayFolder: AMT
				lineageTag: 8b666f48-eab6-44f7-bd20-a9b2000f8dd6

			measure '% AMT Terminées par Type' = ```
					
					VAR TotalAMTTerminees =
					    CALCULATE(
					        COUNTROWS('AMT'),                                                   -- Compter le nombre total d'AMT
					        'AMT'[Statut de l'AMT] = "AMT terminée",                            -- Filtrer les AMT terminées
					        ALL('AMT'[Type])                                                    -- Ignorer le filtre sur le type
					    )
					
					VAR NombreAMTTermineesParType =
					    [Nombre d'AMT terminées]                                                -- Référence à une mesure existante pour le nombre d'AMT terminées par type
					
					RETURN
					    DIVIDE(
					        NombreAMTTermineesParType,                                          -- Numérateur : nombre d'AMT terminées pour le type donné
					        TotalAMTTerminees,                                                  -- Dénominateur : nombre total d'AMT terminées
					        BLANK()                                                             -- Retourner une valeur vide en cas de division par zéro
					    )
					
					-- Description :
					-- Cette mesure calcule le pourcentage d'AMT terminées par type par rapport au total des AMT terminées.
					-- Elle utilise CALCULATE pour déterminer le nombre total d'AMT terminées, en ignorant le filtre sur le type, et DIVIDE pour gérer les divisions par zéro.
					
					```
				formatString: 0.0\ %;-0.0\ %;0.0\ %
				displayFolder: AMT
				lineageTag: 539058dd-910b-4f2e-b80d-eb4ad4db1ecb

			measure '% Entreprises Concernées par AMT' = ```
					
					VAR EntreprisesConcerneesAMT =
					    [# entreprises concernées (AMT)]                                        -- Numérateur : Nombre d'entreprises concernées par une AMT
					
					VAR TotalAdherentsActifsOuSuspendus =
					    [Nombre d'adhérents actifs ou suspendus]                                -- Dénominateur : Nombre total d'adhérents actifs ou suspendus
					
					VAR PourcentageEntreprisesConcerneesAMT =
					    DIVIDE(
					        EntreprisesConcerneesAMT,                                           -- Numérateur
					        TotalAdherentsActifsOuSuspendus,                                    -- Dénominateur
					        BLANK()                                                             -- Retourner une valeur vide si le dénominateur est nul
					    )
					
					RETURN
					    FORMAT(
					        PourcentageEntreprisesConcerneesAMT,
					        "0.00%"                                                             -- Formater le résultat en pourcentage avec deux décimales
					    )
					
					-- Description :
					-- Cette mesure calcule le pourcentage d'entreprises concernées par une AMT par rapport au nombre total d'adhérents actifs ou suspendus.
					-- Elle utilise DIVIDE pour gérer les divisions par zéro et FORMAT pour afficher le résultat en pourcentage.
					
					```
				displayFolder: AMT
				lineageTag: 10f001e8-a092-4ca9-8792-7cafd723b3e3

			measure 'Évolution Nbre AMT 2023->2024' = ```
					
					VAR Valeur2024 =
					    CALCULATE(
					        'AMT'[Nombre d'AMT terminées],          -- Calculer le nombre d'AMT terminées en 2024
					        'Date principale'[Année] = 2024
					    )
					VAR Valeur2023 =
					    CALCULATE(
					        'AMT'[Nombre d'AMT terminées],          -- Calculer le nombre d'AMT terminées en 2023
					        'Date principale'[Année] = 2023
					    )
					RETURN
					    IF(
					        ISBLANK(Valeur2023),
					        BLANK(),                                -- Retourner BLANK si la valeur de 2023 est vide
					        DIVIDE(
					            Valeur2024 - Valeur2023,            -- Calculer la différence entre 2024 et 2023
					            Valeur2023,                         -- Diviser par la valeur de 2023
					            0                                   -- Utiliser 0 comme valeur par défaut pour éviter les erreurs de division par zéro
					        )
					    )
					
					-- Cette mesure calcule l'évolution en pourcentage du nombre d'AMT terminées entre 2023 et 2024.
					-- Elle utilise des variables pour stocker les valeurs des années 2023 et 2024,
					-- et retourne BLANK si la valeur de 2023 est vide pour éviter les erreurs.
					
					```
				formatString: #,0
				displayFolder: AMT
				lineageTag: 5809367d-5ec1-4759-9de0-21c07c76e44b

				annotation PBI_FormatHint = {"isDecimal":true}

			measure 'Moy. AMT (12 mois précédents)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])                            -- Obtenir la date actuelle maximale
					VAR LastMonth = EOMONTH(CurrentDate, -1)                                   -- Dernier jour du mois précédent
					VAR TwelveMonthsAgo = EOMONTH(LastMonth, -12)                              -- Dernier jour du mois il y a 12 mois
					VAR TotalAMTTerminees =
					    CALCULATE(
					        [# AMT terminées],                                                -- Calculer le nombre total d'AMT terminées
					        'Date principale'[Date] > TwelveMonthsAgo,                        -- Filtrer les dates après il y a 12 mois
					        'Date principale'[Date] <= LastMonth                               -- Filtrer les dates jusqu'au dernier jour du mois précédent
					    )
					VAR NombreMois = 12                                                        -- Nombre de mois dans la période
					
					RETURN
					        DIVIDE(TotalAMTTerminees, NombreMois)                                 -- Calculer la moyenne mobile
					
					-- Description :
					-- Cette mesure calcule la moyenne mobile du nombre d'AMT terminées sur les 12 mois précédents.
					-- Elle utilise des variables pour définir les dates et CALCULATE pour filtrer les AMT terminées sur cette période.
					-- DIVIDE est utilisé pour calculer la moyenne en divisant le total par le nombre de mois.
					
					```
				displayFolder: AMT
				lineageTag: 5594cb54-b155-4787-8e12-231a313bb92f

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Ratio AMT Centre' =
					
					CALCULATE(
					    DIVIDE(
					        ('AMT v2'[# AMT terminées]),                                      -- Numérateur : Nombre d'AMT terminées
					        ('Adhérents'[Nombre d'adhérents actifs ou suspendus]),             -- Dénominateur : Nombre d'adhérents actifs ou suspendus
					        BLANK()                                                           -- Retourner une valeur vide en cas de division par zéro
					    ),
					    'Equipe médicale'[Equipe médicale (secteur et médecin référent)] = "Centre" -- Filtrer les adhérents situés dans la zone géographique "Centre"
					)
					
					-- Description :
					-- Cette mesure calcule le ratio des AMT terminées par rapport au nombre d'adhérents actifs ou suspendus, filtré par la zone géographique "Centre".
					-- Elle utilise CALCULATE pour modifier le contexte de filtrage et DIVIDE pour gérer les divisions par zéro.
				formatString: 0.0\ %;-0.0\ %;0.0\ %
				displayFolder: AMT
				lineageTag: 0d16fbfd-1545-4515-b7e7-c9fb0f5be5e5

			measure 'Ratio AMT Grand Nord' = ```
					
					CALCULATE(
