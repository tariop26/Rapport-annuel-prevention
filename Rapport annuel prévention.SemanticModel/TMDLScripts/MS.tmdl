			measure 'Effectif en retard début d''année en-cours' = ```
					
					VAR AnneePrecedente = YEAR(TODAY()) - 1                     -- Obtenir l'année précédente
					VAR DateFinAnneePrecedente = DATE(AnneePrecedente, 12, 31)  -- Déclare une variable pour le 31 décembre de l'année précédente
					VAR CategorieRetard = "En retard"                           -- Déclare une variable pour la catégorie de retard
					
					RETURN
					    CALCULATE(
					        'Evolution retard'[Nombre de salariés suivis],                              -- Mesure à calculer
					        'Evolution retard - catégorie retard'[Catégorie retard] = CategorieRetard,  -- Filtre par catégorie de retard
					        'Date principale'[Date] = DateFinAnneePrecedente                            -- Filtre sur la date de fin de l'année précédente
					    )
					
					-- Cette mesure calcule le nombre de salariés suivis en retard au 31 décembre de l'année précédente donc au 1er janvier de l'année en cours. 
					-- Elle utilise des variables pour stocker la date de fin de l'année précédente et la catégorie de retard, et applique ces filtres avec CALCULATE.
					
					```
				formatString: 0
				displayFolder: Retard
				lineageTag: 55f01bd2-5acd-41f3-b95f-a940140ee624

			measure 'Evol retard depuis début année' = ```
					
					VAR EffectifRetardActuel = [Effectif en retard]                                 -- Effectif en retard actuel
					VAR EffectifRetardDebutAnnee = [Effectif en retard début d'année en-cours]      -- Effectif en retard au début de l'année en cours
					
					RETURN
					    EffectifRetardActuel - EffectifRetardDebutAnnee                             -- Calculer l'évolution du retard depuis le début de l'année
					
					-- Cette mesure calcule l'évolution du nombre de salariés en retard depuis le début de l'année en cours.
					-- Elle utilise des variables pour stocker l'effectif actuel et l'effectif au début de l'année, et calcule la différence entre ces deux valeurs.
					
					```
				formatString: 0
				displayFolder: Retard
				lineageTag: 633dab14-0345-438e-b5e3-a40fffd1acc2

			measure '% variation convocables depuis début année' = ```
					
					VAR EffectifRetardActuel = [Effectif en retard]                             -- Effectif en retard actuel
					VAR EffectifRetardDebutAnnee = [Effectif en retard début d'année en-cours]  -- Effectif en retard au début de l'année en cours
					VAR Evolution =
					    DIVIDE(
					        EffectifRetardActuel - EffectifRetardDebutAnnee,
					        EffectifRetardDebutAnnee,
					        0                                                                   -- Valeur par défaut si le dénominateur est zéro
					    )
					RETURN
					    Evolution
					
					-- Cette mesure calcule l'évolution du nombre de salariés en retard depuis le début de l'année en cours.
					-- Elle utilise des variables pour stocker l'effectif actuel et l'effectif au début de l'année, et calcule le pourcentage d'évolution entre ces deux valeurs.
					
					```
