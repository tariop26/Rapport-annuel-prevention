			measure 'IDEST sélectionnée' = ```
					
					VAR NomUtilisateurSelectionne = SELECTEDVALUE('Utilisateur'[Nom utilisateur])   // Récupère le nom de l'utilisateur sélectionné
					
					RETURN
					    IF(
					        NOT ISBLANK(NomUtilisateurSelectionne),                                 // Vérifie si un utilisateur est sélectionné
					        NomUtilisateurSelectionne,
					        "Ensemble du service"                                                   // Retourne un texte par défaut si aucun utilisateur n'est sélectionné
					    )
					
					/*
					Description :
					Cette mesure détermine l'utilisateur sélectionné dans le rapport Power BI.
					Elle retourne le nom de l'utilisateur si une sélection est faite, sinon elle retourne "Ensemble du service".
					*/
					
					```
				displayFolder: Divers
				lineageTag: 04c0f093-e593-4246-8eb2-2cdcded69470

			measure 'Moy. créneaux ouverts (12 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])                  -- Calcul de la date de la semaine précédente
					VAR LastWeek = CurrentDate - 7                                  -- Calcul de la date 52 semaines avant LastWeek
					VAR FiftyTwoWeeksAgo = LastWeek - 364                           -- Calcul du total des créneaux ouverts sur les 52 dernières semaines
					VAR TotalCreneaux =                                             -- Nombre de semaines sur lesquelles on calcule la moyenne
					    CALCULATE(
					        [Nbre de créneaux ouverts],
					        'Date principale'[Date] > FiftyTwoWeeksAgo,
					        'Date principale'[Date] <= LastWeek
					    )
					
					VAR NombreSemaines = 52                                         -- Retourne la moyenne des créneaux ouverts par semaine
					
					RETURN
					DIVIDE(TotalCreneaux, NombreSemaines)
					
					-- Cette mesure calcule la moyenne des créneaux ouverts sur les 52 dernières semaines,
					-- en utilisant la date maximale de la colonne 'Date principale'[Date] comme point de départ.
					
					```
				displayFolder: Divers
				lineageTag: 26de116a-34ed-486a-a5cf-f49a7aab85f4

			measure 'Nbre de créneaux ouverts' = ```
					
					VAR NombreCreneaux = [Nombre de créneaux]           -- Stocke la valeur de la mesure existante dans une variable
					
					RETURN
					    COALESCE(NombreCreneaux, 0)                     -- Retourne la valeur de NombreCreneaux si elle n'est pas vide, sinon 0
					
					-- Description : Cette mesure calcule le nombre de créneaux ouverts.
					-- Elle utilise la mesure existante [Nombre de créneaux] et retourne 0 si cette mesure est vide grâce à la fonction coalesce. 
					
					```
				formatString: #,0
				displayFolder: Divers
				lineageTag: ab183f2c-50f4-4489-a98b-258dfceaedd8

			measure 'Etiquette effectif suivi' =
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date])                           -- Capture la période affichée sur le graphe
					
					VAR maxi =
					    MAXX(PeriodeVisible, [Effectif suivi figé non intérimaire fin de période])      -- Trouve le maximum sur la période affichée
					
					VAR mini =
					    MINX(PeriodeVisible, [Effectif suivi figé non intérimaire fin de période])      -- Trouve le minimum sur la période affichée
					
					VAR DerniereDate =
					    MAXX(PeriodeVisible, 'Date principale'[Date])                                   -- Trouve la dernière date visible
					
					VAR dernier =
					    CALCULATE(
					        [Effectif suivi figé non intérimaire fin de période],
					        'Date principale'[Date] = DerniereDate
					    )                                                                               -- Récupère les effectifs à la dernière date
					
					RETURN
					    IF(
					        [Effectif suivi figé non intérimaire fin de période] = maxi ||
					        [Effectif suivi figé non intérimaire fin de période] = mini ||
					        [Effectif suivi figé non intérimaire fin de période] = dernier,
					        [Effectif suivi figé non intérimaire fin de période]                        -- Retourne une valeur vide si la condition n'est pas remplie
					    )
					
					-- Description : Cette mesure calcule une étiquette pour l'effectif suivi.
					-- Elle retourne la valeur de l'effectif si celle-ci est égale au maximum, minimum ou à la valeur de la dernière date visible.
				formatString: 0
				displayFolder: Etiquettes
				lineageTag: f2e2c9b1-e9d8-483c-9d99-0f686c1eda43

			measure 'Etiquette min/max tx annulation IDEST' = ```
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Semaine])        -- Capture la période affichée sur le graphe
					
					VAR maxi =
					    MAXX(PeriodeVisible, 'Mesures'[Taux Annulation IDEST])          -- Trouve le maximum sur la période affichée
					
					VAR mini =
					    MINX(PeriodeVisible, 'Mesures'[Taux Annulation IDEST])          -- Trouve le minimum sur la période affichée
					
					VAR DerniereDate =
					    MAXX(PeriodeVisible, 'Date principale'[Semaine])                -- Trouve la dernière date visible
					
					VAR dernier =
					    CALCULATE(
					        'Mesures'[Taux Annulation IDEST],
					        'Date principale'[Semaine] = DerniereDate
					    )                                                                -- Récupère le taux d'annulation à la dernière date
					
					RETURN
					    IF(
					        'Mesures'[Taux Annulation IDEST] = maxi ||
					        'Mesures'[Taux Annulation IDEST] = mini ||
					        'Mesures'[Taux Annulation IDEST] = dernier,
					        IF(
					            'Mesures'[Taux Annulation IDEST] = 0,
					            BLANK(),                                                -- Ne pas afficher si le résultat est 0
					            'Mesures'[Taux Annulation IDEST]
					        ),
					        BLANK()                                                     -- Retourne une valeur vide si la condition n'est pas remplie
					    )
					
					-- Description : Cette mesure calcule une étiquette pour le taux d'annulation IDEST.
					-- Elle retourne la valeur du taux d'annulation si celle-ci est égale au maximum, minimum ou à la valeur de la dernière date visible.
					
					```
				displayFolder: Etiquettes
				lineageTag: 39f7082d-7903-4e3a-80ba-feac45d95de8

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Etiquette min/max/dernier nbre d''adhérents' = ```
					
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date])                               -- Capture la période affichée sur le graphe
					
					VAR maxi =
					    MAXX(PeriodeVisible, 'Evolution effectif'[Nombre d'adhérents fin de période])       -- Trouve le maximum sur la période affichée
					
					VAR mini =
					    MINX(PeriodeVisible, 'Evolution effectif'[Nombre d'adhérents fin de période])       -- Trouve le minimum sur la période affichée
					
					VAR DerniereDate =
					    MAXX(PeriodeVisible, 'Date principale'[Date])                                       -- Trouve la dernière date visible
					
					VAR dernier =
					    CALCULATE(
					        'Evolution effectif'[Nombre d'adhérents fin de période],
					        'Date principale'[Date] = DerniereDate
					    )                                                                                   -- Récupère le nombre d'adhérents à la dernière date
					
					RETURN
					    IF(
					        'Evolution effectif'[Nombre d'adhérents fin de période] = maxi ||
					        'Evolution effectif'[Nombre d'adhérents fin de période] = mini ||
					        'Evolution effectif'[Nombre d'adhérents fin de période] = dernier,
					        'Evolution effectif'[Nombre d'adhérents fin de période],
					        BLANK()                                                                         -- Retourne une valeur vide si la condition n'est pas remplie
					    )
					
					-- Description : Cette mesure calcule une étiquette pour le nombre d'adhérents.
					-- Elle retourne la valeur du nombre d'adhérents si celle-ci est égale au maximum, minimum ou à la valeur de la dernière date visible.
					
					```
				formatString: 0
				displayFolder: Etiquettes
				lineageTag: cf472743-71e9-4ff5-bfc1-74f95bf5cfb5

			measure '% mesure Audiométrie par rapport à total examens complémentaires' = ```
					
					VAR ExamensAudiometrie =
					    CALCULATE(
					        [# examens],
					        'Examen complémentaire - type examen'[Type examen (groupes)] = "Audiométrie"    -- Filtre pour inclure uniquement les examens d'audiométrie
					    )
					VAR TotalExamens = [# examens]                                                          -- Nombre total d'examens
					
					RETURN
					    DIVIDE(
					        ExamensAudiometrie,
					        TotalExamens,
					        0                                                                               -- Valeur par défaut si le dénominateur est zéro
					    )
					
					-- Description : Cette mesure calcule le pourcentage d'examens d'audiométrie par rapport au total des examens complémentaires.
					-- Elle utilise la mesure [# examens] et applique un filtre sur le type d'examen pour inclure uniquement les examens d'audiométrie.
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: IDEST\Examens complémentaires
				lineageTag: 7b0eb622-7c45-41e0-bef0-0ea90286859c

			measure '% mesure IMC par rapport à total examens complémentaires' = ```
					
					VAR ExamensIMC =
					    CALCULATE(
					        [# examens],
					        'Examen complémentaire - type examen'[Type examen (groupes)] = "IMC"        -- Filtre pour inclure uniquement les examens d'IMC
					    )
					VAR TotalExamens = [# examens]                                                      -- Nombre total d'examens
					
					RETURN
					    DIVIDE(
					        ExamensIMC,
					        TotalExamens,
					        0                                                                           -- Valeur par défaut si le dénominateur est zéro
					    )
					
					-- Description : Cette mesure calcule le pourcentage d'examens d'IMC par rapport au total des examens complémentaires.
					-- Elle utilise la mesure [# examens] et applique un filtre sur le type d'examen pour inclure uniquement les examens d'IMC.
					
