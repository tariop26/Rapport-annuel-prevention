			measure '% inaptitude / Nbre salariés suivis' = ```
					
					VAR NombreInaptitude = [Nombre d'avis d'inaptitude] // Récupère le nombre d'avis d'inaptitude
					VAR EffectifSuivi = [Effectif suivi figé non intérimaire fin de période] // Récupère l'effectif suivi non intérimaire à la fin de la période
					
					RETURN
					DIVIDE(
					    NombreInaptitude, // Numérateur : Nombre de personnes en inaptitude
					    EffectifSuivi, // Dénominateur : Effectif suivi non intérimaire
					    0 // Valeur de retour en cas de division par zéro
					)
					/*
					Description : Cette mesure calcule le pourcentage de personnes en inaptitude par rapport à l'effectif suivi non intérimaire à la fin de la période.
					Elle utilise la fonction DIVIDE pour éviter les erreurs de division par zéro.
					Les variables NombreInaptitude et EffectifSuivi sont utilisées pour clarifier le calcul et améliorer la lisibilité.
					*/
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Visites
				lineageTag: a0fe7f99-b052-457f-a20a-a33beb2b8cf7

			measure '% inaptitude / Nbre visites réalisées' = ```
					
					VAR NombreInaptitude = [Nombre d'avis d'inaptitude] // Récupère le nombre d'avis d'inaptitude émis
					VAR NombreVisitesRealisees = [Nombre de visites réalisées (RDV)] // Récupère le nombre de visites réalisées
					
					RETURN
					DIVIDE(
					    NombreInaptitude, // Numérateur : Nombre de visites concernées par une inaptitude
					    NombreVisitesRealisees, // Dénominateur : Nombre de visites réalisées
					    0 // Valeur de retour en cas de division par zéro
					)
					/*
					Description : Cette mesure calcule le pourcentage de visites concernées par une inaptitude par rapport au nombre de visites réalisées.
					Elle utilise la fonction DIVIDE pour éviter les erreurs de division par zéro.
					Les variables NombreInaptitude et NombreVisitesRealisees sont utilisées pour clarifier le calcul et améliorer la lisibilité.
					*/
					
					```
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Visites
