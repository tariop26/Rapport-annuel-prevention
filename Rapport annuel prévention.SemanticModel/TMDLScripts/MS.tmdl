			measure '% Annulation pour Absence Professionnel de Santé' =
					
					VAR AnnulationsAbsenceProfessionnel = [Nombre Annulation pour Absence Professionnel de Santé]                  -- Nombre d'annulations pour absence du professionnel de santé
					VAR TotalRDV = [Nombre de RDV]                                                                                 -- Nombre total de rendez-vous
					
					RETURN
					DIVIDE(AnnulationsAbsenceProfessionnel, TotalRDV, 0)
					
					-- Description :
					-- Cette mesure calcule le pourcentage d'annulations par le service dues à l'absence du professionnel de santé par rapport au nombre total de rendez-vous.
					-- Elle utilise la fonction DIVIDE pour éviter les erreurs de division par zéro.
				formatString: 0.00\ %;-0.00\ %;0.00\ %
				displayFolder: Annulation
				lineageTag: 1e8eb4d4-2f4b-43f6-ad1f-94df5cc31221

			measure 'Nombre Annulation pour Absence Professionnel de Santé' = ```
					
					VAR Motif = "Absence du professionnel de santé"     -- Définir le motif d'annulation pour absence du professionnel de santé
					
					RETURN
					CALCULATE(
					    [Nombre de RDV annulés],
					    'RDV - motif annulation'[Motif annulation détaillé] = Motif
					)
					
					-- Description :
					-- Cette mesure calcule le nombre de rendez-vous annulés par le service en raison de l'absence du professionnel de santé.
					-- Elle utilise la fonction CALCULATE pour appliquer un filtre sur le motif d'annulation détaillé.
					
					```
