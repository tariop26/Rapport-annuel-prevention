			measure 'Moyenne Entretiens PDP par Salarié (12 mois)' = ```
					
					VAR TotalEntretiens = [Nbre d'entretiens PDP (12 mois)]    -- Total des entretiens PDP sur 12 mois
					VAR TotalSalaries = [nb salariés concernés (12 mois)]       -- Total des salariés concernés sur 12 mois
					
					RETURN
					    DIVIDE(TotalEntretiens, TotalSalaries)                  -- Calculer la moyenne en utilisant DIVIDE pour éviter les erreurs de division par zéro
					
					-- Cette mesure calcule la moyenne du nombre d'entretiens PDP par salarié sur une période de 12 mois.
					-- Elle utilise des variables pour stocker les totaux des entretiens et des salariés, et utilise DIVIDE pour gérer les divisions par zéro.
					
					```
				displayFolder: Consultations Spécialisées\PDP
				lineageTag: 931cff1e-b92d-434d-a6d4-b32cc224c031

			measure 'nb salariés concernés (12 mois)' = ```
					
					    CALCULATE(
					        [Nombre de salariés vus],                                                   -- Mesure à évaluer
					        'Date principale'[Filtre Période 12 mois ajustés]                           -- Appliquer le filtre de période sur 12 mois
					    )
					
					-- Cette mesure calcule le nombre de salariés vus sur une période de 12 mois ajustée, en appliquant un filtre sur la table 'Date principale'.
					```
				formatString: 0
				displayFolder: Consultations Spécialisées
				lineageTag: 1caff73d-91a7-41f8-8c8e-1515eef83650

			measure 'Nbre RDV PDP' = ```
					
					VAR NombreVisitesPDP = [Nombre de visites PDP]      -- Utiliser la mesure existante pour compter les RDV
					
					RETURN
					    COALESCE(NombreVisitesPDP, BLANK())             -- Retourner BLANK si aucune visite PDP n'est enregistrée
					
					-- Cette mesure calcule le nombre de rendez-vous PDP en utilisant une mesure existante.
					-- Elle utilise COALESCE pour retourner BLANK si aucune visite n'est enregistrée pour la date donnée.
					
					```
				formatString: #,0
				displayFolder: Consultations Spécialisées\PDP
				lineageTag: eb492f93-fd9a-4966-911e-1ac9a4dbe0e0

			/// Nbre RDV QVCT = 
			/// VAR NombreVisitesQVCT = [Nbre d'entretiens QVCT]      -- Utiliser la mesure existante pour compter les entretiens QVCT
			/// 
			/// RETURN
			///     COALESCE(NombreVisitesQVCT, BLANK())             -- Retourner BLANK si aucune visite QVCT n'est enregistrée
			/// 
			/// -- Cette mesure calcule le nombre de rendez-vous QVCT en utilisant une mesure existante.
			/// -- Elle utilise COALESCE pour retourner BLANK si aucune visite n'est enregistrée pour la date donnée.
			/// 
			/// 
			measure 'Nbre RDV QVCT' = ```
					
					VAR NombreVisitesQVCT = [Nbre d'entretiens QVCT]      -- Utiliser la mesure existante pour compter les entretiens QVCT
					
					RETURN
					    COALESCE(NombreVisitesQVCT, BLANK())             -- Retourner BLANK si aucune visite QVCT n'est enregistrée
					
					-- Cette mesure calcule le nombre de rendez-vous QVCT en utilisant une mesure existante.
					-- Elle utilise COALESCE pour retourner BLANK si aucune visite n'est enregistrée pour la date donnée.
					
					```
				formatString: #,0
				displayFolder: Consultations Spécialisées\QVCT
				lineageTag: ad9a3c05-d415-438a-acfa-e1cf8816299c

			measure 'Etiquette dernier moy. QVCT' = ```
					
					-- Capture la période visible sur le graphe
					VAR PeriodeVisible = ALLSELECTED('Date principale'[Date])
					
					-- Trouve la dernière date visible
					VAR DerniereDate =
					    MAXX(PeriodeVisible, 'Date principale'[Date])
					
					-- Calcule la valeur de l'effectif à la dernière date visible
					VAR Dernier =
					    CALCULATE(
					        [Nombre Moyen Entretiens QVCT par Mois],
					        'Date principale'[Date] = DerniereDate
					    )
					
					-- Retourne la valeur calculée uniquement si la date est la dernière date visible
					RETURN
					    IF(
					        MAX('Date principale'[Date]) = DerniereDate,
					        Dernier,
					        BLANK()
					    )
					
					```
				displayFolder: Etiquettes
				lineageTag: da659070-b577-4485-8c8c-79a29dc22f50

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'titre Nbre de visites / ETP réalisées le mois dernier' = ```
					
					VAR DateMoisPrecedent = EDATE(TODAY(), -1)              -- Calculer la date du mois précédent
					
					RETURN
					    "Nombre de visites / ETP réalisées en " &
					    FORMAT(DateMoisPrecedent, "Mmmm yyyy", "fr-FR")     -- Formater la date en français
					
					-- Cette mesure génère un titre dynamique indiquant le nombre de visites ou ETP réalisées le mois précédent.
					-- Elle utilise EDATE pour obtenir la date du mois précédent et FORMAT pour afficher cette date en français.
					
					```
				displayFolder: Titres
				lineageTag: d523168a-d017-4bd3-bd24-8eca047ad832

			measure 'Moy. hebdo annulation par le service (6 mois)' = ```
					
					VAR CurrentDate = MAX('Date principale'[Date])
					VAR LastWeek = CurrentDate - 7
					VAR TwentySixWeeksAgo = LastWeek - 182
					VAR TotalVisites =
					    CALCULATE(
					        SUM('RDV'[nb_rdv_annule]),
					        'Date principale'[Date] > TwentySixWeeksAgo,
					        'Date principale'[Date] <= LastWeek,
					        'RDV - Motif annulation'[Motif annulation] = "Annulation par le service"
					    )
					VAR NombreSemaines = 26
					
					RETURN
					DIVIDE(TotalVisites, NombreSemaines)
					
					-- Cette mesure calcule la moyenne hebdomadaire des annulations de rendez-vous par le service sur les 6 derniers mois.
					
					```
				displayFolder: Annulation
				lineageTag: 9f93cf70-d4d9-41ee-b342-4d05495f1df4

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Effectif en retard M-1' = ```
					
					VAR CategorieRetard = "En retard"                   -- Définir la catégorie de retard dans une variable pour améliorer la lisibilité
