		measure FE_DerniereValeur =
				
				VAR d0 = [DerniereDateReelle]
				RETURN
				    CALCULATE (
				        [% adhérents à jour de FE (fin de période)],
				        TREATAS ( ROW ( "Date", d0 ), 'Date principale'[Date] )
				    )
			formatString: 0.00\ %;-0.00\ %;0.00\ %
			displayFolder: FE\Simulation
			lineageTag: ac21a2fa-1300-46c0-abeb-e5b9290577cf

			changedProperty = DisplayFolder

			changedProperty = Name

			changedProperty = FormatString


		measure 'Filtres actifs' = ```
				
				VAR SelDate = [Période (Du au)]
				VAR SelTaille =
				    IF(
				        ISFILTERED('Adhérent (actuel)'[Taille d'entreprise]),
				        VAR s = CONCATENATEX(VALUES('Adhérent (actuel)'[Taille d'entreprise]), 'Adhérent (actuel)'[Taille d'entreprise], ", ")
				        RETURN IF(LEN(s)=0, "Aucun", s),
				        "Tous"
				    )
				VAR SelType =
				    IF(
				        ISFILTERED('Adhérent (actuel)'[Type d'entreprise :]),
				        VAR s = CONCATENATEX(VALUES('Adhérent (actuel)'[Type d'entreprise :]), 'Adhérent (actuel)'[Type d'entreprise :], ", ")
				        RETURN IF(LEN(s)=0, "Aucun", s),
				        "Tous"
				    )
				RETURN
				    "Dates : " & SelDate & " | Taille d'entreprise : " & SelTaille & " | Type d'entreprise : " & SelType
				
				```
			lineageTag: 6e73330b-5d2e-4251-95a5-c9a90c9a66c9

			changedProperty = Name

