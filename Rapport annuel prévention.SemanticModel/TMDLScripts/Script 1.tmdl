		measure 'Visites Evol vs last year' = ```
				
				VAR Visites_Period = [Visites Période]  // Mesure de la période courante; utilisée comme numérateur de la variation 
				VAR Visites_LastYear = [Visites SameLastYear]  // Mesure de la période N-1; dénominateur et référence de comparaison 
				VAR Evolution_Proportion =  // Variation relative propre, gère les divisions par zéro via DIVIDE 
				    DIVIDE( Visites_Period - Visites_LastYear, Visites_LastYear, 0 )
				VAR Signe_Affichage =  // Préfixe du signe basé sur 0 car la variation est une proportion (positif/négatif) 
				    IF( Evolution_Proportion >= 0, "+ ", "- " )
				VAR Valeur_Pourcent_Formattee =  // Mise en forme en pourcentage avec une décimale, appliquée sur la valeur absolue pour éviter un double signe 
				    FORMAT( ABS(Evolution_Proportion), "0.00 %" )
				RETURN
				    "("&Signe_Affichage & Valeur_Pourcent_Formattee&")"  // Sortie texte: utile pour cartes/étiquettes; préférer garder une version numérique pour analyses 
				
				/*
				Rôle de la mesure:
				- Produit un affichage texte de l’évolution des visites vs N-1 avec signe explicite, ex: "+ 12,3%" ou "- 4,5%".
				- Le calcul de variation utilise DIVIDE pour la robustesse et sépare calcul (proportion) et présentation (signe/format).
				- Pour analyses et agrégations, utiliser en priorité une version numérique: Visites Evol vs last year (num), avec un format dynamique “+0.0%;-0.0%;0.0%”.
				*/ 
				
				```
			displayFolder: Visites
			lineageTag: d6b51abc-1297-40c0-9320-bb9c0fd31f4c

			changedProperty = DisplayFolder

			changedProperty = Name

		measure 'Visites Evol vs last year (num)' = ```
				
				VAR Visites_Period = [Visites Période]  // Calcule le total de la période courante via la mesure existante [web:27]
				VAR Visites_LastYear = [Visites SameLastYear]  // Calcule la valeur de la même période à N-1 via la mesure existante [web:27]
				VAR Evol_Proportion =  // Variation relative en proportion, robuste aux divisions par zéro [web:21]
				    DIVIDE( Visites_Period - Visites_LastYear, Visites_LastYear, 0 )
				RETURN
				    Evol_Proportion  // Mesure purement numérique, à formater en % au niveau du modèle [web:22][web:34]
				
				// Rôle: calcule l’évolution relative des visites vs N-1 en proportion (ex: 0,12 = +12%), réutilisable dans tout visuel [web:27][web:22].
				
				```
			formatString: 0.00\ %;-0.00\ %;0.00\ %
			displayFolder: Visites
			lineageTag: 9ba20418-093e-40ea-b15a-ed6564241f1a

			changedProperty = DisplayFolder

			changedProperty = Name

			changedProperty = FormatString

		measure 'Visites IDEST' = EXTERNALMEASURE("Visites IDEST", DOUBLE, "DirectQuery à AS – Rapport mensuel EPD")
			formatString: #,0
