				    DIVIDE( Visites_Period - Visites_LastYear, Visites_LastYear, 0 )
				VAR Signe_Affichage =  // Préfixe du signe basé sur 0 car la variation est une proportion (positif/négatif) 
				    IF( Evolution_Proportion >= 0, "+ ", "- " )
				VAR Valeur_Pourcent_Formattee =  // Mise en forme en pourcentage avec une décimale, appliquée sur la valeur absolue pour éviter un double signe 
				    FORMAT( ABS(Evolution_Proportion), "0.00 %" )
				RETURN
				    "("&Signe_Affichage & Valeur_Pourcent_Formattee&")"  // Sortie texte: utile pour cartes/étiquettes; préférer garder une version numérique pour analyses 
				
				/*
				Rôle de la mesure:
				- Produit un affichage texte de l’évolution des visites vs N-1 avec signe explicite, ex: "+ 12,3%" ou "- 4,5%".
				- Le calcul de variation utilise DIVIDE pour la robustesse et sépare calcul (proportion) et présentation (signe/format).
