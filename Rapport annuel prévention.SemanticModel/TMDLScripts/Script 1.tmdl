		measure '% nouveaux adhérents sans FE' =
				
				var Aujourdhui = Max('Date principale'[Date])
				var NouveauxAdherents = CALCULATE(
				                            DISTINCTCOUNT('Adhérent (actuel)'[Matricule entreprise]),
				                            'Adhérent (actuel)'[Date création dossier entreprise] - Aujourdhui < 365
				)
				var NouveauxSansFE = CALCULATE(
				                            NouveauxAdherents,
				                            'Adhérent (actuel)'[Statut FE] = "Aucune FE renseignée"
				)
				
				RETURN
				divide(
				    NouveauxSansFE,
				    NouveauxAdherents,
				    0
				)
			formatString: 0.00\ %;-0.00\ %;0.00\ %
			displayFolder: FE
			lineageTag: 579d601f-c3d4-49e6-adca-f9db26c2916d

			changedProperty = DisplayFolder

			changedProperty = Name

			changedProperty = FormatString

