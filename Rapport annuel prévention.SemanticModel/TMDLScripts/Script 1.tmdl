		measure 'Date Fin Arrêté' =
				
				VAR Selection = SELECTEDVALUE('Choisir Période'[ID], 2) // Par défaut : dernier mois
				VAR DateAuj = TODAY()
				VAR AnneePrecedente = DATE(YEAR(DateAuj)-1, 12, 31)
				VAR FinDernierMois = EOMONTH(DateAuj, -1) // Fin du mois précédent
				
				RETURN
				SWITCH(
				    Selection,
				    1, AnneePrecedente,
				    2, FinDernierMois,
				    FinDernierMois // Valeur par défaut de sécurité
				)
			formatString: General Date
			displayFolder: Date
			lineageTag: b53a23a3-7b77-4014-b664-2e61b796c2c0

			changedProperty = DisplayFolder

			changedProperty = Name

		/// Affiche le premier puis le dernier jour de la période de données sélectionnée
