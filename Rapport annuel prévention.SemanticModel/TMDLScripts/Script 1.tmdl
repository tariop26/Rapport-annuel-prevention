		measure 'Visites intérimaires' =
				
				VAR DerniereDateContexte = MAX('Date principale'[Date])                                         // dernière date visible dans le contexte actuel, plus performant que LASTDATE pour un scalaire
				VAR Fenetre12M = DATESINPERIOD('Date principale'[Date], DerniereDateContexte, -12, MONTH)       // construit la plage de dates des 12 mois glissants incluant la date max
				
				RETURN
				COALESCE(
				    CALCULATE(
				    'RDV'[Nombre de visites réalisées (RDV)],                                                   // mesure de base agrégée à évaluer
				    KEEPFILTERS('Adhérent (actuel)'[Type entreprise] = "Intérim"),                              // restreint aux entreprises d’intérim sans écraser d’autres filtres plus spécifiques
				    Fenetre12M),                                                                                // applique la fenêtre temporelle jour par jour sur la table de date
				    0
				)
				
				//Description: Calcule le total des visites réalisées pour les entreprises d’intérim sur les 12 derniers mois glissants jusqu’à la dernière date visible dans le contexte, en s’appuyant sur DATESINPERIOD pour une fenêtre temporelle robuste et performante.
			formatString: #,0
			displayFolder: Visites
			lineageTag: 0bff3b19-640d-44ed-a654-7ee80ea1cb4e

			changedProperty = DisplayFolder

			changedProperty = Name

			changedProperty = FormatString

