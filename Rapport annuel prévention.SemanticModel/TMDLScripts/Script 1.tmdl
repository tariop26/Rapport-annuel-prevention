		measure 'Nombre de fins de contrat PST YTD' = ```
				
				VAR DateMaxDansContexte =                                     -- Dernière date visible dans le contexte courant (borne supérieure) 
				    MAX ( 'Date principale'[Date] )                           -- Utilise la dimension temps pour caler le "to-date" 
				RETURN
				CALCULATE (                                                   -- Recalcule en appliquant un filtre temps YTD + relation inactive 
				    DISTINCTCOUNT ( '1 - salariés PST'[matricule] ),              -- Comptage distinct des salariés concernés 
				    DATESYTD ( 'Date principale'[Date], "31/12" ),          -- Fenêtre Year-To-Date basée sur le calendrier fiscal (31/12 par défaut) 
				    KEEPFILTERS ( 'Date principale'[Date] <= DateMaxDansContexte ), -- Sécurise la borne supérieure au max visible (to-date)
				    USERELATIONSHIP ( '1 - salariés PST'[Fin de contrat], 'Date principale'[Date] ) -- Active la relation inactive sur Fin contrat le temps du calcul
				)
				-- Description : Compte les salariés PST distincts dont la Fin contrat tombe dans la fenêtre Year-To-Date (selon 'Date principale') jusqu'à la dernière date visible, en activant la relation inactive sur 'Fin contrat' pour que le filtre calendrier s'applique correctement.
				
				```
			formatString: 0
			lineageTag: c9bdfc50-1a6d-40dd-bebe-6c1283c4cf40

