		measure 'Visites / effectif Evol vs last year' = ```
				
				VAR Visites_Period = [Nbre Visites / Effectif suivi]  // Mesure de la période courante; utilisée comme numérateur de la variation 
				VAR Visites_LastYear = [Visites / effectif SameLastYear]  // Mesure de la période N-1; dénominateur et référence de comparaison 
				VAR Evolution_Proportion =  // Variation relative propre, gère les divisions par zéro via DIVIDE 
				    DIVIDE( Visites_Period - Visites_LastYear, Visites_LastYear, 0 )
				VAR Signe_Affichage =  // Préfixe du signe basé sur 0 car la variation est une proportion (positif/négatif) 
				    IF( Evolution_Proportion >= 0, "+ ", "- " )
				VAR Valeur_Pourcent_Formattee =  // Mise en forme en pourcentage avec une décimale, appliquée sur la valeur absolue pour éviter un double signe 
				    FORMAT( ABS(Evolution_Proportion), "0.00 %" )
				RETURN
				    "("&Signe_Affichage & Valeur_Pourcent_Formattee&")"  // Sortie texte: utile pour cartes/étiquettes; préférer garder une version numérique pour analyses 
				
				/*
				Rôle de la mesure:
				- Produit un affichage texte de l’évolution des visites vs N-1 avec signe explicite, ex: "+ 12,3%" ou "- 4,5%".
				- Le calcul de variation utilise DIVIDE pour la robustesse et sépare calcul (proportion) et présentation (signe/format).
				- Pour analyses et agrégations, utiliser en priorité une version numérique: Visites Evol vs last year (num), avec un format dynamique “+0.0%;-0.0%;0.0%”.
				*/ 
				
				```
			displayFolder: Visites
			lineageTag: d207e0a6-d86c-4ee1-8366-ce7a08aa5556

			changedProperty = DisplayFolder

			changedProperty = Name

		measure 'Visites / effectif SameLastYear' = ```
				
				VAR ContexteDatesActuel = VALUES('Date principale'[Date]) // Garantit que l’on décale exactement le set de dates du visuel sans altérer d’autres filtres
				
				RETURN
				CALCULATE(
				[Nbre Visites / Effectif suivi],                            // Utilise la mesure source telle quelle
				DATEADD(ContexteDatesActuel, -1, YEAR)      // Décale la période d’un an en arrière, équivalent à SAMEPERIODLASTYEAR mais explicite et flexible
				) 
				
				// Rôle: calcule les RDV pour la même période de l’année précédente, en respectant le grain (jour/mois/trimestre) et les filtres actifs de la table de dates, sans supprimer ces filtres
				```
			formatString: 0.00\ %;-0.00\ %;0.00\ %
			displayFolder: Visites
			lineageTag: 60a9ae26-8220-4c70-8e49-9a36f4b6ae8f

			changedProperty = DisplayFolder

			changedProperty = Name

			changedProperty = FormatString

