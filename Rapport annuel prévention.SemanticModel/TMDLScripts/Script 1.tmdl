		measure 'Effectif Dynamique' = ```
				
				VAR ChoixSelectionne = SELECTEDVALUE('Choix Date'[Choix]) 
				
				VAR DateCible = 
				    SWITCH(
				        ChoixSelectionne,
				        "Date du jour", TODAY(),
				        "31/12 de l'année précédente", DATE(year(TODAY()) - 1, 12, 31),
				        BLANK()
				    )
				
				RETURN
				    CALCULATE(
				        [Evolution Effectif - effectif suivi], -- Votre mesure d'effectif existante (ex: COUNTROWS('Table Employes'))
				        FILTER(
				            ALL('Date principale'), -- Ignore tous les filtres de date existants
				            'Date principale'[Date] = DateCible -- Applique le filtre à la date cible
				        )
				    )
				```
			formatString: 0
			displayFolder: Date
			lineageTag: 762026e8-c80a-4d51-b8dc-260702f9e2ab

			changedProperty = DisplayFolder

			changedProperty = Name

