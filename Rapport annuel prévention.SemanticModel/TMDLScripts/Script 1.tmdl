		measure 'Taux de service' = EXTERNALMEASURE("Taux de service", DOUBLE, "DirectQuery à AS – Rapport mensuel EPD")
			formatString: 0.0\ %;-0.0\ %;0.0\ %
			displayFolder: Taux de service
			lineageTag: d55c1b91-ef48-4ab5-884b-0a21f4475061
