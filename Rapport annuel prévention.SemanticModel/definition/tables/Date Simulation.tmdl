	partition 'Date Simulation' = calculated
		mode: import
		source = ```
				
				VAR DateDebut = DATE(2023, 12, 31) 
				VAR DateFin = DATE(2029, 12, 31)
				
				RETURN
				ADDCOLUMNS(
				    CALENDAR(DateDebut, DateFin),
				    "Année", YEAR([Date]),
				    "Mois Num", MONTH([Date]),
				    "Mois Nom", FORMAT([Date], "mmmm"),
				    "Mois Court", FORMAT([Date], "mmm"),
				    "Trimestre", "T" & QUARTER([Date]),
				    "Année-Mois", FORMAT([Date], "yyyy-MM"), 
				    "Mois Année", FORMAT([Date], "mmm yyyy"), 
				    "Jour Semaine", WEEKDAY([Date], 2), -- La virgule doit être ici, AVANT le commentaire
				    "Tri Mois année", FORMAT([Date], "yyyyMM") -- Format YYYYMM (ex: 202401) pour un tri sans erreur
				)
				```

	annotation PBI_Id = fd7143ab719f43949e1f23a04a8fb81f

