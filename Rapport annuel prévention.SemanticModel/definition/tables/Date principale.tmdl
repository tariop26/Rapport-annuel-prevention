	column EstJourOuvré = ```
			
			VAR Jour = WEEKDAY('Date principale'[Date], 2) // Lundi=1, Dimanche=7
			VAR Mois = MONTH('Date principale'[Date])
			VAR JourDuMois = DAY('Date principale'[Date])
			VAR Annee = YEAR('Date principale'[Date])
			
			// --- Calcul de la date de Pâques (algorithme de Gauss) ---
			VAR a = MOD(Annee, 19)
			VAR b = QUOTIENT(Annee, 100)
			VAR c = MOD(Annee, 100)
			VAR d = QUOTIENT(b, 4)
			VAR e = MOD(b, 4)
			VAR f = QUOTIENT(b + 8, 25)
			VAR g = QUOTIENT(b - f + 1, 3)
			VAR h = MOD(19 * a + b - d - g + 15, 30)
			VAR i = QUOTIENT(c, 4)
			VAR k = MOD(c, 4)
			VAR l = MOD(32 + 2 * e + 2 * i - h - k, 7)
			VAR m = QUOTIENT(a + 11 * h + 22 * l, 451)
			VAR MoisPaques = QUOTIENT(h + l - 7 * m + 114, 31)
			VAR JourPaques = MOD(h + l - 7 * m + 114, 31) + 1
			VAR DatePaques = DATE(Annee, MoisPaques, JourPaques)
			
			// --- Jours fériés fixes ---
			VAR EstFerieFixe =
			    (Mois = 1 && JourDuMois = 1)      || // 1er janvier
			    (Mois = 5 && JourDuMois = 1)      || // 1er mai
			    (Mois = 5 && JourDuMois = 8)      || // 8 mai
			    (Mois = 7 && JourDuMois = 14)     || // 14 juillet
			    (Mois = 8 && JourDuMois = 15)     || // Assomption
			    (Mois = 11 && JourDuMois = 1)     || // Toussaint
			    (Mois = 11 && JourDuMois = 11)    || // Armistice
			    (Mois = 12 && JourDuMois = 25)       // Noël
			
			// --- Jours fériés mobiles (liés à Pâques) ---
			VAR EstFerieMobile =
			    'Date principale'[Date] = DatePaques + 1   || // Lundi de Pâques
			    'Date principale'[Date] = DatePaques + 39  || // Ascension
			    'Date principale'[Date] = DatePaques + 50     // Lundi de Pentecôte
			
			VAR EstWeekend = Jour IN {6, 7}
			RETURN
			IF(EstWeekend || EstFerieFixe || EstFerieMobile, FALSE, TRUE)
			
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 439e9a8d-a08c-46be-b563-25693a7ef78e
		summarizeBy: none

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

