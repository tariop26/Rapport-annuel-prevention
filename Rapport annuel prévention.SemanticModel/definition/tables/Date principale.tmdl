	column 'Filtre Période 12 mois ajustés' = ```
			
			VAR today = TODAY()
			VAR DateFin = EOMONTH(today, 0) -- Dernier jour du mois actuel
			VAR DateDebut = DATE(YEAR(DateFin), MONTH(DateFin) - 12, 1) -- Premier jour du mois, 12 mois en arrière
			RETURN
			IF(
			    'Date principale'[Date] >= DateDebut &&
			    'Date principale'[Date] <= DateFin,
			    TRUE(),
			    FALSE()
			)
			
			
			-- Description :
			-- Cette colonne vérifie si une date donnée se situe dans les 12 derniers mois complets par rapport à la date maximale de la colonne 'Date principale'.
			-- Elle retourne TRUE si la date est dans cette période, sinon FALSE.
			-- Permet d'inclure les données du mois entier M-12 
			
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 264b0c5b-06b2-47e6-9511-b536208f789a
		summarizeBy: none

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Filtre Période 6 mois ajustés' = ```
			
			VAR today = TODAY()
			VAR DateFin = EOMONTH(today, 0) -- Dernier jour du mois actuel
			VAR DateDebut = DATE(YEAR(DateFin), MONTH(DateFin) - 6, 1) -- Premier jour du mois, 6 mois en arrière
			RETURN
			IF(
			    'Date principale'[Date] >= DateDebut &&
			    'Date principale'[Date] <= DateFin,
			    TRUE(),
			    FALSE()
			)
			
			
			-- Description :
			-- Cette colonne vérifie si une date donnée se situe dans les 6 derniers mois complets par rapport à la date maximale de la colonne 'Date principale'.
			-- Elle retourne TRUE si la date est dans cette période, sinon FALSE.
			-- Permet d'inclure les données du mois entier M-6. 
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: d265e495-8fd9-485d-a7f1-a82c5c1c895d
		summarizeBy: none

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Indicateur M-1' = ```
			
			VAR AujourdHui = TODAY()
			VAR PremierJourMoisActuel = DATE(YEAR(AujourdHui), MONTH(AujourdHui), 1)
			VAR PremierJourMoisPrecedent = DATE(YEAR(PremierJourMoisActuel), MONTH(PremierJourMoisActuel) - 1, 1)
			VAR DernierJourMoisPrecedent = EOMONTH(PremierJourMoisPrecedent, 0)
			
			RETURN
			    IF(
			        'Date principale'[Date] >= PremierJourMoisPrecedent && 'Date principale'[Date] <= DernierJourMoisPrecedent,
			        "Mois Précédent",
			        "Autre"
			    )
			
			    -- Ajout d'une colonne qui indique si la date fait partie du Mois précédent ou non. 
			
			```
		lineageTag: 73763a6a-451d-422f-9b09-41aed7935822
		summarizeBy: none

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Indicateur M-2' = ```
			
			VAR AujourdHui = TODAY()
			VAR PremierJourMoisActuel = DATE(YEAR(AujourdHui), MONTH(AujourdHui), 1)
			VAR PremierJourMoisNmoins2 = DATE(YEAR(PremierJourMoisActuel), MONTH(PremierJourMoisActuel) - 2, 1)
			VAR DernierJourMoisNmoins2 = EOMONTH(PremierJourMoisNmoins2, 0)
			
			RETURN
			    IF(
			        'Date principale'[Date] >= PremierJourMoisNmoins2 && 'Date principale'[Date] <= DernierJourMoisNmoins2,
