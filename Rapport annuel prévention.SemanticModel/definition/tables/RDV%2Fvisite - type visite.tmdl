	column 'Type visite groupées' =
			SWITCH(
				TRUE,
				ISBLANK('RDV/visite - type visite'[Type visite détaillé]),
				"(Vide)",
				'RDV/visite - type visite'[Type visite détaillé] IN {"Demande de l'employeur",
					"Demande de l'IDEST",
					"Demande du salarié"},
				"A la demande (autres)",
				'RDV/visite - type visite'[Type visite détaillé] IN {"Demande du méd. du travail"},
				"A la demande du méd. du travail",
				'RDV/visite - type visite'[Type visite détaillé] IN {"Visite de fin de carrière",
					"Visite de fin d'exposition"},
				"Fin de carrière / Fin d'exposition",
				'RDV/visite - type visite'[Type visite détaillé] IN {"Pré-reprise à la demande du med. conseil",
					"Pré-reprise à la demande du med. du travail",
					"Pré-reprise à la demande du med. traitant",
					"Pré-reprise à la demande du salarié"},
				"Pré-reprise",
				'RDV/visite - type visite'[Type visite détaillé] IN {"Reprise (information non précisée)",
					"Reprise après accident pro",
					"Reprise après maladie non professionnelle",
					"Reprise après maladie professionnelle",
					"Reprise après maternité"},
				"Reprise",
				"Autre"
			)
		lineageTag: a1d6ddd7-a225-4ff0-a209-9ba6052b950d
		summarizeBy: none

