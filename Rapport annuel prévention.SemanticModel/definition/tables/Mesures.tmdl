	measure '% Adhérents à jour d''APP (graph)' =
			
			-- 1. Définition de la fenêtre de temps (Bornes)
			VAR DateFin = [Date Fin Arrêté]           -- La date sélectionnée dans le Slicer (ex: 31/12/2024)
			VAR DateDebut = EDATE(DateFin, -13) + 1   -- 12 mois glissants avant
			
			-- 2. Contexte du graphique (Point actuel de l'axe X)
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			RETURN
			-- 3. Logique d'affichage
			IF(
			    -- Condition : On affiche seulement si le mois de l'axe est dans la fenêtre
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			
			    -- Valeur : On appelle directement la mesure de base (celle qui somme la table Evolution)
			    -- Elle va naturellement se calculer pour le "DateSurAxe" (le mois en cours)
			    [% adhérents à jour d'AMT primaire (fin de période)],
			
			    -- Sinon rien
			    BLANK()
			)
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: cabc0a06-ed48-4f32-94bb-fac8d6fdf4ea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Objectif APP 2026 (Simu)' = ```
			
			-- 1. On récupère la date de l'axe et on la force en FIN DE MOIS
			VAR DateAxe = EOMONTH(MAX('Date Simulation'[Date]), 0)
			VAR DateCible = DATE(2026, 12, 31)
			VAR ValCible = [Objectif APP]
			
			-- 2. On cherche la dernière date de données réelles et on la force en FIN DE MOIS
			VAR DateDerniereDonneeBrute = 
			    CALCULATE(
			        MAX('Date principale'[Date]),
			        FILTER(
			            ALL('Date principale'),
			            NOT(ISBLANK([% adhérents à jour d'AMT primaire (fin de période)]))
			        )
			    )
			VAR DateReference = EOMONTH(DateDerniereDonneeBrute, -1) -- On recule de 1 mois et on cale sur la fin du mois
			
			-- 3. On récupère la valeur de départ
			VAR ValDepart = 
			    CALCULATE(
			        [% adhérents à jour d'AMT primaire (fin de période)], 
			        DATESBETWEEN('Date principale'[Date], EOMONTH(DateReference, -1)+1, DateReference)
			    )
			
			-- 4. NOUVELLE LOGIQUE : Gestion de l'écart
			-- Si le départ est supérieur à la cible, l'écart est nul (on reste stable).
			-- Sinon, on calcule la différence classique pour la pente.
			VAR Ecart = 
			    IF(
			        ValDepart > ValCible, 
			        0, 
			        ValCible - ValDepart
			    )
			
			RETURN
			IF(
			    -- CAS 1 : Point de soudure (Si l'axe est le même mois que la ref)
			    DateAxe = DateReference,
			    ValDepart,
			
			    -- CAS 2 : Projection
			    IF(
			        DateAxe > DateReference && DateAxe <= DateCible,
			        
			        VAR DureeTotale = DATEDIFF(DateReference, DateCible, DAY)
			        VAR DureeEcoulee = DATEDIFF(DateReference, DateAxe, DAY)
			        
			        -- Si Ecart est 0 (car ValDepart > ValCible), le calcul ajoute 0, donc on reste à ValDepart
			        RETURN ValDepart + (Ecart * DIVIDE(DureeEcoulee, DureeTotale)),
			        
			        BLANK()
			    )
			)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 32bd8697-869c-490c-b637-d12db5e9e4cf

