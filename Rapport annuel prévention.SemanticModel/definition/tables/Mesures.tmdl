	measure '# adhérents sans FE moins de 1 an' = ```
			
			VAR DateSeuil = EDATE(TODAY(), -12) 
			
			// 1. On récupère la liste des IDs des adhérents récents dans la table 'Adhérent (actuel)'
			VAR AdherentsRecents = 
			    CALCULATETABLE(
			        VALUES('Adhérent (actuel)'[id_entreprise]), // Vérifie bien le nom exact de la colonne ID ici
			        'Adhérent (actuel)'[Date premier statut actif] >= DateSeuil
			    )
			
			RETURN
			// 2. On injecte cette liste dans le calcul de la mesure sans FE
			CALCULATE(
			    [# adhérents sans FE (fin de période)],
			    // On applique le filtre sur la table cible (probablement 'Evolution effectif' ou 'Adhérents')
			    TREATAS(AdherentsRecents, 'Evolution effectif'[id_entreprise]) 
			)
			```
		formatString: 0
		displayFolder: FE
		lineageTag: 63864a86-9079-4346-affc-658b3b325e90

		changedProperty = DisplayFolder

		changedProperty = Name

