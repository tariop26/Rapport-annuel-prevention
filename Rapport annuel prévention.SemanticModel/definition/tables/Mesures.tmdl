	measure 'Adhérents actifs ou suspendus N-1' = ```
			
			-- 1. On récupère la date choisie actuelle
			VAR DateActuelle = [Date Fin Arrêté]
			
			-- 2. On calcule la date exacte 1 an avant (EDATE gère parfaitement les années bissextiles)
			VAR DateNMoins1 = EDATE(DateActuelle, -12)
			
			RETURN
			CALCULATE(
