	measure 'Nouveaux adhérents sans FE (graph)' = ```
			
			-- 1. Définition de la fenêtre d'affichage (Statique par rapport au rapport)
			VAR DateFin = [Date Fin Arrêté]
			VAR DateDebut = EDATE(DateFin, -13) + 1
			VAR DateSurAxe = MAX('Date principale'[Date]) -- La date du mois en cours sur le graphique
			
			-- 2. Définition de la limite d'ancienneté (DYNAMIQUE par rapport au mois affiché)
			-- C'est la correction clé : on recule de 1 an par rapport au mois du graphique, pas la fin d'année
			VAR DateLimiteAnciennete = EDATE(DateSurAxe, -12)
			
			RETURN
			IF(
			    -- Condition d'affichage : est-on dans la fenêtre ?
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			    
			    -- Si oui, on calcule
			    CALCULATE(
			        -- Mesure de base
			        [Nombre d'adhérents fin de période avec FE non renseignée],
			
			        -- Filtre 1 : Critère "Nouveau" (Date d'entrée > il y a 1 an par rapport au mois affiché)
			        'Adhérent (actuel)'[Date premier statut actif] > DateLimiteAnciennete,
			
			        -- Sécurité : On s'assure que la date d'entrée n'est pas dans le futur par rapport au mois affiché
			        'Adhérent (actuel)'[Date premier statut actif] <= DateSurAxe,
			
			        -- Filtre 2 : Contexte temporel standard
			        'Date principale'[Date] <= DateSurAxe
			    ),
			    
			    BLANK()
			)
			```
		formatString: #,0
		displayFolder: Suivi des indicateurs\FE
		lineageTag: c4f1ef14-525c-4796-972d-33a4e5ddfa2f

	measure 'Nouveaux adhérents sans FE évolution (Variation %)' =
			
			DIVIDE(
			    [Nouveaux adhérents sans FE] - [Nouveaux adhérents sans FE N-1],
			    [Nouveaux adhérents sans FE N-1]
