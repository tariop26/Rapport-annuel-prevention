	measure 'Nouveaux adhérents sans FE' =
			
			-- 1. On définit la date d'arrêt pour le calcul (Mois du graphique OU Date du Slicer)
			VAR DateSnapshot = [Date Fin Arrêté]
			
			-- 2. On définit la date limite pour l'ancienneté (il y a 1 an)
			VAR DateLimiteAnciennete = EDATE(DateSnapshot, -12)
			
			RETURN
			CALCULATE(
			    -- Mesure de base
			    [Nombre d'adhérents fin de période avec FE non renseignée],
			
			    -- Filtre 1 : Critère "Nouveau" (Date d'entrée > il y a 1 an)
			    'Adhérent (actuel)'[Date premier statut actif] > DateLimiteAnciennete,
			
			    -- Filtre 2 : La fenêtre temporelle (Comme dans votre exemple "Adhérents actifs ou suspendus")
			    'Date principale'[Date] <= DateSnapshot
			)
		formatString: #,0
		displayFolder: Suivi des indicateurs\FE
		lineageTag: 0b6cd74e-4653-4f78-8b2c-6a7718542f95

	measure '# adhérents avec FE à mettre à jour (fin de période)' = ```
			
			CALCULATE(
			    'Evolution effectif'[# adhérents en retard de FE (fin de période)],         -- Mesure à calculer
			    'Evolution effectif'[date dernière fe] <> DATE(1900, 1, 1)                  -- Filtre pour exclure les dates non valides
			)
			
			-- Description : Cette mesure calcule le nombre d'adhérents dont la fiche d'évaluation (FE) doit être mise à jour à la fin de la période.
			-- Elle exclut les adhérents dont la date de la dernière FE est une date par défaut (1900-01-01), indiquant que la FE n'est pas valide ou n'a pas été mise à jour.
			
			```
		formatString: 0
		displayFolder: FE
		lineageTag: bb1ecf4c-c9ed-4e0a-807b-faeaa25a1c1b

	measure 'Adhérents avec FE à mettre à jour' =
			
			VAR DateSnapshot = [Date Fin Arrêté]
			
			RETURN
			CALCULATE(
			    COALESCE(
			        ([# adhérents avec FE à mettre à jour (fin de période)]),
			        0
			    ),
			    'Date principale'[Date] <= DateSnapshot
			)
		formatString: #,0
		displayFolder: Suivi des indicateurs\FE
		lineageTag: e586e90f-0c7a-41e8-8c75-071897b9e061

	measure 'sous titre adhérents avec FE à mettre à jour' =
			
			"Adhérents dont la FE a été réalisé avant le "& format([Date 4 an avant], "DD mmmm YYYY", "fr-FR")
		displayFolder: Titres
		lineageTag: ad043f3b-7362-49b5-a353-4cb4e91b60a1

	measure 'Adhérents avec FE a mettre à jour (graph)' =
			
			-- 1. Définition de la fenêtre de temps (Bornes)
			VAR DateFin = [Date Fin Arrêté]           -- La date sélectionnée dans le Slicer (ex: 31/12/2024)
			VAR DateDebut = EDATE(DateFin, -13) + 1   -- 12 mois glissants avant
			
			-- 2. Contexte du graphique (Point actuel de l'axe X)
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			RETURN
			-- 3. Logique d'affichage
			IF(
			    -- Condition : On affiche seulement si le mois de l'axe est dans la fenêtre
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			
			    -- Valeur : On appelle directement la mesure de base (celle qui somme la table Evolution)
			    -- Elle va naturellement se calculer pour le "DateSurAxe" (le mois en cours)
			    [# adhérents avec FE à mettre à jour (fin de période)],
			
			    -- Sinon rien
			    BLANK()
			)
		formatString: #,0
		displayFolder: Suivi des indicateurs\FE
		lineageTag: d2a867b0-6416-43ef-966b-60d59322ad63

	measure 'Adhérents sans FE' = ```
			
			CALCULATE(
			    -- On appelle votre mesure de base
			    [# adhérents en retard de FE (fin de période)],
			    
			    -- On garde uniquement le filtre métier (Jamais eu de FE)
			    'Evolution effectif'[date dernière fe] = DATE(1900, 1, 1)
			)
			```
		formatString: 0
		displayFolder: Suivi des indicateurs\FE
		lineageTag: 99d49908-fd7e-44a9-91b6-00cc7c602495

	measure 'Adhérents sans FE (graph)' = ```
			
			VAR DateFin = [Date Fin Arrêté]
			VAR DateDebut = EDATE(DateFin, -13) + 1
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			-- On récupère la valeur dynamique calculée par votre autre mesure graphique
			-- Assurez-vous que le nom correspond exactement à votre mesure "Nouveaux adhérents sans FE (graph)"
			VAR NouveauxSansFE = [Nouveaux adhérents sans FE (graph)]
			
			RETURN
			IF(
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			    
			    -- CORRECTION : C'est ici qu'on retire les nouveaux pour ne garder que les "vieux" sans FE
			    [Adhérents sans FE] - NouveauxSansFE,
			    
			    BLANK()
			)
			```
		formatString: #,0
		displayFolder: Suivi des indicateurs\FE
		lineageTag: 82bd47cd-147e-49f5-a6d4-9c7c6e976942

