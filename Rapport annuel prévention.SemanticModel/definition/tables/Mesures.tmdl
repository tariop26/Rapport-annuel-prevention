	measure 'Taux de service coalesce' = ```
			
			VAR TauxRetard = [Taux de retard] // Stocke la valeur de la mesure [Taux de retard]
			VAR TauxService = 1 - TauxRetard // Calcule le taux de service en soustrayant le taux de retard de 1
			
			RETURN
			     COALESCE(
			      IF(
			      ISBLANK(TauxRetard), // Vérifie si la valeur du taux de retard est vide
			      1, // Retourne une valeur vide si le taux de retard est vide
			      IF(
			          TauxService = 1, // Vérifie si le taux de service est égal à 1 (100%)
			          1, // Retourne une valeur vide si le taux de service est égal à 100%
			          TauxService // Retourne le taux de service calculé
			      )
			  ),
			  ""
			  )
			
			/*
			Description :
			Cette mesure calcule le taux de service en soustrayant le taux de retard de 1.
			Elle utilise une variable pour stocker la valeur de [Taux de retard] et une condition IF pour vérifier si la valeur est vide ou si le taux de service est égal à 100%.
			Si le taux de retard est vide ou si le taux de service est égal à 100%, la mesure retourne une valeur vide.
			*/
			
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Taux de service
		lineageTag: 0d0b213b-f9ed-40e5-a512-11bd20f86f44

		changedProperty = DisplayFolder

		changedProperty = Name

