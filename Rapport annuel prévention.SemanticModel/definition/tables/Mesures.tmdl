	measure 'Objectif FE 2026 (Simu)' = ```
			
			-- 1. Configuration
			VAR DateAxe = EOMONTH(MAX('Date Simulation'[Date]), 0)
			VAR DateCible = DATE(2026, 12, 31)
			VAR ValCible = [Objectif FE]
			
			-- 2. On cherche la dernière date de données réelles
			VAR DateDerniereDonneeBrute = 
			    CALCULATE(
			        MAX('Date principale'[Date]),
			        FILTER(
			            ALL('Date principale'),
			            NOT(ISBLANK([% Adhérents FE (Base)]))
			        )
			    )
			
			-- 3. On définit le point d'ancrage à M-1
			VAR DateReference = EOMONTH(DateDerniereDonneeBrute, -1)
			
			-- 4. On calcule la valeur de départ sur ce point d'ancrage
			VAR ValDepart = 
			    CALCULATE(
			        [% Adhérents FE (Base)], 
			        DATESBETWEEN('Date principale'[Date], EOMONTH(DateReference, -1)+1, DateReference)
			    )
			
			-- 5. NOUVELLE LOGIQUE : Gestion de l'écart
			-- Si le départ est supérieur à la cible, l'écart est nul (on reste stable).
			-- Sinon, on calcule la différence classique pour la pente.
			VAR Ecart = 
			    IF(
			        ValDepart > ValCible, 
			        0, 
			        ValCible - ValDepart
			    )
			
			RETURN
			IF(
			    -- CAS 1 : Point de jonction (soudure avec le réel)
			    DateAxe = DateReference,
			    ValDepart,
			
			    -- CAS 2 : Projection dans le futur
			    IF(
			        DateAxe > DateReference && DateAxe <= DateCible,
			        
			        VAR DureeTotale = DATEDIFF(DateReference, DateCible, DAY)
			        VAR DureeEcoulee = DATEDIFF(DateReference, DateAxe, DAY)
			        
			        -- Si Ecart est 0 (car ValDepart > ValCible), le calcul ajoute 0, donc on reste à ValDepart
			        RETURN ValDepart + (Ecart * DIVIDE(DureeEcoulee, DureeTotale)),
			        
			        BLANK()
			    )
			)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\FE
		lineageTag: 78a9f3d0-b1c5-4b68-9071-ee319f4ce8a2

