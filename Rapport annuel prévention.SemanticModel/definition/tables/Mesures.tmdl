	measure '% Adhérents sans FE (graph)' = ```
			
			-- 1. Définition de la fenêtre
			VAR DateFin = [Date Fin Arrêté]
			VAR DateDebut = EDATE(DateFin, -13) + 1
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			RETURN
			IF(
			    -- Condition d'affichage (fenêtre)
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			
			    -- 2. Calcul du pourcentage
			    DIVIDE(
			        [Adhérents sans FE]-[Nouveaux adhérents sans FE],                          -- Numérateur (Votre mesure de base corrigée)
			        [# adhérents éligibles FE (fin de période)],  -- Dénominateur
			        0
			    ),
			    
			    BLANK()
			)
