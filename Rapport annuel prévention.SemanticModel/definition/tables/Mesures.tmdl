/// Table de mesure
table Mesures
	lineageTag: e4e5606e-6c09-4686-927a-7d77b8ae27e1

	measure 'Taux de convocations' = ```
			
			VAR NombreVisitesRealisees = [Nombre de visites réalisées (RDV)] -- Variable pour stocker le nombre de visites réalisées
			VAR NombreConvocations = [Nombre de RDV avec convocation] -- Variable pour stocker le nombre total de convocations
			
			RETURN
			    COALESCE(
			        DIVIDE(
			        NombreConvocations, --  nombre total de convocations
			        NombreVisitesRealisees, -- nombre de visites réalisées
			        0 -- Valeur de retour en cas de division par zéro
			    ),
			    0
			    )
			
			-- Cette mesure calcule le taux de convocations en divisant le nombre de visites réalisées
			-- par le nombre total de convocations. Elle utilise DIVIDE pour éviter les erreurs de division par zéro.
			
			```
		formatString: 0.00
		displayFolder: Visites
		lineageTag: be02f609-e699-4357-b77b-adec8e71732c

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = FormatString

	measure 'titre Répartition des visites fonction publique réalisées le mois dernier par catégorie' =
			
			VAR DateMoisDernier = EDATE(TODAY(), -1)                            -- Calcul de la date du mois dernier
			VAR DateFormatee = FORMAT(DateMoisDernier, "Mmmm yyyy", "fr-FR")    -- Formatage de la date
			RETURN
			"Répartition des visites fonction publique réalisées en " & DateFormatee & " par catégorie"                   -- Concaténation du texte avec la date formatée
			
			-- Description : Cette mesure calcule le nombre de visites réalisées le mois dernier et retourne un texte formaté indiquant le mois et l'année.
		displayFolder: Titres
		lineageTag: 5bb7c566-e5af-4c9a-973b-4701a13f3376

