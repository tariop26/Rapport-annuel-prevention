	measure 'Adhérents (Graphique Dynamique)' = ```
			
			-- 1. Définition de la fenêtre de temps (inchangé)
			VAR DateFin = [Date Fin Arrêté]
			VAR DateDebut = EDATE(DateFin, -13) + 1 
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			RETURN
			IF(
			    -- On affiche le chiffre UNIQUEMENT si la date de l'axe est dans la fenêtre
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			    
			    -- 2. On récupère simplement la valeur stockée dans votre table
			    ('Evolution effectif'[Nombre d'adhérents fin de période]),
			    
			    BLANK()
			)
			```
		formatString: #,0
		displayFolder: Suivi des indicateurs\Adhérents
		lineageTag: 23a73131-9838-43d3-acc1-0c1df0ab33e4

	measure 'Adhérents Min Y' = ```
			
			-- 1. On récupère la fenêtre de temps (identique à votre graphique)
			VAR DateFin = [Date Fin Arrêté]
			VAR DateDebut = EDATE(DateFin, -12) + 1
			
			-- 2. On cherche la valeur minimale atteinte par la courbe sur cette période
			VAR MinVal = 
			    MINX(
			        DATESBETWEEN('Date principale'[Date], DateDebut, DateFin),
			        CALCULATE(('Evolution effectif'[Nombre d'adhérents fin de période]))
			    )
			
			-- 3. On applique la réduction de 3%
			RETURN MinVal * 0.97
			```
		displayFolder: Suivi des indicateurs\Adhérents
		lineageTag: 4a3fc3c6-fbc2-4c31-bbf2-0a804d409dd1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Adhérents Max Y' = ```
			
			-- 1. On récupère la fenêtre de temps (identique à votre graphique)
			VAR DateFin = [Date Fin Arrêté]
			VAR DateDebut = EDATE(DateFin, -12) + 1
			
			-- 2. On cherche la valeur max atteinte par la courbe sur cette période
			VAR MaxVal = 
			    MAXX(
			        DATESBETWEEN('Date principale'[Date], DateDebut, DateFin),
			        CALCULATE(('Evolution effectif'[Nombre d'adhérents fin de période]))
			    )
			
			-- 3. On applique la majoration de 3%
			RETURN MaxVal * 1.03
			```
		displayFolder: Suivi des indicateurs\Adhérents
		lineageTag: 4509fd60-aee2-4845-b400-9b4affbfc3fc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

