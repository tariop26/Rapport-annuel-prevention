	measure 'Adhérents à jour d''APP (graph)' =
			
			-- 1. Définition de la fenêtre de temps (Bornes)
			VAR DateFin = [Date Fin Arrêté]           -- La date sélectionnée dans le Slicer (ex: 31/12/2024)
			VAR DateDebut = EDATE(DateFin, -13) + 1   -- 12 mois glissants avant
			
			-- 2. Contexte du graphique (Point actuel de l'axe X)
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			RETURN
			-- 3. Logique d'affichage
			IF(
			    -- Condition : On affiche seulement si le mois de l'axe est dans la fenêtre
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			
			    -- Valeur : On appelle directement la mesure de base (celle qui somme la table Evolution)
			    -- Elle va naturellement se calculer pour le "DateSurAxe" (le mois en cours)
			    [% adhérents à jour d'AMT primaire (fin de période)],
			
			    -- Sinon rien
			    BLANK()
			)
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 904099dd-145a-4596-8bfa-a44a0eb8ef77

	measure '% Adhérents à jour d''APP N-1' = ```
			
			-- 1. On récupère la date actuelle (Fin de période sélectionnée)
			VAR DateActuelle = [Date Fin Arrêté]
			
			-- 2. On calcule la date de référence pour l'année précédente (Le "Aujourd'hui" de l'an dernier)
			VAR DateNMoins1 = EDATE(DateActuelle, -12)
			
			-- 3. On définit la limite d'ancienneté pour cette époque-là 
			-- (Pour être "nouveau" en N-1, il faut être arrivé après N-2)
			VAR DateLimiteAncienneteNMoins1 = EDATE(DateNMoins1, -12)
			
			RETURN
			CALCULATE(
			    -- Mesure de base
			    [% adhérents à jour d'AMT primaire (fin de période)],
			
			    -- Filtre 2 : On remonte le temps sur la date principale
			    'Date principale'[Date] <= DateNMoins1
			)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: f918ea05-34e4-4e5e-94d6-7aee52472040

	measure 'Adhérents à jour d''APP (Variation %)' =
			
			DIVIDE(
			    [Adhérents à jour d'APP] - [Adhérents à jour d'APP N-1],
