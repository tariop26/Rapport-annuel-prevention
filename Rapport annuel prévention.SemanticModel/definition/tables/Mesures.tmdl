			VAR DatesPeriode =
			    FILTER(ALL('Date principale'[Date]), 'Date principale'[Date] >= dMin && 'Date principale'[Date] <= dMax)
			Return
			CALCULATE([% Visites avec échelle remplie (visite)], DatesPeriode)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\DMST
