	measure '% Adhérents à jour de APP (Réalisé)' = ```
			
			VAR DerniereDateReelle = CALCULATE(MAX('Date principale'[Date]), ALL('Date principale'))
			VAR DateSimu = MAX('Date Simulation'[Date])
			
			RETURN
			IF(
			    -- On coupe l'affichage après la dernière vraie date pour laisser la place à la simu
			    DateSimu <= DerniereDateReelle,
			    
			    CALCULATE(
			        [% adhérents à jour d'AMT primaire (fin de période)], -- On appelle la mesure de BASE
			        TREATAS(VALUES('Date Simulation'[Date]), 'Date principale'[Date])
			    ),
			    BLANK()
			)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\AMT
