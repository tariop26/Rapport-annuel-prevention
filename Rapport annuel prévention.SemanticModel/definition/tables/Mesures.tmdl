	measure 'Visites intérimaires' = ```
			
			-- 1. On récupère la date butoir dynamique (basée sur votre segment "Choisir Période")
			VAR DateFinContexte = [Date Fin Arrêté]
			
			-- 2. On construit la plage de 12 mois glissants qui se termine à cette date précise
			VAR Fenetre12M = DATESINPERIOD('Date principale'[Date], DateFinContexte, -12, MONTH)
			
			RETURN
			COALESCE(
			    CALCULATE(
			        'RDV'[Nombre de visites réalisées (RDV)],
			        
			        -- On conserve le filtre Intérim sans écraser d'autres filtres potentiels sur l'adhérent
			        KEEPFILTERS('Adhérent (actuel)'[Type entreprise] = "Intérim"),
			        
			        -- On force le contexte de date à être notre fenêtre glissante calculée
			        -- Cela va "surcharger" tout autre filtre de date présent sur la page pour ce calcul
			        Fenetre12M
			    ),
			    0
			)
			```
		formatString: #,0
		displayFolder: Suivi des indicateurs\Visites
		lineageTag: 0bff3b19-640d-44ed-a654-7ee80ea1cb4e

