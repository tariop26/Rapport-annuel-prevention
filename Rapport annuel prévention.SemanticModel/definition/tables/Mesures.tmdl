	measure '% nouveaux adhérents sans FE' =
			
			var Aujourdhui = Max('Date principale'[Date])
			var NouveauxAdherents = CALCULATE(
			                            DISTINCTCOUNT('Adhérent (actuel)'[Matricule entreprise]),
			                            'Adhérent (actuel)'[Date création dossier entreprise] - Aujourdhui < 365
			)
			var NouveauxSansFE = CALCULATE(
			                            NouveauxAdherents,
			                            'Adhérent (actuel)'[Statut FE] = "Aucune FE renseignée"
			)
			
			RETURN
			divide(
			    NouveauxSansFE,
			    NouveauxAdherents,
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: FE
		lineageTag: 579d601f-c3d4-49e6-adca-f9db26c2916d

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = FormatString

	measure Afficher_jusqua_Cible = ```
			
			VAR CurDate  = DATEVALUE( MAX ( 'Dates_Futur'[EndOfMonth] ) )
			VAR Target0  =
			   COALESCE(
			    SELECTEDVALUE( Dates_Cible[Date] ),
			    MAXX( ALLSELECTED( Dates_Cible[Date] ), Dates_Cible[Date] )
			)
			VAR Target = DATEVALUE( EOMONTH( Target0, 0 ) )  // option: caler à fin de mois
			RETURN
			    NOT ISBLANK( Target ) && CurDate <= Target
			
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		displayFolder: FE\Simulation
		lineageTag: af5d126f-5e81-40cd-9b31-5cd1b988b136

		changedProperty = DisplayFolder

		changedProperty = Name

