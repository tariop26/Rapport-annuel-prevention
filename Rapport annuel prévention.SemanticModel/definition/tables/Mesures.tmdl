	measure '% adhérents ayant transmis leur DU évolution (variation %)' =
			
			([% Adhérents ayant transmis leur DU] - [% Adhérents ayant transmis leur DU N-1])/[% Adhérents ayant transmis leur DU N-1]
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 6b241128-add6-4175-8cb6-8976c571b54x

	measure '% Adhérents ayant transmis leur DU N-1' =
			
			DIVIDE(
			    CALCULATE(
			    [Adhérents actifs ou suspendus N-1],
			    'Adhérent (actuel)'[DU transmis] = "DU transmis par l'adhérent"
			    ),
			    [Adhérents actifs ou suspendus N-1],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 9b60d56c-0677-49a4-949e-7bb00c81b4x9

	partition Mesures = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#"Colonne 1" = _t]),
				    #"Type modifié" = Table.TransformColumnTypes(Source,{{"Colonne 1", type text}}),
				    #"Colonnes supprimées" = Table.RemoveColumns(#"Type modifié",{"Colonne 1"})
				in
				    #"Colonnes supprimées"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

