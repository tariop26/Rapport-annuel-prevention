			CALCULATE(
			    COALESCE(
			        ('Evolution effectif'[Effectif suivi figé non intérimaire fin de période] + 'Evolution effectif'[Effectif suivi figé intérimaire fin de période]), 
			        0
			    ),
			    -- 3. On remplace le filtre de date par celle de l'année précédente
