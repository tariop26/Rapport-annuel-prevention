	measure '# adhérents (respecte secteur)' = ```
			
			CALCULATE(
			    DISTINCTCOUNT('CRM - tickets'[id_entreprise]),
			    FILTER(
			        ALLSELECTED('CRM - tickets'), 
			        [Tickets en-cours] > 0
			    ),
			    KEEPFILTERS(VALUES('CRM - tickets'[id_secteur]))
			)
			
			```
		formatString: 0
		displayFolder: Tickets
		lineageTag: 65f8b280-04e9-454d-981a-1416b50b2823

		changedProperty = DisplayFolder

		changedProperty = Name

	measure '# adhérents avec un ticket depuis début de l''année' = ```
			
			VAR CetteAnnee = YEAR(TODAY())
			VAR T =
			    FILTER(
			        ALL('CRM - tickets'[id_entreprise]),          -- ne retire pas le filtre secteur
			        [# tickets] > 0
			    )
			RETURN
			CALCULATE(
			    DISTINCTCOUNT('CRM - tickets'[id_entreprise]),
			    T,                                                -- condition “au moins 1 ticket”
			    KEEPFILTERS('CRM - activité - date'[Année activité] = CetteAnnee),  -- ajoute sans écraser
			    REMOVEFILTERS('Utilisateur'),                     -- remplace ALL(...) de façon ciblée
			    REMOVEFILTERS('Date principale')                  -- idem, si nécessaire
			)
			
			```
		formatString: #,0
		displayFolder: Tickets
		lineageTag: 4f411e69-3397-4a54-b8e1-e302b414d760

		changedProperty = Name

		changedProperty = FormatString

		changedProperty = DisplayFolder

