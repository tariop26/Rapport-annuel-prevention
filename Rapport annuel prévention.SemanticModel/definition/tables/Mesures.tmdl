	measure 'nouveaux adhérents' =
			
			CALCULATE(
			    [Adhérents actifs ou suspendus],
			    'Adhérent (actuel)'[Date premier statut actif] > TODAY()-365
			)
		formatString: 0
		displayFolder: Suivi des indicateurs\Adhérents
