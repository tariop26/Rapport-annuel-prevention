			VAR DateNMoins1 = EDATE(DateActuelle, -12)
			
			RETURN
			CALCULATE(
			    'Evolution retard'[Nombre de salariés suivis],
			    'Evolution retard - catégorie retard'[Catégorie retard] = "En retard",
			    -- 3. On remplace le filtre de date par celle de l'année précédente
			    'Date principale'[Date] <= DateNMoins1
