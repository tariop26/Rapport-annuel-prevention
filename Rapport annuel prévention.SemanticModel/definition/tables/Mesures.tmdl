	measure 'APP à mettre à jour dans les 12 mois' = ```
			
			-- 1. On identifie la date de fin de la période sélectionnée (ex: 31/12/2025)
			VAR DateReference = MAX('Date principale'[Date])
			
			-- 2. On définit la date butoir (Date Ref + 1 an)
			VAR DateButoir = DateReference + 365
			
			RETURN
			CALCULATE(
			    'Evolution effectif'[# adhérents à jour d'AMT primaire (fin de période)],
			    
			    -- Critère : La date prochaine doit être APRÈS la date de référence ET AVANT la date butoir
			    'Evolution effectif - date prochaine APP'[Date] > DateReference &&
			    'Evolution effectif - date prochaine APP'[Date] <= DateButoir
			)
			```
		formatString: 0
		displayFolder: Suivi des indicateurs\FE
		lineageTag: 4b71634c-807f-4bb6-b404-67265811bb53

	measure 'FE à mettre à jour dans les 12 mois' = ```
			
