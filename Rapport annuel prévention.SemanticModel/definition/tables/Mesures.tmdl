	measure 'Délai moyen en-cours > à valider AMT Période' = ```
			VAR dMax = [Date Fin Arrêté]
			VAR dMin = EDATE([Date Fin Arrêté],-12)+1
			VAR DatesPeriode = FILTER(ALL('Date principale'[Date]), 'Date principale'[Date] >= dMin && 'Date principale'[Date] <= dMax)
			VAR Resultat = CALCULATE(
			        AVERAGE('AMT v2'[Délai AMT statut en cours -> à valider]), -- Calcul de la moyenne arithmétique sur la colonne des délais
			        FILTER(
			            'AMT v2', -- Itération sur la table de faits pour évaluer la condition ligne par ligne
			            [# AMT terminées] >= 1 && -- Filtre pour ne garder que les lignes où l'AMT est considérée comme terminée
			            NOT(ISBLANK('AMT v2'[Délai AMT statut en cours -> à valider])) -- Optimisation : exclusion explicite des valeurs vides pour alléger le calcul
			        )
			    )
			RETURN
			    CALCULATE(
					Resultat, 
					DatesPeriode
				)
			/* Description : 
			Cette mesure calcule la moyenne des délais (en jours ou heures selon la colonne source) 
			entre le statut 'en cours' et 'à valider'. 
			Le calcul ne prend en compte que les AMT qui remplissent la condition d'être terminées ([# AMT terminées] >= 1)
			et exclut les valeurs vides pour garantir la pertinence de la moyenne.
			*/
			```
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 79c8936d-ac39-4dc9-b7d2-57700db28d72

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Délai moyen à faire > terminée AMT Période' = ```
			
			VAR dMax = [Date Fin Arrêté]
			VAR dMin = EDATE([Date Fin Arrêté],-12)+1
			VAR DatesPeriode = FILTER(ALL('Date principale'[Date]), 'Date principale'[Date] >= dMin && 'Date principale'[Date] <= dMax)
			VAR Resultat = 
			    CALCULATE(
			        AVERAGE('AMT v2'[Délai AMT statut à Faire -> Terminée]), -- Calcul de la moyenne arithmétique sur la colonne des délais
			        FILTER(
			            'AMT v2', -- Itération sur la table de faits pour évaluer la condition ligne par ligne
			            [# AMT terminées] >= 1 && -- Filtre pour ne garder que les lignes où l'AMT est considérée comme terminée
			            NOT(ISBLANK('AMT v2'[Délai AMT statut à Faire -> Terminée])) -- Optimisation : exclusion explicite des valeurs vides pour alléger le calcul
			        )
			    )
			RETURN
			    CALCULATE(
					Resultat, 
					DatesPeriode
				)
			/* Description : 
			Cette mesure calcule la moyenne des délais (en jours ou heures selon la colonne source) 
			entre le statut 'à faire' et 'terminée'. 
			Le calcul ne prend en compte que les AMT qui remplissent la condition d'être terminées ([# AMT terminées] >= 1)
			et exclut les valeurs vides pour garantir la pertinence de la moyenne.
			*/
			```
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 059f2f78-dfef-442f-8a2d-e94088e06354

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Délai moyen à validée > validée AMT Période' = ```
			VAR dMax = [Date Fin Arrêté]
			VAR dMin = EDATE([Date Fin Arrêté],-12)+1
			VAR DatesPeriode = FILTER(ALL('Date principale'[Date]), 'Date principale'[Date] >= dMin && 'Date principale'[Date] <= dMax)
			VAR Resultat = 
			    CALCULATE(
			        AVERAGE('AMT v2'[Délai AMT statut à valider -> validée]), -- Calcul de la moyenne arithmétique sur la colonne des délais
			        FILTER(
			            'AMT v2', -- Itération sur la table de faits pour évaluer la condition ligne par ligne
			            [# AMT terminées] >= 1 && -- Filtre pour ne garder que les lignes où l'AMT est considérée comme terminée
			            NOT(ISBLANK('AMT v2'[Délai AMT statut à valider -> validée])) -- Optimisation : exclusion explicite des valeurs vides pour alléger le calcul
			        )
			    )
			RETURN
			    CALCULATE(
					Resultat, 
					DatesPeriode
				)
			/* Description : 
			Cette mesure calcule la moyenne des délais (en jours ou heures selon la colonne source) 
			entre le statut 'à valider' et 'validéé. 
			Le calcul ne prend en compte que les AMT qui remplissent la condition d'être terminées ([# AMT terminées] >= 1)
			et exclut les valeurs vides pour garantir la pertinence de la moyenne.
			*/
			```
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 52a14503-aa37-4542-8e53-fc38a14ac0e3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Délai moyen à faire > terminée AMT N-1' = ```
			
			VAR DateFin_Arrete = [Date Fin Arrêté]
			-- Calcul explicite des bornes pour la période N-1 (Glissant - 1 an)
			-- On recule la date de fin de 12 mois pour obtenir la fin N-1
			VAR DateFin_N1 = EDATE(DateFin_Arrete, -12) 
			-- On recule la date de fin de 24 mois + 1 jour pour obtenir le début N-1 (période de 12 mois)
			VAR DateDebut_N1 = EDATE(DateFin_Arrete, -24) + 1 
			
			VAR Resultat = 
			    CALCULATE(
			        AVERAGE('AMT v2'[Délai AMT statut à Faire -> Terminée]), -- La moyenne ignore nativement les vides
			        
			        -- Optimisation : On applique le filtre de date directement dans le CALCULATE principal
			        -- Cela est plus performant que de passer une table filtrée via FILTER(ALL(...))
			        'Date principale'[Date] >= DateDebut_N1,
			        'Date principale'[Date] <= DateFin_N1,
			
			        -- Filtre conditionnel sur les AMT terminées
			        -- Attention : En DirectQuery, assurez-vous que cette condition est indispensable. 
			        -- Si la colonne [Délai...] n'existe que pour les AMT terminées, ce filtre pourrait même être retiré.
			        FILTER(
			            'AMT v2', 
			            [# AMT terminées] >= 1 
			        )
			    )
			
			RETURN
			    Resultat
			
			/* Description :
			Cette mesure calcule le délai moyen (en jours) entre le statut 'à faire' et 'terminée' 
			pour la période de 12 mois précédant l'année glissante actuelle (N-1).
			Elle se base sur la date de fin d'arrêté sélectionnée.
			Le calcul filtre dynamiquement la période temporelle et ne considère que les lignes 
			où l'AMT est validée comme terminée via la mesure [# AMT terminées].
			*/
			```
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 059f2f78-dfef-442f-8a2d-e94088e06454

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Délai moyen à validée > validée AMT N-1' =
			VAR dMax = [Date Fin Arrêté]
			VAR dMin = EDATE([Date Fin Arrêté],-12)+1
			VAR DatesPeriode = FILTER(ALL('Date principale'[Date]), 'Date principale'[Date] >= dMin && 'Date principale'[Date] <= dMax)
			VAR DatesPeriodeN1 = DATEADD(DatesPeriode, -1, YEAR)
			VAR Resultat =
			    CALCULATE(
			        AVERAGE('AMT v2'[Délai AMT statut à valider -> validée]), -- Calcul de la moyenne arithmétique sur la colonne des délais
			        FILTER(
			            'AMT v2', -- Itération sur la table de faits pour évaluer la condition ligne par ligne
			            [# AMT terminées] >= 1 && -- Filtre pour ne garder que les lignes où l'AMT est considérée comme terminée
			            NOT(ISBLANK('AMT v2'[Délai AMT statut à valider -> validée])) -- Optimisation : exclusion explicite des valeurs vides pour alléger le calcul
			        )
			    )
			RETURN
			    CALCULATE(
					Resultat,
					DatesPeriodeN1
				)
			/* Description :
			Cette mesure calcule la moyenne des délais de l'année N-1
			entre le statut à valider et validée'.
			Le calcul ne prend en compte que les AMT qui remplissent la condition d'être terminées ([# AMT terminées] >= 1)
			et exclut les valeurs vides pour garantir la pertinence de la moyenne.
			*/
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 52a14503-aa37-4532-8e53-fc38a14ac0e3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Délai moyen en-cours > à valider AMT N-1' =
			VAR dMax = [Date Fin Arrêté]
			VAR dMin = EDATE([Date Fin Arrêté],-12)+1
			VAR DatesPeriode = FILTER(ALL('Date principale'[Date]), 'Date principale'[Date] >= dMin && 'Date principale'[Date] <= dMax)
			VAR DatesPeriodeN1 = DATEADD(DatesPeriode, -1, YEAR)
			VAR Resultat =
			    CALCULATE(
			        AVERAGE('AMT v2'[Délai AMT statut en cours -> à valider]), -- Calcul de la moyenne arithmétique sur la colonne des délais
			        FILTER(
			            'AMT v2', -- Itération sur la table de faits pour évaluer la condition ligne par ligne
			            [# AMT terminées] >= 1 && -- Filtre pour ne garder que les lignes où l'AMT est considérée comme terminée
			            NOT(ISBLANK('AMT v2'[Délai AMT statut en cours -> à valider])) -- Optimisation : exclusion explicite des valeurs vides pour alléger le calcul
			        )
			    )
			RETURN
			    CALCULATE(
					Resultat,
					DatesPeriodeN1
				)
			/* Description :
			Cette mesure calcule la moyenne des délais de l'année N-1
			entre le statut à valider et validée'.
			Le calcul ne prend en compte que les AMT qui remplissent la condition d'être terminées ([# AMT terminées] >= 1)
			et exclut les valeurs vides pour garantir la pertinence de la moyenne.
			*/
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: 79c8936d-ac39-4dc9-b8d2-57700db28d72

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Délai AMT en cours > à valider évolution' =
			
			DIVIDE(
			    [Délai moyen en-cours > à valider AMT Période] - [Délai moyen en-cours > à valider AMT N-1],
			    [Délai moyen en-cours > à valider AMT N-1]
			)
		displayFolder: Suivi des indicateurs\AMT
		lineageTag: e77317b2-9f20-41f6-93b2-a60abbd07ff8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Délai AMT à valider > validée évolution' =
			
