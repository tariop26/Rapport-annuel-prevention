	measure 'Nb Mois Simulation' = ```
			
			VAR DateCible = SELECTEDVALUE('Dates_Futur'[Date]) // Récupère la date choisie dans le segment
			VAR DateReference = TODAY() // Ou la dernière date de vos données : MAX('Date principale'[Date])
			
			RETURN
			    // Calcul de la différence en mois
			    IF(
			        ISBLANK(DateCible) || DateCible <= DateReference, 
			        BLANK(), // Sécurité si pas de date ou date passée
			        DATEDIFF(DateReference, DateCible, MONTH)
			    )
			```
		formatString: 0
		displayFolder: FE\Simulation
		lineageTag: d4ed7a7a-7cc5-4b61-b32d-502644623b59

		changedProperty = DisplayFolder

