	measure 'AMT N-1' =
			
			CALCULATE(
			    [# AMT terminées],
			    DATEADD( 'Date principale'[Date], -1, YEAR ) -- Déplace la période visible de 2 ans en arrière
			)
			/* Description :
			Cette mesure calcule le résultat pour la même période que celle sélectionnée, mais deux ans plus tôt.
			Elle utilise DATEADD qui est plus flexible que SAMEPERIODLASTYEAR.
			Nécessite une table de dates marquée et continue.
			*/
		formatString: #,0
		displayFolder: AMT
		lineageTag: 70b62caf-a0bc-44b3-b35d-9898fc0087a1

	measure 'Max Y AMT' =
			
