	measure 'Taux de service (graph)' =
			
			-- 1. Définition de la fenêtre de temps (Bornes)
			VAR DateFin = [Date Fin Arrêté]           -- La date sélectionnée dans le Slicer (ex: 31/12/2024)
			VAR DateDebut = EDATE(DateFin, -13) + 1   -- 12 mois glissants avant
			VAR TauxService = 1-[Taux de retard]
			
			-- 2. Contexte du graphique (Point actuel de l'axe X)
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			RETURN
			-- 3. Logique d'affichage
			IF(
			    -- Condition : On affiche seulement si le mois de l'axe est dans la fenêtre
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			
			    -- Valeur : On appelle directement la mesure de base (celle qui somme la table Evolution)
			    -- Elle va naturellement se calculer pour le "DateSurAxe" (le mois en cours)
			    TauxService,
			
			    -- Sinon rien
			    BLANK()
			)
		displayFolder: Suivi des indicateurs\Taux de service
		lineageTag: b635685e-287a-4c4d-967d-75199b7e2836

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Objectif Taux de service 2026 (Simu)' = ```
			
			VAR DateAxe = MAX('Date Simulation'[Date]) -- On lit notre nouvel axe
			VAR DateCible = DATE(2026, 12, 31)
			VAR ValCible = [Objectif Taux de service]
			
			-- 1. On trouve la dernière date où on a du "vrai" réalisé
			VAR DateDerniereDonnee = 
			    CALCULATE(
			        MAX('Date principale'[Date]),
			        FILTER(
			            ALL('Date principale'), -- On prend toute la table
			            NOT(ISBLANK([Taux de service (graph)])) -- Et on teste la mesure ligne par ligne
			        )
			    )
			
			-- 2. On récupère la valeur de départ à cette date précise
			VAR ValDepart = 
			    CALCULATE(
			        [Taux de service (graph)],
			        'Date principale'[Date] = DateDerniereDonnee
			    )
			
			RETURN
			-- 3. On affiche la projection uniquement pour le futur
			IF(
			    DateAxe >= DateDerniereDonnee && DateAxe <= DateCible,
			    
			    VAR DureeTotale = DATEDIFF(DateDerniereDonnee, DateCible, DAY)
			    VAR DureeEcoulee = DATEDIFF(DateDerniereDonnee, DateAxe, DAY)
			    VAR Ecart = ValCible - ValDepart
			    
			    RETURN ValDepart + (Ecart * DIVIDE(DureeEcoulee, DureeTotale)),
			    
			    BLANK()
			)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\Taux de service
		lineageTag: 76e9d0c7-1e66-4497-bd5a-a4275f8868dd

	measure 'Taux de Service N-1' = ```
			
			-- 1. On récupère la date actuelle (Fin de période sélectionnée)
			VAR DateActuelle = [Date Fin Arrêté]
			
			-- 2. On calcule la date de référence pour l'année précédente (Le "Aujourd'hui" de l'an dernier)
			VAR DateNMoins1 = EDATE(DateActuelle, -12)
			
			-- 3. On définit la limite d'ancienneté pour cette époque-là 
			-- (Pour être "nouveau" en N-1, il faut être arrivé après N-2)
			VAR DateLimiteAncienneteNMoins1 = EDATE(DateNMoins1, -12)
			
			RETURN
			CALCULATE(
			    -- Mesure de base
			    1-[Taux de retard],
			
			    -- Filtre 2 : On remonte le temps sur la date principale
			    'Date principale'[Date] <= DateNMoins1
			)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Suivi des indicateurs\Taux de service
