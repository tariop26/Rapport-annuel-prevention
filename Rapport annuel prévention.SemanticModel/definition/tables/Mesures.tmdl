	measure 'Visites (Graphique Dynamique)' = ```
			
			-- 1. On définit la fenêtre de temps souhaitée par rapport au Slicer
			VAR DateFin = [Date Fin Arrêté]
			VAR DateDebut = EDATE(DateFin, -13) + 1 -- Recule de 12 mois + 1 jour
			
			-- 2. On regarde la date du point actuel du graphique
			VAR DateSurAxe = MAX('Date principale'[Date])
			
			RETURN
			IF(
			    -- On affiche le chiffre UNIQUEMENT si la date de l'axe est dans la fenêtre
			    DateSurAxe >= DateDebut && DateSurAxe <= DateFin,
			    
			    [Nombre de visites réalisées (RDV)],
			    
			    -- Sinon on renvoie BLANK, ce qui effacera la ligne sur le graphique
			    BLANK()
			)
			```
