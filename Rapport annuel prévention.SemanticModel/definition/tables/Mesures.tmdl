	measure 'Visites Période N-1' = ```
			
			VAR dMax = [Date Fin Arrêté]
			VAR dMin = EDATE([Date Fin Arrêté],-12)+1
			VAR DatesPeriode =
			    FILTER(ALL('Date principale'[Date]), 'Date principale'[Date] >= dMin && 'Date principale'[Date] <= dMax)
			VAR DatesPeriodeN1 =
			    DATEADD(DatesPeriode, -1, YEAR)
			RETURN
			CALCULATE( [Nombre de visites réalisées (RDV)], DatesPeriodeN1 )
			
			```
