	column 'Mois de retard' = DATEDIFF([Date visite calculée],TODAY(),MONTH)
		formatString: 0
		lineageTag: 46fe94e6-cd96-4ffe-9445-39937af403fc
		summarizeBy: sum

		changedProperty = Name

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Années de retard' = [Mois de retard]/12
		lineageTag: b43da813-239f-4e2b-9a79-601a6fdbe4b4
		summarizeBy: sum

		changedProperty = Name

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Catégorie année de retard' =
			
			SWITCH(
			    TRUE(),
			    'Salarié (actuel)'[Années de retard] < 0, "A jour",
			    'Salarié (actuel)'[Années de retard] >= 0 && 'Salarié (actuel)'[Années de retard] < 1, "0-1 an",
			    'Salarié (actuel)'[Années de retard] >= 1 && 'Salarié (actuel)'[Années de retard] < 3, "1-3 ans",
			    'Salarié (actuel)'[Années de retard] >= 3 && 'Salarié (actuel)'[Années de retard] < 5, "3-5 ans",
			    'Salarié (actuel)'[Années de retard] >= 5, "Plus de 5 ans"
			)
		lineageTag: bd584377-28df-49cf-9d42-34d21106fefb
		summarizeBy: none

		changedProperty = Name

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Visite calculée réalisable par :' =
			SWITCH(
				TRUE,
				ISBLANK('Salarié (actuel)'[Visite calculée réalisable par]),
				"(Vide)",
				'Salarié (actuel)'[Visite calculée réalisable par] IN {"Médecin et IDEST"},
				"IDEST",
				'Salarié (actuel)'[Visite calculée réalisable par] IN {"Médecin uniquement"},
				"Médecin",
				"Autre"
			)
		lineageTag: ce0fdab4-7e20-4d1a-8714-cacd1bc2d90c
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
				  "version": 0,
				  "groupedColumns": [
				    {
				      "Column": {
				        "Expression": {
				          "SourceRef": {
				            "Entity": "Salarié (actuel)"
				          }
				        },
				        "Property": "Visite calculée réalisable par"
				      }
				    }
				  ]
				}

		changedProperty = IsHidden

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"s","Entity":"Salarié (actuel)"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"s"}},"Property":"Visite calculée réalisable par"}}],"GroupItems":[{"DisplayName":"(Vide)","BlankDefaultPlaceholder":true},{"DisplayName":"IDEST","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"s"}},"Property":"Visite calculée réalisable par"}}],"Values":[[{"Literal":{"Value":"'Médecin et IDEST'"}}]]}}},{"DisplayName":"Médecin","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"s"}},"Property":"Visite calculée réalisable par"}}],"Values":[[{"Literal":{"Value":"'Médecin uniquement'"}}]]}}},{"DisplayName":"Autre"}]}

