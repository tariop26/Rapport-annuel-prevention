	column 'Type de zone (travail/hors travail)' =
			SWITCH(
				TRUE,
				ISBLANK('Temps travail - type zone'[Type de zone]),
				"(Vide)",
				'Temps travail - type zone'[Type de zone] IN {"Hors zone d'activité non clinique",
					"Zone d'activité non clinique"},
				"Heures de travail",
				'Temps travail - type zone'[Type de zone] IN {"Indisponibilité"},
