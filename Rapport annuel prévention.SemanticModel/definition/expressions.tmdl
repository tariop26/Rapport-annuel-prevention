expression '0 - SPSTI par commune' =
		let
		    // Paramètres
		    url_fichier = "https://pst38.sharepoint.com/sites/a_ETO_DG_DOP-Sectorisation/Documents%20partages/Carto/SPSTI par commune.xlsx",
		
		    // Source SharePoint en flux Web (meilleure pliabilité côté source)
		    src_classeur = Excel.Workbook(Web.Contents(url_fichier), null, false),
		
		    // Sélection de la feuille par nom, avec contrôle de présence
		    tbl_feuille = src_classeur{[Item = "SPSTI par commune", Kind = "Sheet"]}[Data],
		
		    // Promotion d'en-têtes
		    entetes = Table.PromoteHeaders(tbl_feuille, [PromoteAllScalars = true]),
		    #"Type modifié" = Table.TransformColumnTypes(entetes,{{"SPSTI", type text}, {"LIBELLE", type text}, {"Nom Commune", type text}, {"COMMUNE", type text}}),
		    #"Colonnes renommées" = Table.RenameColumns(#"Type modifié",{{"COMMUNE", "Code INSEE"}}),
		    #"Personnalisée ajoutée" = Table.AddColumn(#"Colonnes renommées", "Localisation", each [LIBELLE]& ", Isère, France", type text)
		in
		    #"Personnalisée ajoutée"
