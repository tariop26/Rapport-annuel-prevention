		    ),
		
		    // Filtrer tôt sur le chemin du dossier (réduit le volume traité)
		    FichiersDossierAMT = Table.SelectRows(Source, each ([Folder Path] = "https://pst38.sharepoint.com/sites/a_ETO_DG_DOP/Documents partages/Qualité et indicateurs/0 - Export Padoa/9 - AMT/AMT - Export/")),
		        #"Fichiers masqués filtrés2" = Table.SelectRows(FichiersDossierAMT, each [Attributes]?[Hidden]? <> true),
		    #"Appeler une fonction personnalisée2" = Table.AddColumn(#"Fichiers masqués filtrés2", "Transformer le fichier", each #"Transformer le fichier"([Content])),
		    #"Colonnes renommées1" = Table.RenameColumns(#"Appeler une fonction personnalisée2", {"Name", "Source.Name"}),
		    #"Autres colonnes supprimées2" = Table.SelectColumns(#"Colonnes renommées1", {"Source.Name", "Transformer le fichier"}),
		    #"Colonne de tables développée2" = Table.ExpandTableColumn(#"Autres colonnes supprimées2", "Transformer le fichier", Table.ColumnNames(#"Transformer le fichier"(#"Exemple de fichier"))),
		    // Typage colonnes
		    TypeModifié = Table.TransformColumnTypes(#"Colonne de tables développée2",{{"Rapport envoyé", type text}, {"Date statut actuel AMT", type date}, {"Date clôture AMT", type date}, {"Date statut abandonnée", type date}, {"Date statut terminée", type date}, {"Date statut en cours", type date}, {"Date statut à faire", type date}, {"Date statut suspendue", type date}, {"Date statut validée", type date}, {"Date statut à valider", type date}, {"Date création AMT", type date}, {"Date statut à affecter", type date}, {"Date d'échéance", type date}, {"Date affectation demande AMT", type date}, {"Date création demande AMT", type date}, {"Identifiant AMT", Int64.Type}, {"Type AMT", type text}, {"Modèle AMT", type text}, {"Périmètre AMT", type text}, {"Titre AMT", type text}, {"Action de maintien en emploi", type text}, {"Origine AMT", type text}, {"Priorité AMT", type text}, {"AMT Prévention primaire", type text}, {"Déclineur AMT", type text}, {"Statut AMT", type text}, {"Statut AMT détaillé", type text}, {"Liste des intervenants", type text}, {"Motif abandon AMT", type text}, {"Sous motif abandon AMT", type text}, {"AMT issue d'une demande", type text}, {"Demandeur AMT", type text}, {"Créateur AMT", type text}, {"Avec piece jointe", type text}, {"Temps total alloué", Int64.Type}, {"Nombre d'évènements", Int64.Type}, {"Nombre de tâches réalisées", Int64.Type}, {"Nombre de tâches planifiées", Int64.Type}, {"Nombre de jours de retard", Int64.Type}, {"Avec pièce jointe partagée", type text}, {"Origine de la demande AMT", type text}, {"Date de dernière intervention AMT", type date}, {"AMT en retard", type text}}),
		    #"Colonnes supprimées" = Table.RemoveColumns(TypeModifié,{"Avec piece jointe", "Date statut actuel AMT", "Modalités de l'intervention", "Présence du médecin", "Projet de service", "Thématiques intervention ergonomique", "Temps total alloué", "Durée intervention en heures (planning)", "Durée trajet en heures (planning)", "Durée rédaction en heures (planning)", "Durée évènement collectif en heures (planning)", "Durée autre évènement en heures (planning)", "Durée intervention en heures (ajoutée manuellement)", "Durée trajet en heures (ajoutée manuellement)", "Durée rédaction et autres en heures (ajoutée manuellement)", "Source.Name", "Périmètre AMT", "Action de maintien en emploi", "Origine AMT", "Priorité AMT", "Déclineur AMT", "Statut AMT détaillé", "Liste des intervenants", "Nombre d'évènements", "Motif abandon AMT", "Sous motif abandon AMT", "Nombre de tâches réalisées", "Date de dernière intervention AMT", "Nombre de tâches planifiées", "Avec pièce jointe partagée", "Rapport envoyé", "AMT issue d'une demande", "Origine de la demande AMT", "Date d'échéance", "Date création demande AMT", "Date affectation demande AMT", "AMT en retard", "Date statut à affecter", "Nombre de jours de retard", "Titre AMT", "Demandeur AMT"}),
		    #"Lignes filtrées" = Table.SelectRows(#"Colonnes supprimées", each [Date statut terminée] > #date(2023, 12, 31)),
		    #"Lignes filtrées1" = Table.SelectRows(#"Lignes filtrées", each ([Statut AMT] = "AMT terminée")),
		
		    // Ajout colonne délai 'En-cours' > 'A valider' 
		    AjoutColonneDélaiEnCoursAValider = Table.AddColumn(#"Lignes filtrées1", "délai 'En-cours' > 'A valider'", each if[Date statut en cours]="01/01/1900" then 0
		        else if[Date statut à valider]<[Date statut en cours] then 0 else [Date statut à valider]-[Date statut en cours], type duration),
		
		    // Ajout colonne "Délai 'A valider' > 'Validée'"
		    AjoutColonneDélaiAValiderValidee = Table.AddColumn(AjoutColonneDélaiEnCoursAValider, "Délai 'A valider' > 'Validée'", each if[Date statut à valider] = "01/01/1900" then 0 
		        else if[Date statut validée]<[Date statut à valider] then 0 else [Date statut validée]-[Date statut à valider], type duration),
		
		    // Ajout colonne "Délai 'A faire' > 'terminée'"
		    AjoutColonneDélaiAfaireTerminee = Table.AddColumn(AjoutColonneDélaiAValiderValidee, "Délai 'A faire' > 'Terminée'", each if[Date statut terminée]="01/01/1900" then 0
		        else if[Date statut terminée]<[Date statut à faire] then 0 else [Date statut terminée]-[Date statut à faire], type duration),
		
		    // Ajout colonne "Délai 'A faire' > 'En-cours'"
		    AjoutColonneDélaiAfaireEnCours = Table.AddColumn(AjoutColonneDélaiAfaireTerminee, "Délai 'A faire' > 'En-cours'", each if[Date statut en cours]="01/01/1900" then 0
		        else if[Date statut en cours]<[Date statut à faire] then 0 else [Date statut en cours]-[Date statut à faire], type duration),
		    #"Requêtes fusionnées" = Table.NestedJoin(AjoutColonneDélaiAfaireEnCours, {"Identifiant AMT"}, #"0 - AMT par entreprise  import", {"Identifiant AMT"}, "0 - AMT par entreprise  import", JoinKind.LeftOuter),
		    #"0 - AMT par entreprise  import développé" = Table.ExpandTableColumn(#"Requêtes fusionnées", "0 - AMT par entreprise  import", {"Matricule Padoa", "Équipe médicale", "Zone géographique (centre convocation)"}, {"Matricule Padoa", "Équipe médicale", "Zone géographique (centre convocation)"})
		in
		    #"0 - AMT par entreprise  import développé"
