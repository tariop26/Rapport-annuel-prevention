expression '0 - Communes' = ```
		let
		    // 1. Connexion et typage initial (inchangé mais nettoyage immédiat)
		    Source = Json.Document(Web.Contents("https://pst38.sharepoint.com/sites/a_ETO_DG_DOP-Sectorisation/Documents%20partages/Carto/Carto PBI/communes-de-lisere.json")),
		    #"Converti en table" = Table.FromList(Source, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
		    
		    // 2. Expansion CIBLÉE (On ne prend que ce qui sert : Nom, INSEE, Pop, Surface)
		    // On ignore volontairement geo_shape et geo_point qui alourdissent la requête
		    #"Enregistrement développé" = Table.ExpandRecordColumn(#"Converti en table", "Column1", 
		        {"nom", "numero", "surface", "com_arm_pop_mun"}, 
		        {"Commune", "Code INSEE", "surface", "com_arm_pop_mun"}
		    ),
		    #"Valeur remplacée1" = Table.ReplaceValue(#"Enregistrement développé",".",",",Replacer.ReplaceText,{"surface"}),
		
		    // 3. Typage des données
		    #"Type modifié" = Table.TransformColumnTypes(#"Valeur remplacée1",{
		        {"Commune", type text}, 
		        {"Code INSEE", type text}, // INSEE doit être du texte (ex: 38001) pour éviter perte du 0
		        {"surface", type number}, // Changé en number pour le tri
		        {"com_arm_pop_mun", type number}
		    }),
		
		    // 4. Nettoyage spécifique (Ex: Les Éparres)
		    #"Valeur remplacée" = Table.ReplaceValue(#"Type modifié","Les Éparres","Eparres",Replacer.ReplaceText,{"Commune"}),
		    #"Requêtes fusionnées1" = Table.NestedJoin(#"Valeur remplacée", {"Code INSEE"}, #"Codes postaux / INSEE", {"Code INSEE"}, "Codes postaux / INSEE", JoinKind.LeftOuter),
		    #"Codes postaux / INSEE développé" = Table.ExpandTableColumn(#"Requêtes fusionnées1", "Codes postaux / INSEE", {"Code Postal / CEDEX"}, {"Code Postal / CEDEX"}),
		    #"Lignes triées" = Table.Sort(#"Codes postaux / INSEE développé",{{"Code Postal / CEDEX", Order.Ascending}, {"com_arm_pop_mun", Order.Descending}, {"surface", Order.Descending}}),
		    #"Requêtes fusionnées" = Table.NestedJoin(#"Lignes triées", {"Code INSEE"}, #"0 - SPSTI par commune", {"Code INSEE"}, "0 - SPSTI par commune", JoinKind.LeftOuter),
		    #"0 - SPSTI par commune développé" = Table.ExpandTableColumn(#"Requêtes fusionnées", "0 - SPSTI par commune", {"SPSTI"}, {"SPSTI"}),
		    #"Lignes filtrées" = Table.SelectRows(#"0 - SPSTI par commune développé", each ([SPSTI] = "PST38"))
		in
		    #"Lignes filtrées"
		```
